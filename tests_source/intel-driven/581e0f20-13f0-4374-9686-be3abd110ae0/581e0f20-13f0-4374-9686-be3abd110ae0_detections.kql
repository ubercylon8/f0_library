// ============================================================
// F0RT1KA Detection Queries - Ransomware Encryption via BitLocker
// Test ID: 581e0f20-13f0-4374-9686-be3abd110ae0
// MITRE ATT&CK: T1070.001, T1562.004, T1082, T1083, T1486, T1490
// Generated: 2024-12-07
// ============================================================
//
// These KQL queries are designed for Microsoft Sentinel and
// Microsoft Defender for Endpoint. Deploy to detect BitLocker-based
// ransomware activity as simulated by this F0RT1KA test.
//
// Query Index:
// 1. Event Log Clearing Detection (T1070.001)
// 2. Firewall Rule Manipulation Detection (T1562.004)
// 3. System Enumeration via WMIC (T1082)
// 4. Drive Enumeration Detection (T1083)
// 5. BitLocker Encryption Detection (T1486)
// 6. VHD Creation Detection (T1486)
// 7. VSS Shadow Copy Deletion (T1490)
// 8. BitLocker Ransomware Behavioral Correlation (High-Confidence)
// ============================================================


// ============================================================
// Detection 1: Event Log Clearing (T1070.001)
// Test ID: 581e0f20-13f0-4374-9686-be3abd110ae0
// MITRE ATT&CK: T1070.001
// Confidence: High
// ============================================================
// Purpose: Detect wevtutil.exe clearing event logs
// False Positives: IT admin maintenance, automated log rotation scripts
// Threshold: Alert on any occurrence outside maintenance windows
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName =~ "wevtutil.exe"
| where ProcessCommandLine has "cl" or ProcessCommandLine has "clear-log"
| extend LogCleared = extract(@"cl\s+(\S+)", 1, ProcessCommandLine)
| extend
    Severity = "High",
    ThreatType = "Defense Evasion - Log Clearing",
    MitreAttack = "T1070.001",
    TestID = "581e0f20-13f0-4374-9686-be3abd110ae0"
| project TimeGenerated, DeviceName, AccountName, AccountDomain, ProcessCommandLine, LogCleared, InitiatingProcessFileName, Severity, ThreatType, MitreAttack, TestID


// ============================================================
// Detection 2: Firewall Rule Manipulation (T1562.004)
// Test ID: 581e0f20-13f0-4374-9686-be3abd110ae0
// MITRE ATT&CK: T1562.004
// Confidence: Medium
// ============================================================
// Purpose: Detect netsh firewall rule additions or deletions
// False Positives: Software installation, IT admin configuration
// Threshold: Alert on patterns showing rapid add/delete or suspicious rule names
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName =~ "netsh.exe"
| where ProcessCommandLine has "advfirewall" and ProcessCommandLine has "firewall"
| where ProcessCommandLine has_any ("add rule", "delete rule", "set rule")
| extend
    FirewallAction = case(
        ProcessCommandLine has "add rule", "Add",
        ProcessCommandLine has "delete rule", "Delete",
        ProcessCommandLine has "set rule", "Modify",
        "Unknown"
    ),
    RuleName = extract(@"name=([^\s]+)", 1, ProcessCommandLine)
| extend
    Severity = "Medium",
    ThreatType = "Defense Evasion - Firewall Manipulation",
    MitreAttack = "T1562.004",
    TestID = "581e0f20-13f0-4374-9686-be3abd110ae0"
| project TimeGenerated, DeviceName, AccountName, ProcessCommandLine, FirewallAction, RuleName, Severity, ThreatType, MitreAttack, TestID


// ============================================================
// Detection 3: System Enumeration via WMIC (T1082)
// Test ID: 581e0f20-13f0-4374-9686-be3abd110ae0
// MITRE ATT&CK: T1082
// Confidence: Low
// ============================================================
// Purpose: Detect system information gathering using WMIC
// False Positives: IT scripts, monitoring tools, legitimate admin activity
// Threshold: Alert when multiple WMIC queries occur in sequence from non-admin processes
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName =~ "wmic.exe"
| where ProcessCommandLine has_any ("computersystem", "os get", "bios", "cpu")
| extend QueryType = case(
    ProcessCommandLine has "computersystem", "ComputerSystem",
    ProcessCommandLine has "os get", "OperatingSystem",
    ProcessCommandLine has "bios", "BIOS",
    ProcessCommandLine has "cpu", "CPU",
    "Other"
)
| extend
    Severity = "Low",
    ThreatType = "Discovery - System Enumeration",
    MitreAttack = "T1082",
    TestID = "581e0f20-13f0-4374-9686-be3abd110ae0"
| project TimeGenerated, DeviceName, AccountName, ProcessCommandLine, QueryType, InitiatingProcessFileName, Severity, ThreatType, MitreAttack, TestID


// ============================================================
// Detection 4: Drive Enumeration Detection (T1083)
// Test ID: 581e0f20-13f0-4374-9686-be3abd110ae0
// MITRE ATT&CK: T1083
// Confidence: Low
// ============================================================
// Purpose: Detect drive and volume enumeration (pre-encryption reconnaissance)
// False Positives: Backup software, disk management tools, admin scripts
// Threshold: Alert when combined with other ransomware indicators
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where (FileName =~ "wmic.exe" and ProcessCommandLine has "logicaldisk")
    or (FileName =~ "fsutil.exe" and ProcessCommandLine has "fsinfo")
    or (FileName =~ "manage-bde.exe" and ProcessCommandLine has "-status")
| extend EnumType = case(
    FileName =~ "wmic.exe", "WMIC LogicalDisk",
    FileName =~ "fsutil.exe", "FSUtil",
    FileName =~ "manage-bde.exe", "BitLocker Status",
    "Other"
)
| extend
    Severity = "Low",
    ThreatType = "Discovery - Drive Enumeration",
    MitreAttack = "T1083",
    TestID = "581e0f20-13f0-4374-9686-be3abd110ae0"
| project TimeGenerated, DeviceName, AccountName, ProcessCommandLine, EnumType, InitiatingProcessFileName, Severity, ThreatType, MitreAttack, TestID


// ============================================================
// Detection 5: BitLocker Encryption Detection (T1486)
// Test ID: 581e0f20-13f0-4374-9686-be3abd110ae0
// MITRE ATT&CK: T1486
// Confidence: High
// ============================================================
// Purpose: Detect BitLocker encryption being enabled, especially with password
// False Positives: IT BitLocker deployment, legitimate encryption
// Threshold: Alert on password-based BitLocker (unusual - should be TPM)
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName =~ "manage-bde.exe"
| where ProcessCommandLine has "-on"
| extend
    UsesPassword = ProcessCommandLine has "-Password",
    TargetVolume = extract(@"-on\s+(\w:)", 1, ProcessCommandLine),
    UsedSpaceOnly = ProcessCommandLine has "-UsedSpaceOnly"
| extend
    Severity = iff(UsesPassword, "Critical", "High"),
    ThreatType = "Impact - BitLocker Encryption",
    MitreAttack = "T1486",
    TestID = "581e0f20-13f0-4374-9686-be3abd110ae0",
    AlertNote = iff(UsesPassword, "PASSWORD-BASED BITLOCKER - HIGH RANSOMWARE INDICATOR", "Standard BitLocker encryption")
| project TimeGenerated, DeviceName, AccountName, ProcessCommandLine, TargetVolume, UsesPassword, UsedSpaceOnly, AlertNote, Severity, ThreatType, MitreAttack, TestID


// ============================================================
// Detection 6: VHD Creation Detection (T1486)
// Test ID: 581e0f20-13f0-4374-9686-be3abd110ae0
// MITRE ATT&CK: T1486
// Confidence: Medium
// ============================================================
// Purpose: Detect VHD creation which may be used for isolated encryption
// False Positives: Hyper-V operations, developer VMs, legitimate VHD usage
// Threshold: Alert when VHD creation is combined with BitLocker commands
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName =~ "diskpart.exe"
| where ProcessCommandLine has "/s" // Script mode
| extend
    Severity = "Medium",
    ThreatType = "Impact - VHD Operations",
    MitreAttack = "T1486",
    TestID = "581e0f20-13f0-4374-9686-be3abd110ae0"
| project TimeGenerated, DeviceName, AccountName, ProcessCommandLine, InitiatingProcessFileName, Severity, ThreatType, MitreAttack, TestID

// Alternative: File creation monitoring for VHD files
DeviceFileEvents
| where TimeGenerated > ago(24h)
| where FileName endswith ".vhd" or FileName endswith ".vhdx"
| where ActionType in ("FileCreated", "FileModified")
| extend
    Severity = "Medium",
    ThreatType = "Impact - VHD File Creation",
    MitreAttack = "T1486",
    TestID = "581e0f20-13f0-4374-9686-be3abd110ae0"
| project TimeGenerated, DeviceName, InitiatingProcessAccountName, FileName, FolderPath, ActionType, Severity, ThreatType, MitreAttack, TestID


// ============================================================
// Detection 7: VSS Shadow Copy Deletion (T1490)
// Test ID: 581e0f20-13f0-4374-9686-be3abd110ae0
// MITRE ATT&CK: T1490
// Confidence: Critical
// ============================================================
// Purpose: Detect Volume Shadow Copy deletion - strong ransomware indicator
// False Positives: Rare - some backup software, disk maintenance
// Threshold: Alert on any occurrence - very high ransomware correlation
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where (FileName =~ "vssadmin.exe" and ProcessCommandLine has "delete" and ProcessCommandLine has "shadows")
    or (FileName =~ "wmic.exe" and ProcessCommandLine has "shadowcopy" and ProcessCommandLine has "delete")
    or (FileName =~ "wbadmin.exe" and ProcessCommandLine has "delete" and ProcessCommandLine has "catalog")
| extend
    DeletionMethod = case(
        FileName =~ "vssadmin.exe", "vssadmin",
        FileName =~ "wmic.exe", "wmic shadowcopy",
        FileName =~ "wbadmin.exe", "wbadmin catalog",
        "Other"
    ),
    TargetVolume = extract(@"/for=(\w:)", 1, ProcessCommandLine),
    QuietMode = ProcessCommandLine has "/quiet" or ProcessCommandLine has "/q"
| extend
    Severity = "Critical",
    ThreatType = "Impact - Shadow Copy Deletion (Ransomware Indicator)",
    MitreAttack = "T1490",
    TestID = "581e0f20-13f0-4374-9686-be3abd110ae0"
| project TimeGenerated, DeviceName, AccountName, ProcessCommandLine, DeletionMethod, TargetVolume, QuietMode, Severity, ThreatType, MitreAttack, TestID


// ============================================================
// Detection 8: BitLocker Ransomware Behavioral Correlation
// Test ID: 581e0f20-13f0-4374-9686-be3abd110ae0
// MITRE ATT&CK: T1070.001, T1562.004, T1082, T1083, T1486, T1490
// Confidence: Critical (Multi-indicator correlation)
// ============================================================
// Purpose: Correlate multiple indicators for high-confidence ransomware detection
// False Positives: Very rare - combination is highly specific
// Threshold: Alert immediately on 2+ indicators within 1 hour window
// ============================================================

let TimeWindow = 1h;
let SuspiciousCommands = DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where
    // Stage 1: Defense Evasion
    (FileName =~ "wevtutil.exe" and ProcessCommandLine has "cl")
    or (FileName =~ "netsh.exe" and ProcessCommandLine has "advfirewall" and ProcessCommandLine has_any ("add rule", "delete rule"))
    // Stage 2: Discovery
    or (FileName =~ "wmic.exe" and ProcessCommandLine has_any ("computersystem", "os get", "logicaldisk"))
    or (FileName =~ "manage-bde.exe" and ProcessCommandLine has "-status")
    // Stage 3: Impact
    or (FileName =~ "manage-bde.exe" and ProcessCommandLine has "-on")
    or (FileName =~ "vssadmin.exe" and ProcessCommandLine has "delete" and ProcessCommandLine has "shadows")
    or (FileName =~ "diskpart.exe" and ProcessCommandLine has "/s")
| extend
    TechniqueCategory = case(
        FileName =~ "wevtutil.exe", "T1070.001-EventLogClear",
        FileName =~ "netsh.exe", "T1562.004-FirewallManip",
        FileName =~ "wmic.exe" and ProcessCommandLine has_any ("computersystem", "os get"), "T1082-SystemDiscovery",
        FileName =~ "wmic.exe" and ProcessCommandLine has "logicaldisk", "T1083-DriveDiscovery",
        FileName =~ "manage-bde.exe" and ProcessCommandLine has "-status", "T1083-BitLockerRecon",
        FileName =~ "manage-bde.exe" and ProcessCommandLine has "-on", "T1486-BitLockerEncrypt",
        FileName =~ "vssadmin.exe", "T1490-ShadowDelete",
        FileName =~ "diskpart.exe", "T1486-VHDOperation",
        "Other"
    )
| summarize
    CommandCount = count(),
    TechniquesUsed = make_set(TechniqueCategory),
    UniqueTools = make_set(FileName),
    CommandLines = make_list(ProcessCommandLine),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated)
    by DeviceName, AccountName, bin(TimeGenerated, TimeWindow)
| where CommandCount >= 2
| extend
    ThreatScore = case(
        CommandCount >= 5, 100,
        CommandCount >= 4, 95,
        CommandCount >= 3, 85,
        CommandCount >= 2, 70,
        50
    ),
    AttackStageReached = case(
        array_length(TechniquesUsed) >= 5, "Full Chain - Impact",
        TechniquesUsed has_any ("T1486-BitLockerEncrypt", "T1490-ShadowDelete"), "Stage 3 - Impact",
        TechniquesUsed has_any ("T1082-SystemDiscovery", "T1083-DriveDiscovery"), "Stage 2 - Discovery",
        TechniquesUsed has_any ("T1070.001-EventLogClear", "T1562.004-FirewallManip"), "Stage 1 - Defense Evasion",
        "Unknown"
    )
| extend
    Severity = "Critical",
    ThreatType = "BitLocker Ransomware Activity Chain",
    MitreAttack = "T1070.001,T1562.004,T1082,T1083,T1486,T1490",
    TestID = "581e0f20-13f0-4374-9686-be3abd110ae0"
| project TimeGenerated=FirstSeen, DeviceName, AccountName, CommandCount, TechniquesUsed, UniqueTools, AttackStageReached, ThreatScore, Duration=datetime_diff('minute', LastSeen, FirstSeen), Severity, ThreatType, MitreAttack, TestID
| order by ThreatScore desc


// ============================================================
// Detection 9: Suspicious File Activity in Staging Directories
// Test ID: 581e0f20-13f0-4374-9686-be3abd110ae0
// Purpose: Detect suspicious file creation in common attacker staging paths
// ============================================================
// Real attackers commonly use TEMP, AppData, Public, and ProgramData
// for staging malicious files before execution
// ============================================================

DeviceFileEvents
| where TimeGenerated > ago(24h)
| where ActionType in ("FileCreated", "FileModified")
| where FileName endswith ".exe" or FileName endswith ".vhd" or FileName endswith ".ps1"
| where FolderPath matches regex @"(?i)(\\Temp\\|\\AppData\\|\\Users\\Public\\|\\ProgramData\\)"
| where not(FolderPath has_any ("Microsoft", "Windows Defender", "Google", "Mozilla"))  // Reduce false positives
| extend
    StagingLocation = case(
        FolderPath has "\\Temp\\", "TEMP Directory",
        FolderPath has "\\AppData\\", "AppData Directory",
        FolderPath has "\\Users\\Public\\", "Public User Directory",
        FolderPath has "\\ProgramData\\", "ProgramData Directory",
        "Other Staging Location"
    ),
    FileType = case(
        FileName endswith ".exe", "Executable",
        FileName endswith ".vhd", "Virtual Hard Disk",
        FileName endswith ".ps1", "PowerShell Script",
        "Other"
    )
| extend
    Severity = iff(FileType == "Virtual Hard Disk", "High", "Medium"),
    ThreatType = "Suspicious File in Staging Directory",
    MitreAttack = "T1486",
    TestID = "581e0f20-13f0-4374-9686-be3abd110ae0"
| project TimeGenerated, DeviceName, InitiatingProcessAccountName, FileName, FolderPath, StagingLocation, FileType, ActionType, Severity, ThreatType, MitreAttack, TestID


// ============================================================
// END OF DETECTION QUERIES
// ============================================================
