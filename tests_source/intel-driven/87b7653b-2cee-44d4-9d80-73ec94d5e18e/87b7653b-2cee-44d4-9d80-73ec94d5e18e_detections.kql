// ============================================================
// EDR-Freeze Defense Evasion - Detection Queries
// Test ID: 87b7653b-2cee-44d4-9d80-73ec94d5e18e
// MITRE ATT&CK: T1562.001, T1055, T1574
// Author: F0RT1KA Defense Guidance Builder
// Version: 2.0.0
// Date: 2025-12-07
// ============================================================
//
// This file contains KQL queries for Microsoft Sentinel and
// Microsoft Defender for Endpoint to detect EDR-Freeze attacks
// and associated behaviors.
//
// Query Index:
//   1. WerFaultSecure Targeting Security Processes (HIGH)
//   2. Certutil Downloading Executables (HIGH)
//   3. Security Process Thread Suspension Anomalies (CRITICAL)
//   4. WerFaultSecure PPL Process Creation (HIGH)
//   5. Full Attack Chain Correlation (CRITICAL)
//   6. File Staging in C:\F0 Directory (MEDIUM)
//   7. CreateProcessAsPPL Usage Detection (HIGH)
//   8. Defender Process Termination/Suspension (CRITICAL)
//   9. LOLBin Network Downloads (HIGH)
//   10. Multi-Indicator Time Correlation (CRITICAL)
//   11. EDR-Freeze Tool Direct Detection (CRITICAL)
//   12. WerFault Memory Dump Targeting Security Processes (HIGH)
//   13. Process Suspension Chain Analysis (HIGH)
//   14. Seatbelt Reconnaissance Tool Detection (HIGH)
//   15. Defense Evasion Summary Dashboard (AGGREGATION)
//
// ============================================================


// ============================================================
// Query 1: WerFaultSecure Targeting Security Processes
// ============================================================
// Purpose: Detects WerFaultSecure.exe launched with command-line
//          parameters targeting security processes
// Confidence: HIGH
// False Positives: Legitimate crash dumps of security processes
//                  (rare, verify with WER reports)
// Threshold: Any occurrence should be investigated
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName =~ "WerFaultSecure.exe"
| where ProcessCommandLine has_any (
    "MsMpEng",
    "MpDefenderCoreService",
    "NisSrv",
    "SenseCE",
    "SenseIR",
    "SenseNdr",
    "MsSense",
    "CylanceSvc",
    "CSFalconService",
    "CrowdStrike",
    "TmListen",
    "TmCCSF",
    "SentinelOne",
    "cb.exe",
    "RepMgr",
    "RepUtils",
    "RepWsc"
)
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    AccountDomain,
    ProcessId,
    ProcessCommandLine,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    InitiatingProcessId,
    InitiatingProcessParentFileName
| extend
    Severity = "High",
    ThreatType = "Defense Evasion - WerFaultSecure Abuse",
    MitreAttack = "T1562.001",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = "WerFaultSecure.exe launched with parameters targeting security process"


// ============================================================
// Query 2: Certutil Downloading Executables
// ============================================================
// Purpose: Detects certutil.exe being used to download executable
//          files from the internet
// Confidence: HIGH
// False Positives: Legitimate certificate verification tasks
//                  (review URL and file type)
// Threshold: Any .exe download should be investigated
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName =~ "certutil.exe"
| where ProcessCommandLine has_any ("-urlfetch", "-urlcache", "-verifyctl", "-ping")
| where ProcessCommandLine has_any (".exe", ".dll", ".ps1", ".bat", ".vbs", ".js", ".hta")
| extend
    DownloadURL = extract(@"https?://[^\s""']+", 0, ProcessCommandLine),
    TargetFile = extract(@"[A-Za-z]:\\[^\s""']+\.(exe|dll|ps1|bat)", 0, ProcessCommandLine)
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    AccountDomain,
    ProcessId,
    ProcessCommandLine,
    DownloadURL,
    TargetFile,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine
| extend
    Severity = "High",
    ThreatType = "Malicious Download via Certutil (LOLBin)",
    MitreAttack = "T1105",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = "Certutil.exe used to download executable content"


// ============================================================
// Query 3: Security Process Thread Suspension Anomalies
// ============================================================
// Purpose: Detects unusual thread suspension events in security
//          processes indicating EDR-Freeze or similar attacks
// Confidence: HIGH
// False Positives: Legitimate debugging activities, crash dumps
// Threshold: Suspension > 5 seconds or multiple suspensions
// ============================================================

DeviceEvents
| where TimeGenerated > ago(24h)
| where ActionType in ("ThreadSuspended", "ProcessSuspended", "SuspendThread")
| where FileName in~ (
    "MsMpEng.exe",
    "MpDefenderCoreService.exe",
    "NisSrv.exe",
    "SenseCE.exe",
    "SenseIR.exe",
    "MsSense.exe",
    "CylanceSvc.exe",
    "CSFalconService.exe",
    "SentinelAgent.exe"
)
| summarize
    SuspensionCount = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    SuspensionDurationSec = datetime_diff('second', max(TimeGenerated), min(TimeGenerated)),
    InitiatingProcesses = make_set(InitiatingProcessFileName)
    by DeviceName, FileName
| where SuspensionDurationSec > 5 or SuspensionCount > 1
| extend
    Severity = "Critical",
    ThreatType = "Security Process Manipulation",
    MitreAttack = "T1562.001",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("Security process ", FileName, " suspended for ", SuspensionDurationSec, " seconds")


// ============================================================
// Query 4: WerFaultSecure PPL Process Creation
// ============================================================
// Purpose: Detects WerFaultSecure being launched as PPL with
//          specific parameters indicating memory dump abuse
// Confidence: HIGH
// False Positives: Legitimate WER crash reporting (check context)
// Threshold: Presence of /h, /pid, /tid, /encfile parameters
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName =~ "WerFaultSecure.exe"
| where ProcessCommandLine has "/h"
| extend
    HasPID = ProcessCommandLine has "/pid",
    HasTID = ProcessCommandLine has "/tid",
    HasEncFile = ProcessCommandLine has "/encfile",
    TargetPID = extract(@"/pid[:\s]+(\d+)", 1, ProcessCommandLine)
| where HasPID and HasTID
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    ProcessId,
    ProcessCommandLine,
    TargetPID,
    HasEncFile,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    InitiatingProcessId
| extend
    Severity = "High",
    ThreatType = "WerFaultSecure PPL Abuse",
    MitreAttack = "T1574",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("WerFaultSecure launched with PPL parameters targeting PID ", TargetPID)


// ============================================================
// Query 5: Full Attack Chain Correlation - EDR-Freeze Pattern
// ============================================================
// Purpose: Correlates WerFaultSecure abuse with subsequent
//          malicious activity for high-confidence detection
// Confidence: VERY HIGH
// False Positives: Very rare - full chain is highly specific
// Threshold: Any match indicates active attack
// ============================================================

let WerFaultAbuseEvents = DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where FileName =~ "WerFaultSecure.exe"
| where ProcessCommandLine has_any ("MsMpEng", "MpDefenderCoreService", "NisSrv", "Sense", "Defender")
| project
    WerFaultTime = TimeGenerated,
    DeviceName,
    WerFaultAccount = AccountName,
    WerFaultCommand = ProcessCommandLine,
    WerFaultPID = ProcessId;

let CertutilDownloads = DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where FileName =~ "certutil.exe"
| where ProcessCommandLine has_any ("-urlfetch", "-urlcache", "-verifyctl")
| where ProcessCommandLine has_any (".exe", ".dll")
| project
    CertutilTime = TimeGenerated,
    DeviceName,
    CertutilAccount = AccountName,
    CertutilCommand = ProcessCommandLine;

let EDRFreezeExecution = DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where FileName =~ "EDR-Freeze.exe" or ProcessCommandLine has "EDR-Freeze"
| project
    EDRFreezeTime = TimeGenerated,
    DeviceName,
    EDRFreezeAccount = AccountName,
    EDRFreezeCommand = ProcessCommandLine;

WerFaultAbuseEvents
| join kind=leftouter (CertutilDownloads) on DeviceName
| join kind=leftouter (EDRFreezeExecution) on DeviceName
| where (CertutilTime between (WerFaultTime .. (WerFaultTime + 120s)))
    or (EDRFreezeTime between ((WerFaultTime - 30s) .. WerFaultTime))
| project
    TimeGenerated = WerFaultTime,
    DeviceName,
    WerFaultAccount,
    WerFaultCommand,
    CertutilTime,
    CertutilCommand,
    EDRFreezeTime,
    EDRFreezeCommand,
    TimeDeltaCertutil = datetime_diff('second', CertutilTime, WerFaultTime),
    TimeDeltaEDRFreeze = datetime_diff('second', WerFaultTime, EDRFreezeTime)
| extend
    Severity = "Critical",
    ThreatType = "EDR-Freeze Attack Chain Detected",
    MitreAttack = "T1562.001, T1055, T1574",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = "Full EDR-Freeze attack pattern detected: WerFaultSecure abuse followed by malicious download"


// ============================================================
// Query 6: File Staging in C:\F0 Directory
// ============================================================
// Purpose: Detects files being created in C:\F0 directory
//          (F0RT1KA test staging area) or other suspicious locations
// Confidence: MEDIUM
// False Positives: Legitimate F0RT1KA test executions
// Threshold: Review context and initiating process
// ============================================================

DeviceFileEvents
| where TimeGenerated > ago(24h)
| where ActionType == "FileCreated"
| where FolderPath startswith @"C:\F0\"
    or FolderPath startswith @"C:\Temp\"
    or FolderPath startswith @"C:\Users\Public\"
| where FileName endswith ".exe" or FileName endswith ".dll" or FileName endswith ".ps1"
| where InitiatingProcessFileName !in~ ("explorer.exe", "msiexec.exe", "MpCmdRun.exe", "setup.exe")
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    FileName,
    FolderPath,
    SHA256,
    FileSize,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    InitiatingProcessFolderPath
| extend
    Severity = "Medium",
    ThreatType = "Suspicious File Staging",
    MitreAttack = "T1074",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("Executable file ", FileName, " created in staging directory")


// ============================================================
// Query 7: CreateProcessAsPPL Usage Detection
// ============================================================
// Purpose: Detects processes attempting to create PPL
//          (Protected Process Light) processes
// Confidence: HIGH
// False Positives: Rare - legitimate PPL creation is system-only
// Threshold: Any non-system PPL creation attempt
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where ProcessCommandLine has_any ("CreateProcessAsPPL", "WinTCB", "ProtectionLevel", "PsProtectedSigner")
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    FileName,
    ProcessId,
    ProcessCommandLine,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    InitiatingProcessFolderPath
| extend
    Severity = "High",
    ThreatType = "PPL Process Creation Attempt",
    MitreAttack = "T1055, T1574",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = "Process attempted to create Protected Process Light (PPL)"


// ============================================================
// Query 8: Defender Process Termination/Suspension
// ============================================================
// Purpose: Detects direct termination or suspension of Defender
//          processes indicating successful defense evasion
// Confidence: CRITICAL
// False Positives: System updates, legitimate maintenance
// Threshold: Any occurrence during non-maintenance windows
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName in~ ("MsMpEng.exe", "MpDefenderCoreService.exe", "NisSrv.exe", "SecurityHealthService.exe")
| where ActionType in ("ProcessTerminated", "ProcessSuspended")
| project
    TimeGenerated,
    DeviceName,
    ActionType,
    FileName,
    ProcessId,
    ProcessCommandLine,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    InitiatingProcessId,
    InitiatingProcessParentFileName
| extend
    Severity = "Critical",
    ThreatType = "Defender Process Termination/Suspension",
    MitreAttack = "T1562.001",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("Defender process ", FileName, " was ", ActionType)


// ============================================================
// Query 9: LOLBin Network Downloads from Known Repositories
// ============================================================
// Purpose: Detects Living-Off-the-Land binaries downloading
//          content from known malicious tool repositories
// Confidence: HIGH
// False Positives: Developers downloading legitimate tools
// Threshold: Downloads of executable content
// ============================================================

DeviceNetworkEvents
| where TimeGenerated > ago(24h)
| where InitiatingProcessFileName in~ ("certutil.exe", "bitsadmin.exe", "curl.exe", "wget.exe", "powershell.exe")
| where RemoteUrl has_any (
    "github.com",
    "raw.githubusercontent.com",
    "pastebin.com",
    "gist.github.com",
    "ghostbin.com",
    "hastebin.com",
    "transfer.sh"
)
| where RemoteUrl has_any (".exe", ".dll", ".ps1", ".bat", "Seatbelt", "SharpCollection", "Mimikatz", "Rubeus")
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    RemoteUrl,
    RemoteIP,
    RemotePort
| extend
    Severity = "High",
    ThreatType = "Malicious Download via LOLBin",
    MitreAttack = "T1105",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("LOLBin ", InitiatingProcessFileName, " downloaded from ", RemoteUrl)


// ============================================================
// Query 10: Multi-Indicator Time Correlation
// ============================================================
// Purpose: Aggregates multiple suspicious events within a time
//          window for high-confidence threat detection
// Confidence: CRITICAL
// False Positives: Very rare when multiple indicators present
// Threshold: 2+ indicators within 5-minute window
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where (
    (FileName =~ "WerFaultSecure.exe" and ProcessCommandLine has_any ("MsMpEng", "MpDefenderCoreService", "Defender"))
    or (FileName =~ "certutil.exe" and ProcessCommandLine has_any ("-urlfetch", "-urlcache"))
    or (FileName =~ "EDR-Freeze.exe")
    or (ProcessCommandLine has "CreateProcessAsPPL")
    or (FileName has "Seatbelt")
)
| extend IndicatorType = case(
    FileName =~ "WerFaultSecure.exe", "WerFaultSecure_Abuse",
    FileName =~ "certutil.exe", "Certutil_Download",
    FileName =~ "EDR-Freeze.exe", "EDR_Freeze_Tool",
    ProcessCommandLine has "CreateProcessAsPPL", "PPL_Creation",
    FileName has "Seatbelt", "Seatbelt_Tool",
    "Unknown"
)
| summarize
    EventCount = count(),
    IndicatorTypes = make_set(IndicatorType),
    FileNames = make_set(FileName),
    Commands = make_set(ProcessCommandLine),
    FirstEvent = min(TimeGenerated),
    LastEvent = max(TimeGenerated)
    by DeviceName, AccountName, bin(TimeGenerated, 5m)
| where EventCount >= 2
| extend TimeWindowSec = datetime_diff('second', LastEvent, FirstEvent)
| project
    TimeGenerated = FirstEvent,
    DeviceName,
    AccountName,
    EventCount,
    IndicatorTypes,
    FileNames,
    TimeWindowSec
| extend
    Severity = "Critical",
    ThreatType = "Multiple Defense Evasion Indicators",
    MitreAttack = "T1562.001, T1055, T1574",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("Multiple (", EventCount, ") defense evasion indicators detected within ", TimeWindowSec, " seconds")


// ============================================================
// Query 11: EDR-Freeze Tool Direct Detection
// ============================================================
// Purpose: Directly detects EDR-Freeze.exe execution or files
// Confidence: CRITICAL
// False Positives: Authorized security testing (verify with F0RT1KA logs)
// Threshold: Any detection indicates attack or test
// ============================================================

union
(
    DeviceProcessEvents
    | where TimeGenerated > ago(24h)
    | where FileName =~ "EDR-Freeze.exe"
        or ProcessCommandLine has "EDR-Freeze"
        or InitiatingProcessFileName =~ "EDR-Freeze.exe"
    | extend EventType = "ProcessExecution"
),
(
    DeviceFileEvents
    | where TimeGenerated > ago(24h)
    | where FileName =~ "EDR-Freeze.exe"
    | extend EventType = ActionType
)
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    EventType,
    FileName,
    FolderPath,
    ProcessCommandLine,
    SHA256,
    InitiatingProcessFileName
| extend
    Severity = "Critical",
    ThreatType = "EDR-Freeze Tool Detected",
    MitreAttack = "T1562.001",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("EDR-Freeze tool detected: ", EventType)


// ============================================================
// Query 12: WerFault Memory Dump Targeting Security Processes
// ============================================================
// Purpose: Detects WerFault/WerFaultSecure creating memory dumps
//          of security-related processes
// Confidence: HIGH
// False Positives: Legitimate crash reporting (verify dump location)
// Threshold: Dumps of security processes in non-standard locations
// ============================================================

DeviceFileEvents
| where TimeGenerated > ago(24h)
| where InitiatingProcessFileName in~ ("WerFault.exe", "WerFaultSecure.exe")
| where ActionType == "FileCreated"
| where FileName endswith ".dmp" or FileName endswith ".hdmp" or FileName endswith ".mdmp"
| where FileName has_any ("MsMpEng", "MpDefenderCoreService", "NisSrv", "Sense", "Defender")
    or FolderPath !startswith @"C:\ProgramData\Microsoft\Windows\WER\"
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    FileName,
    FolderPath,
    FileSize,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine
| extend
    Severity = "High",
    ThreatType = "Suspicious Memory Dump of Security Process",
    MitreAttack = "T1003",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("Memory dump created for security process: ", FileName)


// ============================================================
// Query 13: Process Suspension Chain Analysis
// ============================================================
// Purpose: Analyzes parent-child relationships in process
//          suspension events to identify attack chains
// Confidence: HIGH
// False Positives: Complex debugging scenarios
// Threshold: Suspension chains involving security processes
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where ActionType == "ProcessCreated"
| where FileName in~ ("WerFaultSecure.exe", "WerFault.exe")
| join kind=inner (
    DeviceEvents
    | where ActionType has "Suspend"
    | where FileName in~ ("MsMpEng.exe", "MpDefenderCoreService.exe", "NisSrv.exe")
) on DeviceName
| where TimeGenerated1 between (TimeGenerated .. (TimeGenerated + 30s))
| project
    WerFaultCreation = TimeGenerated,
    SuspensionEvent = TimeGenerated1,
    DeviceName,
    AccountName,
    WerFaultPID = ProcessId,
    WerFaultCommand = ProcessCommandLine,
    SuspendedProcess = FileName1,
    TimeDelta = datetime_diff('second', TimeGenerated1, TimeGenerated)
| extend
    Severity = "High",
    ThreatType = "WerFault-Based Process Suspension Chain",
    MitreAttack = "T1562.001, T1574",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("WerFault created and ", SuspendedProcess, " suspended within ", TimeDelta, " seconds")


// ============================================================
// Query 14: Seatbelt Reconnaissance Tool Detection
// ============================================================
// Purpose: Detects Seatbelt.exe (post-exploitation tool) execution
//          or download, often used after EDR-Freeze success
// Confidence: HIGH
// False Positives: Authorized red team engagements
// Threshold: Any detection indicates compromise or test
// ============================================================

union
(
    DeviceProcessEvents
    | where TimeGenerated > ago(24h)
    | where FileName =~ "Seatbelt.exe"
        or ProcessCommandLine has "Seatbelt"
    | extend EventType = "Execution"
),
(
    DeviceFileEvents
    | where TimeGenerated > ago(24h)
    | where FileName =~ "Seatbelt.exe"
    | extend EventType = ActionType
),
(
    DeviceNetworkEvents
    | where TimeGenerated > ago(24h)
    | where RemoteUrl has "Seatbelt" or RemoteUrl has "SharpCollection"
    | extend EventType = "Download"
)
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    EventType,
    FileName,
    ProcessCommandLine,
    RemoteUrl
| extend
    Severity = "High",
    ThreatType = "Seatbelt Reconnaissance Tool",
    MitreAttack = "T1082, T1087",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("Seatbelt reconnaissance tool detected: ", EventType)


// ============================================================
// Query 15: Defense Evasion Summary Dashboard
// ============================================================
// Purpose: Aggregates all defense evasion indicators for
//          executive dashboard and trending analysis
// Confidence: AGGREGATION
// False Positives: N/A - summary query
// Threshold: N/A
// ============================================================

let TimeWindow = ago(7d);
union
(
    DeviceProcessEvents
    | where TimeGenerated > TimeWindow
    | where FileName =~ "EDR-Freeze.exe"
    | extend Category = "EDR-Freeze Tool", Severity = "Critical"
),
(
    DeviceProcessEvents
    | where TimeGenerated > TimeWindow
    | where FileName =~ "WerFaultSecure.exe"
    | where ProcessCommandLine has_any ("MsMpEng", "MpDefenderCoreService", "Defender")
    | extend Category = "WerFaultSecure Abuse", Severity = "High"
),
(
    DeviceProcessEvents
    | where TimeGenerated > TimeWindow
    | where FileName =~ "certutil.exe"
    | where ProcessCommandLine has_any ("-urlfetch", "-urlcache") and ProcessCommandLine has ".exe"
    | extend Category = "Certutil Download", Severity = "High"
),
(
    DeviceFileEvents
    | where TimeGenerated > TimeWindow
    | where FolderPath startswith @"C:\F0\" and FileName endswith ".exe"
    | extend Category = "C:\\F0 Staging", Severity = "Medium"
)
| summarize
    TotalEvents = count(),
    AffectedDevices = dcount(DeviceName),
    AffectedAccounts = dcount(AccountName),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated)
    by Category, Severity
| order by Severity desc, TotalEvents desc
| extend
    MitreAttack = "T1562.001",
    TestID = "87b7653b-2cee-44d4-9d80-73ec94d5e18e",
    Description = strcat("Defense evasion indicator summary for past 7 days")


