// ============================================================
// Behavioral Detection Queries for HONESTCUE LLM-Assisted Runtime C# Compilation
// Test ID: e5472cd5-c799-4b07-b455-8c02665ca4cf
// MITRE ATT&CK: T1071.001, T1027.004, T1027.010, T1620, T1105, T1583.006, T1565.001
// Threat Actor: N/A (unattributed per GTIG)
// Generated: 2026-04-13
// ============================================================
// FOCUS: Technique-level attack behaviors. Detections target HONESTCUE-class
// TTPs (LLM-as-runtime, in-memory C# compile + reflective load, Discord CDN
// abuse, hosts-file manipulation), NOT F0RT1KA test artifacts.
// ============================================================


// ============================================================
// QUERY 1: Non-Browser Process Issuing POST to LLM API Endpoints (T1071.001)
// Confidence: Medium-High
// Purpose: Detect direct-from-PE HTTPS POST to known LLM API hostnames by
//          processes that are NOT the allowed set of AI-enabled apps. HONESTCUE
//          issues POST requests to Gemini's generateContent endpoint from a
//          non-browser launcher process.
// False Positives: Authorized internal AI tooling, copilot-integrated IDEs,
//                  data-science workloads.
// Threshold: Any single match from an unusual parent chain warrants review.
// ============================================================
DeviceNetworkEvents
| where TimeGenerated > ago(1h)
| where RemoteUrl has_any ("generativelanguage.googleapis.com",
                           "generativelanguage.googleapis",
                           "api.openai.com",
                           "api.anthropic.com",
                           "api.cohere.ai")
    or RemoteUrl has "v1beta/models" and RemoteUrl has "generateContent"
| where InitiatingProcessFileName !in~ ("chrome.exe", "msedge.exe", "firefox.exe",
                                         "brave.exe", "opera.exe", "iexplore.exe",
                                         "Code.exe", "devenv.exe", "cursor.exe",
                                         "windsurf.exe", "zed.exe")
| project Timestamp, DeviceName, InitiatingProcessFileName,
          InitiatingProcessCommandLine, InitiatingProcessParentFileName,
          RemoteUrl, RemotePort
| sort by Timestamp desc


// ============================================================
// QUERY 2: PowerShell Invoking CSharpCodeProvider In-Memory Compile (T1027.004)
// Confidence: High
// Purpose: Detect the exact AMSI/ScriptBlock logging pattern produced when
//          PowerShell invokes CSharpCodeProvider with GenerateInMemory=true.
//          This is HONESTCUE stage 2's characteristic signature.
// False Positives: Legitimate dev tools. In production environments,
//                  compile-from-powershell should be extremely rare.
// Threshold: Any single match warrants investigation.
// ============================================================
DeviceEvents
| where TimeGenerated > ago(1h)
| where ActionType in ("PowerShellCommand", "ScriptBlockLogging", "AmsiScanEvent")
| where AdditionalFields has_all ("CSharpCodeProvider", "GenerateInMemory")
    or AdditionalFields has_all ("CompileAssemblyFromSource", "CompilerParameters")
| project Timestamp, DeviceName, InitiatingProcessFileName,
          InitiatingProcessCommandLine, InitiatingProcessParentFileName,
          ActionType, AdditionalFields
| sort by Timestamp desc


// ============================================================
// QUERY 3: Reflective Assembly Load via Assembly.Load(byte[]) (T1620)
// Confidence: High
// Purpose: Detect the AMSI event generated by [System.Reflection.Assembly]::Load
//          being invoked with a byte[] argument. This is the canonical reflective
//          load pattern used by HONESTCUE stage 2 and many other offensive tools.
// False Positives: Internally-developed .NET loaders, plugin hosts.
// Threshold: Any single match from an unexpected parent process.
// ============================================================
DeviceEvents
| where TimeGenerated > ago(1h)
| where ActionType in ("AmsiScanEvent", "ScriptBlockLogging")
| where AdditionalFields has "Assembly" and
        (AdditionalFields has "::Load" or AdditionalFields has ".Load(")
| where AdditionalFields has_any ("[byte[]]", "byte[]]", "System.Byte[]")
| project Timestamp, DeviceName, InitiatingProcessFileName,
          InitiatingProcessParentFileName, AdditionalFields
| sort by Timestamp desc


// ============================================================
// QUERY 4: csc.exe Child of powershell.exe (T1027.004 / T1059.001)
// Confidence: High
// Purpose: Detect csc.exe being spawned as a child of powershell.exe. This is
//          the byproduct of CSharpCodeProvider.CompileAssemblyFromSource (even
//          with GenerateInMemory=true, csc.exe is invoked for compilation).
// False Positives: PowerShell-based build systems, internal tooling.
// Threshold: Any single match from a non-developer workstation.
// ============================================================
DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where FileName =~ "csc.exe"
| where InitiatingProcessFileName =~ "powershell.exe"
    or InitiatingProcessFileName =~ "pwsh.exe"
| project Timestamp, DeviceName, AccountName,
          FileName, ProcessCommandLine,
          InitiatingProcessFileName, InitiatingProcessCommandLine,
          InitiatingProcessParentFileName
| sort by Timestamp desc


// ============================================================
// QUERY 5: Hosts File Modification by Non-Installer Process (T1565.001)
// Confidence: High
// Purpose: Detect writes to %SystemRoot%\System32\drivers\etc\hosts by any
//          process that is not a known OS installer, update agent, or domain
//          join tool. Malware redirects trusted hostnames (e.g., CDN endpoints)
//          to attacker-controlled infrastructure via hosts-file manipulation.
// False Positives: Enterprise software deployment tools, VPN clients.
//                  Endpoint provisioning scripts.
// Threshold: Any single match warrants investigation.
// ============================================================
DeviceFileEvents
| where TimeGenerated > ago(1h)
| where FolderPath =~ "C:\\Windows\\System32\\drivers\\etc"
| where FileName =~ "hosts"
| where ActionType in ("FileCreated", "FileModified")
| where InitiatingProcessFileName !in~ ("TrustedInstaller.exe", "TiWorker.exe",
                                          "MsiExec.exe", "setup.exe",
                                          "dsregcmd.exe", "djoin.exe")
| project Timestamp, DeviceName, AccountName,
          InitiatingProcessFileName, InitiatingProcessCommandLine,
          InitiatingProcessParentFileName, ActionType
| sort by Timestamp desc


// ============================================================
// QUERY 6: Unsigned PE Dropped to %TEMP% Followed by Execution (T1105)
// Confidence: Medium-High
// Purpose: Detect a PE file with missing/invalid Authenticode signature
//          dropped to %TEMP% and subsequently executed. HONESTCUE stage 3
//          drops the CDN-fetched payload to %TEMP% and executes.
// False Positives: Installer temp directories, legitimate updaters.
// Threshold: Any single execution of an unsigned %TEMP% PE.
// ============================================================
let temp_drops =
    DeviceFileEvents
    | where TimeGenerated > ago(1h)
    | where ActionType == "FileCreated"
    | where FileName endswith ".exe" or FileName endswith ".bat" or FileName endswith ".cmd"
    | where FolderPath matches regex @"(?i)(C:\\Windows\\Temp|C:\\Users\\[^\\]+\\AppData\\Local\\Temp)"
    | project DropTime=Timestamp, DeviceName, DroppedFile=FileName, DroppedPath=FolderPath, DropSHA1=SHA1,
              InitiatingProcessFileName;
let subsequent_exec =
    DeviceProcessEvents
    | where TimeGenerated > ago(1h)
    | where FolderPath matches regex @"(?i)(C:\\Windows\\Temp|C:\\Users\\[^\\]+\\AppData\\Local\\Temp)"
    | project ExecTime=Timestamp, DeviceName, ExecFile=FileName, ExecPath=FolderPath, ExecSHA1=SHA1,
              ExecCommandLine=ProcessCommandLine, ExecParent=InitiatingProcessFileName;
temp_drops
| join kind=inner subsequent_exec on DeviceName, $left.DropSHA1 == $right.ExecSHA1
| where ExecTime between (DropTime .. (DropTime + 10m))
| project DropTime, ExecTime, DeviceName, DroppedFile, DroppedPath,
          DropSHA1, InitiatingProcessFileName, ExecParent, ExecCommandLine


// ============================================================
// QUERY 7: cdn.discordapp.com Traffic to Non-Routable Address (T1583.006 / T1565.001)
// Confidence: High
// Purpose: Detect DNS or network traffic where cdn.discordapp.com (or any
//          other trusted CDN) resolves to a loopback, RFC1918, or otherwise
//          non-routable address. This indicates hosts-file or DNS hijacking
//          used to redirect trusted hostnames to attacker-controlled servers.
// False Positives: CDN development testing (should be rare on endpoint fleet).
// Threshold: Any single match.
// ============================================================
DeviceNetworkEvents
| where TimeGenerated > ago(1h)
| where RemoteUrl has_any ("cdn.discordapp.com", "media.discordapp.net",
                            "github.com", "raw.githubusercontent.com")
| where RemoteIP startswith "127."
    or RemoteIP startswith "10."
    or RemoteIP startswith "192.168."
    or (RemoteIP startswith "172." and toint(split(RemoteIP, ".")[1]) between (16 .. 31))
    or RemoteIP == "::1"
| project Timestamp, DeviceName, InitiatingProcessFileName,
          InitiatingProcessCommandLine, RemoteUrl, RemoteIP, RemotePort
| sort by Timestamp desc


// ============================================================
// QUERY 8: Combined Behavioral Correlation — HONESTCUE Chain Signature
// Confidence: Very High
// Purpose: Correlate multiple HONESTCUE-chain signals within a single host/hour.
//          Fires when at least 2 of the 3 chain phases are observed on the
//          same device within a correlation window.
// Threshold: >=2 signals = investigate; 3 signals = confirmed compromise.
// ============================================================
let window = 1h;
let llm_post =
    DeviceNetworkEvents
    | where TimeGenerated > ago(window)
    | where RemoteUrl has_any ("generativelanguage.googleapis.com", "api.openai.com", "api.anthropic.com")
    | where InitiatingProcessFileName !in~ ("chrome.exe", "msedge.exe", "firefox.exe", "Code.exe")
    | distinct DeviceName, LlmSig=InitiatingProcessFileName;
let reflective_compile =
    DeviceEvents
    | where TimeGenerated > ago(window)
    | where ActionType in ("AmsiScanEvent", "ScriptBlockLogging")
    | where AdditionalFields has_any ("CSharpCodeProvider", "Assembly.Load", "::Load(")
    | distinct DeviceName, ReflectiveSig=InitiatingProcessFileName;
let hosts_write =
    DeviceFileEvents
    | where TimeGenerated > ago(window)
    | where FolderPath =~ "C:\\Windows\\System32\\drivers\\etc"
    | where FileName =~ "hosts"
    | where InitiatingProcessFileName !in~ ("TrustedInstaller.exe", "MsiExec.exe")
    | distinct DeviceName, HostsSig=InitiatingProcessFileName;
llm_post
| join kind=fullouter reflective_compile on DeviceName
| join kind=fullouter hosts_write on DeviceName
| extend SignalCount = iff(isnotempty(LlmSig), 1, 0)
                     + iff(isnotempty(ReflectiveSig), 1, 0)
                     + iff(isnotempty(HostsSig), 1, 0)
| where SignalCount >= 2
| project DeviceName, SignalCount, LlmSig, ReflectiveSig, HostsSig
