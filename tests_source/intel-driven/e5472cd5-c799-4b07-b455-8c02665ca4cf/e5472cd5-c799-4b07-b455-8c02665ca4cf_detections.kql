// ============================================================
// Behavioral Detection Queries for HONESTCUE v2 LLM-Assisted Runtime C# Compilation
// Test ID: e5472cd5-c799-4b07-b455-8c02665ca4cf
// MITRE ATT&CK: T1071.001, T1027.004, T1027.010, T1620, T1105, T1204.002, T1059.001
// Threat Actor: N/A (unattributed per GTIG)
// Generated: 2026-04-13 (v2)
// ============================================================
// FOCUS: Technique-level attack behaviors. Detections target HONESTCUE-class
// TTPs (LLM-as-runtime, real TLS to trusted hosting, in-memory Roslyn compile
// + reflective load, PE drop to %TEMP% + exec from trusted-hosting CDN).
// ============================================================


// ============================================================
// QUERY 1: Non-Browser/Non-Git Process Fetching from raw.githubusercontent.com (T1071.001 / T1105)
// Confidence: Medium-High
// Purpose: Detect HTTPS GET to raw.githubusercontent.com from processes that
//          are NOT the allowed set of browsers, git clients, or package managers.
//          HONESTCUE v2 fetches Gemini-shaped JSON and its stage-3 PE from
//          GitHub-raw to blend with benign developer traffic.
// False Positives: Authorized internal tooling pulling GitHub-hosted configs,
//                  CI runners on the endpoint (rare).
// Threshold: Any single match from a non-standard parent chain.
// ============================================================
DeviceNetworkEvents
| where TimeGenerated > ago(1h)
| where RemoteUrl has_any ("raw.githubusercontent.com",
                           "api.github.com/repos",
                           "github.com/raw",
                           "objects.githubusercontent.com")
| where InitiatingProcessFileName !in~ ("chrome.exe", "msedge.exe", "firefox.exe",
                                         "brave.exe", "opera.exe", "iexplore.exe",
                                         "Code.exe", "devenv.exe", "cursor.exe",
                                         "windsurf.exe", "zed.exe",
                                         "git.exe", "git-remote-https.exe",
                                         "curl.exe", "wget.exe",
                                         "GitHubDesktop.exe", "ssh.exe")
| project Timestamp, DeviceName, InitiatingProcessFileName,
          InitiatingProcessCommandLine, InitiatingProcessParentFileName,
          RemoteUrl, RemotePort
| sort by Timestamp desc


// ============================================================
// QUERY 2: Non-Browser/Non-Git Process Resolving raw.githubusercontent.com (T1071.001)
// Confidence: Medium
// Purpose: Complements Query 1. Sysmon EventID 22 / DeviceEvents DnsQuery gives
//          the initial DNS lookup IOC even before the TLS connection is made.
// False Positives: Endpoint package managers (nuget, pip) fetching from GitHub.
// Threshold: Correlate with Query 1 for higher confidence.
// ============================================================
DeviceEvents
| where TimeGenerated > ago(1h)
| where ActionType == "DnsQueryResponse" or ActionType == "DnsQuery"
| where AdditionalFields has "raw.githubusercontent.com"
   or  AdditionalFields has "objects.githubusercontent.com"
| where InitiatingProcessFileName !in~ ("chrome.exe", "msedge.exe", "firefox.exe",
                                         "brave.exe", "Code.exe", "devenv.exe",
                                         "git.exe", "GitHubDesktop.exe",
                                         "curl.exe", "wget.exe")
| project Timestamp, DeviceName, InitiatingProcessFileName,
          InitiatingProcessCommandLine, InitiatingProcessParentFileName,
          AdditionalFields
| sort by Timestamp desc


// ============================================================
// QUERY 3: Microsoft.CodeAnalysis.CSharp.dll Image Load in Non-Dev Process (T1027.004)
// Confidence: High
// Purpose: Detect the Roslyn API surface being loaded by a process that is not
//          a developer tool, build server, or IDE. HONESTCUE v2 stage 2 is
//          a .NET 8 self-contained exe that loads Microsoft.CodeAnalysis.CSharp
//          in-process — no csc.exe child spawn, no powershell.exe ancestor.
// False Positives: In-house .NET plugin hosts, scripted code-generation tools.
// Threshold: Any single match from a workstation outside the dev team.
// ============================================================
DeviceImageLoadEvents
| where TimeGenerated > ago(1h)
| where FileName in~ ("Microsoft.CodeAnalysis.CSharp.dll",
                      "Microsoft.CodeAnalysis.dll")
| where InitiatingProcessFileName !in~ ("devenv.exe", "Code.exe", "dotnet.exe",
                                         "MSBuild.exe", "csc.exe", "ServiceHub.Host.CLR.x64.exe",
                                         "JetBrains.Rider.exe", "rider64.exe",
                                         "jetbrains.resharper.globaltools.exe")
| project Timestamp, DeviceName, InitiatingProcessFileName,
          InitiatingProcessCommandLine, InitiatingProcessParentFileName,
          FileName, FolderPath, SHA1
| sort by Timestamp desc


// ============================================================
// QUERY 4: Reflective Assembly Load via Assembly.Load(byte[]) (T1620)
// Confidence: High
// Purpose: Detect the AMSI event generated by Assembly.Load being invoked with
//          a byte[] argument. This is the canonical reflective load pattern
//          used by HONESTCUE stage 2 and many other offensive tools.
// False Positives: Internally-developed .NET loaders, plugin hosts.
// Threshold: Any single match from an unexpected parent process.
// ============================================================
DeviceEvents
| where TimeGenerated > ago(1h)
| where ActionType in ("AmsiScanEvent", "ScriptBlockLogging")
| where AdditionalFields has "Assembly" and
        (AdditionalFields has "::Load" or AdditionalFields has ".Load(")
| where AdditionalFields has_any ("[byte[]]", "byte[]]", "System.Byte[]")
| project Timestamp, DeviceName, InitiatingProcessFileName,
          InitiatingProcessParentFileName, AdditionalFields
| sort by Timestamp desc


// ============================================================
// QUERY 5: Self-Contained .NET Single-File Executable Launching from Unusual Path (T1027.004)
// Confidence: Medium
// Purpose: HONESTCUE v2 stage 2 is a ~80 MB .NET 8 self-contained single-file
//          executable. Such binaries load a characteristic set of DLLs from
//          their per-invocation extraction directory. Detect the combination
//          of a large single-file self-extracting bundle + clrjit.dll load
//          from a non-installed-app path.
// False Positives: Consumer .NET desktop apps shipped as single-file bundles.
// Threshold: Correlate with Queries 3 and 4.
// ============================================================
DeviceImageLoadEvents
| where TimeGenerated > ago(1h)
| where FileName =~ "clrjit.dll"
| where FolderPath matches regex @"(?i)\\AppData\\Local\\Temp\\.net\\"
   or  FolderPath matches regex @"(?i)\\c:\\F0\\"
| project Timestamp, DeviceName, InitiatingProcessFileName,
          InitiatingProcessCommandLine, FolderPath
| sort by Timestamp desc


// ============================================================
// QUERY 6: PE Dropped to c:\Windows\Temp Followed by Execution (T1105 + T1204.002)
// Confidence: Medium-High
// Purpose: Detect a PE file dropped to c:\Windows\Temp (or %TEMP%) and then
//          executed within 10 minutes. HONESTCUE v2 stage 3 fetches the PE
//          from GitHub raw and drops to c:\Windows\Temp\honestcue_payload.exe.
// False Positives: Installer temp directories, legitimate updaters.
// Threshold: Any single match correlated with a GitHub-raw fetch in Query 1.
// ============================================================
let temp_drops =
    DeviceFileEvents
    | where TimeGenerated > ago(1h)
    | where ActionType == "FileCreated"
    | where FileName endswith ".exe"
    | where FolderPath matches regex @"(?i)(C:\\Windows\\Temp|C:\\Users\\[^\\]+\\AppData\\Local\\Temp)"
    | project DropTime=Timestamp, DeviceName, DroppedFile=FileName, DroppedPath=FolderPath, DropSHA1=SHA1,
              InitiatingProcessFileName;
let subsequent_exec =
    DeviceProcessEvents
    | where TimeGenerated > ago(1h)
    | where FolderPath matches regex @"(?i)(C:\\Windows\\Temp|C:\\Users\\[^\\]+\\AppData\\Local\\Temp)"
    | project ExecTime=Timestamp, DeviceName, ExecFile=FileName, ExecPath=FolderPath, ExecSHA1=SHA1,
              ExecCommandLine=ProcessCommandLine, ExecParent=InitiatingProcessFileName;
temp_drops
| join kind=inner subsequent_exec on DeviceName, $left.DropSHA1 == $right.ExecSHA1
| where ExecTime between (DropTime .. (DropTime + 10m))
| project DropTime, ExecTime, DeviceName, DroppedFile, DroppedPath,
          DropSHA1, InitiatingProcessFileName, ExecParent, ExecCommandLine


// ============================================================
// QUERY 7: PE Dropped and Executed After GitHub-Raw Fetch by Same Process (T1105 + T1204.002)
// Confidence: Very High
// Purpose: Full chain correlation. Same process fetches from raw.githubusercontent.com,
//          drops a PE to c:\Windows\Temp, then executes the dropped PE.
//          Matches HONESTCUE v2 stage 3 end-to-end.
// False Positives: Very rare. Software installers occasionally match a subset.
// Threshold: Single match = confirmed HONESTCUE-v2-chain signal.
// ============================================================
let github_fetch =
    DeviceNetworkEvents
    | where TimeGenerated > ago(1h)
    | where RemoteUrl has "raw.githubusercontent.com"
    | where InitiatingProcessFileName !in~ ("chrome.exe", "msedge.exe", "firefox.exe",
                                             "git.exe", "Code.exe", "devenv.exe", "curl.exe", "wget.exe")
    | project FetchTime=Timestamp, DeviceName, FetchProcess=InitiatingProcessFileName,
              FetchPID=InitiatingProcessId, RemoteUrl;
let pe_drop =
    DeviceFileEvents
    | where TimeGenerated > ago(1h)
    | where ActionType == "FileCreated"
    | where FileName endswith ".exe"
    | where FolderPath matches regex @"(?i)C:\\Windows\\Temp"
    | project DropTime=Timestamp, DeviceName, DropProcess=InitiatingProcessFileName,
              DropPID=InitiatingProcessId, DroppedFile=FileName, DropSHA1=SHA1;
let pe_exec =
    DeviceProcessEvents
    | where TimeGenerated > ago(1h)
    | where FolderPath matches regex @"(?i)C:\\Windows\\Temp"
    | project ExecTime=Timestamp, DeviceName, ExecProcess=FileName, ExecParent=InitiatingProcessFileName,
              ExecSHA1=SHA1;
github_fetch
| join kind=inner pe_drop on DeviceName, $left.FetchPID == $right.DropPID
| where DropTime between (FetchTime .. (FetchTime + 2m))
| join kind=inner pe_exec on DeviceName, $left.DropSHA1 == $right.ExecSHA1
| where ExecTime between (DropTime .. (DropTime + 5m))
| project FetchTime, DropTime, ExecTime, DeviceName, FetchProcess,
          RemoteUrl, DroppedFile, DropSHA1, ExecProcess
| sort by FetchTime desc


// ============================================================
// QUERY 8: Combined Behavioral Correlation — HONESTCUE v2 Chain Signature
// Confidence: Very High
// Purpose: Correlate multiple HONESTCUE-v2-chain signals within a single host/hour.
//          Fires when at least 2 of the 3 chain phases are observed on the
//          same device within the correlation window.
// Threshold: >=2 signals = investigate; 3 signals = confirmed compromise.
// ============================================================
let window = 1h;
let github_fetch_sig =
    DeviceNetworkEvents
    | where TimeGenerated > ago(window)
    | where RemoteUrl has "raw.githubusercontent.com"
    | where InitiatingProcessFileName !in~ ("chrome.exe", "msedge.exe", "firefox.exe",
                                             "git.exe", "Code.exe", "curl.exe", "wget.exe")
    | distinct DeviceName, GithubSig=InitiatingProcessFileName;
let roslyn_load_sig =
    DeviceImageLoadEvents
    | where TimeGenerated > ago(window)
    | where FileName =~ "Microsoft.CodeAnalysis.CSharp.dll"
    | where InitiatingProcessFileName !in~ ("devenv.exe", "Code.exe", "MSBuild.exe", "dotnet.exe")
    | distinct DeviceName, RoslynSig=InitiatingProcessFileName;
let reflective_load_sig =
    DeviceEvents
    | where TimeGenerated > ago(window)
    | where ActionType in ("AmsiScanEvent", "ScriptBlockLogging")
    | where AdditionalFields has_any ("Assembly.Load", "::Load(byte[])")
    | distinct DeviceName, ReflectiveSig=InitiatingProcessFileName;
let pe_drop_exec_sig =
    DeviceProcessEvents
    | where TimeGenerated > ago(window)
    | where FolderPath matches regex @"(?i)C:\\Windows\\Temp"
    | where FileName endswith ".exe"
    | distinct DeviceName, DropExecSig=FileName;
github_fetch_sig
| join kind=fullouter roslyn_load_sig on DeviceName
| join kind=fullouter reflective_load_sig on DeviceName
| join kind=fullouter pe_drop_exec_sig on DeviceName
| extend SignalCount = iff(isnotempty(GithubSig), 1, 0)
                     + iff(isnotempty(RoslynSig), 1, 0)
                     + iff(isnotempty(ReflectiveSig), 1, 0)
                     + iff(isnotempty(DropExecSig), 1, 0)
| where SignalCount >= 2
| project DeviceName, SignalCount, GithubSig, RoslynSig, ReflectiveSig, DropExecSig
