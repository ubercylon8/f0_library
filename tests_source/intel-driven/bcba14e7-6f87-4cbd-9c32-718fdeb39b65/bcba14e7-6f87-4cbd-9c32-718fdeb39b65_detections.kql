// ============================================================
// EDRSilencer Detection - KQL Queries for Microsoft Sentinel/Defender
// Test ID: bcba14e7-6f87-4cbd-9c32-718fdeb39b65
// MITRE ATT&CK: T1562.001 - Impair Defenses: Disable or Modify Tools
// Generated: 2024-12-07
// ============================================================

// ============================================================
// 1. EDRSilencer Binary Execution Detection
// ============================================================
// Purpose: Detects execution of EDRSilencer.exe by process name
// Confidence: High
// False Positives: None expected - tool name is specific
// Threshold: Alert on any occurrence
// ============================================================

DeviceProcessEvents
| where FileName =~ "EDRSilencer.exe"
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    FileName,
    ProcessCommandLine,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    ProcessId,
    InitiatingProcessId
| extend
    Severity = "Critical",
    ThreatType = "Defense Evasion - EDRSilencer Execution",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 2. EDRSilencer BlockEDR Command Execution
// ============================================================
// Purpose: Detects EDRSilencer being executed with "blockedr" parameter
// Confidence: High
// False Positives: None expected - specific command pattern
// Threshold: Alert on any occurrence
// ============================================================

DeviceProcessEvents
| where ProcessCommandLine has_all ("EDRSilencer", "blockedr")
    or ProcessCommandLine has_all ("edrsilencer", "blockedr")
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    FileName,
    ProcessCommandLine,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine
| extend
    Severity = "Critical",
    ThreatType = "Defense Evasion - EDR Blocking Attempt",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 3. WFP Filter Manipulation via Command Line
// ============================================================
// Purpose: Detects processes with command lines indicating WFP filter manipulation
// Confidence: Medium
// False Positives: Legitimate network administration tools
// Threshold: Correlate with other indicators
// ============================================================

DeviceProcessEvents
| where ProcessCommandLine has_any (
    "blockedr",
    "unblockall",
    "FwpmFilterAdd",
    "FwpmEngineOpen",
    "fwpuclnt"
)
| where FileName !in~ ("netsh.exe", "svchost.exe", "services.exe")
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    FileName,
    ProcessCommandLine,
    InitiatingProcessFileName
| extend
    Severity = "High",
    ThreatType = "Defense Evasion - WFP Filter Manipulation",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 4. Suspicious Process Loading WFP Library
// ============================================================
// Purpose: Detects non-standard processes loading fwpuclnt.dll (WFP API library)
// Confidence: Medium
// False Positives: Legitimate firewall management tools, VPN clients
// Threshold: Correlate with process behavior and location
// ============================================================

DeviceImageLoadEvents
| where FileName =~ "fwpuclnt.dll"
| where InitiatingProcessFolderPath !startswith "C:\\Windows\\System32"
| where InitiatingProcessFolderPath !startswith "C:\\Program Files"
| where InitiatingProcessFolderPath !startswith "C:\\Program Files (x86)"
| project
    TimeGenerated,
    DeviceName,
    FileName,
    InitiatingProcessFileName,
    InitiatingProcessFolderPath,
    InitiatingProcessCommandLine
| extend
    Severity = "Medium",
    ThreatType = "Defense Evasion - WFP Library Load from Suspicious Location",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 5. Suspicious EDR-Targeting Tool Staging
// ============================================================
// Purpose: Detects executables with EDR-targeting naming patterns in user-writable directories
// Confidence: Medium
// False Positives: Legitimate security tools with similar naming
// Threshold: Alert on detection and correlate with other EDR-related activity
// ============================================================

DeviceFileEvents
| where ActionType == "FileCreated"
| where FolderPath has_any ("\\Temp\\", "\\AppData\\Local\\Temp", "\\Users\\Public", "\\Downloads\\")
| where FileName endswith ".exe" or FileName endswith ".dll"
| where FileName has_any ("EDRSilencer", "EDRKiller", "blockEDR", "WFP", "Silencer", "EDRBlock")
    or FileName has_any ("Defender", "Sentinel", "CrowdStrike", "Falcon", "Carbon")
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    FileName,
    FolderPath,
    SHA256,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine
| extend
    Severity = case(
        FileName has_any ("EDRSilencer", "EDRKiller", "blockEDR"), "High",
        "Medium"
    ),
    ThreatType = "Tool Staging - Potential EDR-Targeting Tool",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 6. Security Process Communication Anomalies
// ============================================================
// Purpose: Detects when security processes fail to make outbound connections
// Confidence: High
// False Positives: Network connectivity issues, proxy changes
// Threshold: Alert after 5+ failed connections within 10 minutes
// ============================================================

DeviceNetworkEvents
| where InitiatingProcessFileName in~ (
    "MsMpEng.exe",
    "MpDefenderCoreService.exe",
    "NisSrv.exe",
    "SenseCE.exe",
    "SenseIR.exe",
    "SenseNdr.exe",
    "MsSense.exe",
    "CylanceSvc.exe",
    "CSFalconService.exe",
    "SentinelAgent.exe",
    "cb.exe",
    "CarbonBlack.exe"
)
| where ActionType == "ConnectionFailed"
| summarize
    FailedConnections = count(),
    FirstFailure = min(TimeGenerated),
    LastFailure = max(TimeGenerated),
    TargetPorts = make_set(RemotePort),
    TargetIPs = make_set(RemoteIP)
    by DeviceName, InitiatingProcessFileName, bin(TimeGenerated, 10m)
| where FailedConnections >= 5
| extend
    Severity = "High",
    ThreatType = "Defense Evasion - Security Process Communication Blocked",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 7. EDR Process Network Activity Gap Detection
// ============================================================
// Purpose: Detects unusual gaps in EDR process network activity (potential blocking)
// Confidence: Medium
// False Positives: System reboots, network outages
// Threshold: No EDR traffic for 30+ minutes during business hours
// ============================================================

let ExpectedEDRProcesses = dynamic([
    "MsMpEng.exe", "MpDefenderCoreService.exe", "NisSrv.exe",
    "SenseCE.exe", "MsSense.exe", "CylanceSvc.exe", "CSFalconService.exe"
]);
let timeWindow = 30m;
DeviceNetworkEvents
| where TimeGenerated > ago(1h)
| where InitiatingProcessFileName in~ (ExpectedEDRProcesses)
| summarize
    LastActivity = max(TimeGenerated),
    ConnectionCount = count()
    by DeviceName, InitiatingProcessFileName
| where LastActivity < ago(timeWindow)
| project
    DeviceName,
    InitiatingProcessFileName,
    LastActivity,
    MinutesSinceLastActivity = datetime_diff('minute', now(), LastActivity),
    ConnectionCount
| extend
    Severity = "High",
    ThreatType = "Defense Evasion - EDR Network Activity Gap",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 8. Known EDR Silencing Tool Names
// ============================================================
// Purpose: Detects execution of known EDR silencing/disabling tools
// Confidence: High
// False Positives: None expected - specific tool names
// Threshold: Alert on any occurrence
// ============================================================

DeviceProcessEvents
| where FileName in~ (
    "EDRSilencer.exe",
    "edrsilencer.exe",
    "FireBlock.exe",
    "EDR-Freeze.exe",
    "edr-freeze.exe",
    "Backstab.exe",
    "backstab.exe",
    "EDRSandBlast.exe",
    "edrsandblast.exe"
)
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    FileName,
    FolderPath,
    ProcessCommandLine,
    SHA256,
    InitiatingProcessFileName
| extend
    Severity = "Critical",
    ThreatType = "Defense Evasion - Known EDR Silencing Tool",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 9. Behavioral Correlation - EDRSilencer Attack Chain
// ============================================================
// Purpose: Correlates multiple indicators of EDRSilencer attack
// Confidence: Critical
// False Positives: Very low - multiple indicators required
// Threshold: Alert on detection
// ============================================================

let FileStaging = DeviceFileEvents
| where ActionType == "FileCreated"
| where FolderPath has_any ("\\Temp\\", "\\AppData\\Local\\Temp", "\\Users\\Public", "\\Downloads\\", "\\ProgramData\\")
| where FileName endswith ".exe"
| where FileName has_any ("EDRSilencer", "edrsilencer", "silencer", "FireBlock", "EDR-Freeze", "Backstab")
| project StagingTime = TimeGenerated, DeviceName, StagedFile = FileName, StagedPath = FolderPath;

let ToolExecution = DeviceProcessEvents
| where FileName =~ "EDRSilencer.exe"
    or ProcessCommandLine has "blockedr"
| project ExecutionTime = TimeGenerated, DeviceName, ExecutedFile = FileName,
    Command = ProcessCommandLine;

FileStaging
| join kind=inner (ToolExecution) on DeviceName
| where ExecutionTime between (StagingTime .. (StagingTime + 5m))
| project
    TimeGenerated = StagingTime,
    DeviceName,
    StagedFile,
    StagedPath,
    ExecutedFile,
    Command,
    TimeDeltaSeconds = datetime_diff('second', ExecutionTime, StagingTime)
| extend
    Severity = "Critical",
    ThreatType = "EDRSilencer Attack Chain - Staging and Execution",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65",
    Description = "EDRSilencer tool was staged and executed within 5-minute window"


// ============================================================
// 10. Windows Filtering Platform Audit Events
// ============================================================
// Purpose: Detects WFP filter addition events from Windows Security logs
// Confidence: High
// False Positives: Legitimate firewall rule changes, VPN connections
// Threshold: Correlate with non-standard processes
// ============================================================

SecurityEvent
| where EventID in (5152, 5153, 5154, 5155, 5156, 5157, 5158, 5159)
// 5152: WFP blocked a packet
// 5156: WFP permitted a connection
// 5157: WFP blocked a connection
// 5158: WFP permitted a bind
// 5159: WFP blocked a bind
| where Application !startswith "\\device\\harddiskvolume"
| where Application !has "\\windows\\system32\\"
| where Application !has "\\program files\\"
| summarize
    EventCount = count(),
    FilteredApplications = make_set(Application),
    EventTypes = make_set(EventID)
    by Computer, bin(TimeGenerated, 5m)
| where EventCount >= 10
| extend
    Severity = "Medium",
    ThreatType = "Defense Evasion - Unusual WFP Activity",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 11. Process Targeting EDR Executables
// ============================================================
// Purpose: Detects processes with command lines targeting EDR process names
// Confidence: High
// False Positives: EDR management/update processes
// Threshold: Alert when non-EDR process targets EDR
// ============================================================

DeviceProcessEvents
| where ProcessCommandLine has_any (
    "MsMpEng",
    "MpDefenderCoreService",
    "NisSrv",
    "SenseCE",
    "SenseIR",
    "MsSense",
    "CylanceSvc",
    "CSFalconService",
    "SentinelAgent",
    "CarbonBlack"
)
| where ProcessCommandLine has_any ("block", "kill", "stop", "disable", "terminate")
| where InitiatingProcessFileName !in~ (
    "services.exe", "svchost.exe", "msiexec.exe", "TrustedInstaller.exe"
)
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    FileName,
    ProcessCommandLine,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine
| extend
    Severity = "Critical",
    ThreatType = "Defense Evasion - EDR Process Targeting",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 12. Anomalous Process from User-Writable Directory
// ============================================================
// Purpose: Detects EDR-targeting tool execution from user-writable directories
// Confidence: Medium
// False Positives: Legitimate portable security tools
// Threshold: Correlate with tool naming patterns
// ============================================================

DeviceProcessEvents
| where FolderPath has_any ("\\Temp\\", "\\AppData\\Local\\Temp", "\\Users\\Public", "\\Downloads\\", "\\ProgramData\\")
| where FileName has_any ("EDRSilencer", "edrsilencer", "silencer", "FireBlock", "EDR-Freeze", "Backstab", "EDRSandBlast")
    or ProcessCommandLine has_any ("blockedr", "unblockall", "FwpmFilterAdd")
| project
    TimeGenerated,
    DeviceName,
    AccountName,
    FileName,
    FolderPath,
    ProcessCommandLine,
    SHA256,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine
| extend
    Severity = "High",
    ThreatType = "Suspicious Execution - EDR Targeting Tool from User-Writable Directory",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65"


// ============================================================
// 13. Time-Based Multi-Indicator Correlation
// ============================================================
// Purpose: Aggregates multiple suspicious events within time window for high-confidence detection
// Confidence: Critical
// False Positives: Very low - requires multiple indicators
// Threshold: 2+ indicators within 10-minute window
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where (
    // EDRSilencer specific
    FileName =~ "EDRSilencer.exe"
    or ProcessCommandLine has "blockedr"
    or ProcessCommandLine has "unblockall"
    // Generic EDR tampering
    or (ProcessCommandLine has_any ("MsMpEng", "MpDefenderCoreService", "Sense")
        and ProcessCommandLine has_any ("block", "kill", "stop"))
    // WFP manipulation
    or (ProcessCommandLine has_any ("FwpmFilterAdd", "FwpmEngineOpen")
        and FolderPath !startswith "C:\\Windows\\")
)
| summarize
    EventCount = count(),
    EventTypes = make_set(FileName),
    Commands = make_set(ProcessCommandLine),
    FirstEvent = min(TimeGenerated),
    LastEvent = max(TimeGenerated)
    by DeviceName, AccountName, bin(TimeGenerated, 10m)
| where EventCount >= 2
| extend
    Severity = "Critical",
    ThreatType = "Multiple Defense Evasion Indicators - EDRSilencer Pattern",
    MitreAttack = "T1562.001",
    TestID = "bcba14e7-6f87-4cbd-9c32-718fdeb39b65",
    TimeWindowSeconds = datetime_diff('second', LastEvent, FirstEvent)


// ============================================================
// HUNTING QUERIES
// ============================================================

// ============================================================
// H1. Hunt - Processes with WFP API Imports
// ============================================================
// Purpose: Identify processes that have loaded WFP libraries (proactive hunting)
// Use Case: Identify potentially malicious tools before execution

DeviceImageLoadEvents
| where TimeGenerated > ago(24h)
| where FileName =~ "fwpuclnt.dll"
| summarize
    LoadCount = count(),
    LoadingProcesses = make_set(InitiatingProcessFileName),
    LoadPaths = make_set(InitiatingProcessFolderPath)
    by DeviceName
| where LoadCount > 0
| extend HuntingNote = "Review processes loading WFP library for anomalies"


// ============================================================
// H2. Hunt - EDR Process Health Check
// ============================================================
// Purpose: Verify EDR processes are running and communicating normally
// Use Case: Proactive detection of potential EDR silencing

let healthWindow = 1h;
let expectedEDR = dynamic(["MsMpEng.exe", "MsSense.exe"]);
DeviceProcessEvents
| where TimeGenerated > ago(healthWindow)
| where FileName in~ (expectedEDR)
| summarize
    ProcessStartCount = count(),
    LastSeen = max(TimeGenerated)
    by DeviceName, FileName
| extend
    HealthStatus = iff(LastSeen < ago(30m), "STALE", "HEALTHY"),
    MinutesSinceLastSeen = datetime_diff('minute', now(), LastSeen)
| where HealthStatus == "STALE"
| extend HuntingNote = "EDR process not seen recently - investigate potential silencing"
