// ============================================================================
// ALERT SUMMARY DASHBOARD QUERY
// Purpose: Aggregate all AMSI bypass detections for SOC dashboard
// ============================================================================

let DetectionEvents = union
    (DeviceRegistryEvents
    | where TimeGenerated > ago(24h)
    | where RegistryKey has_all ("Microsoft", "AMSI", "Providers")
    | where InitiatingProcessFileName !in~ ("MsMpEng.exe", "svchost.exe")
    | summarize EventCount = count() by Computer = DeviceName, bin(TimeGenerated, 1h)
    | extend DetectionType = "AMSI Registry Manipulation"
    ),
    (DeviceProcessEvents
    | where TimeGenerated > ago(24h)
    | where FileName matches regex @"(?i)(troll|amsi.*bypass|seatbelt)"
    | summarize EventCount = count() by Computer = DeviceName, bin(TimeGenerated, 1h)
    | extend DetectionType = "AMSI Bypass Tool Execution"
    ),
    (DeviceNetworkEvents
    | where TimeGenerated > ago(24h)
    | where RemoteUrl has_any ("SharpCollection", "GhostPack", "Seatbelt")
    | summarize EventCount = count() by Computer = DeviceName, bin(TimeGenerated, 1h)
    | extend DetectionType = "Remote Assembly Download"
    );
DetectionEvents
| summarize TotalEvents = sum(EventCount), DetectionTypes = make_set(DetectionType)
    by Computer, bin(TimeGenerated, 1h)
| order by TotalEvents desc
| project TimeGenerated, Computer, TotalEvents, DetectionTypes,
    Severity = case(TotalEvents >= 5, "Critical", TotalEvents >= 3, "High", "Medium"),
    ThreatType = "AMSI Bypass Activity Cluster",
    MitreAttack = "T1562.001",
    TestID = "c1f0fe6f-6907-4f95-820d-47e0a39abe54"
