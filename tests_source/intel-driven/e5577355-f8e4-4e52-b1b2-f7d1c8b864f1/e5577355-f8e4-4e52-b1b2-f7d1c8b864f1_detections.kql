// ============================================================================
// DEFENSE GUIDANCE: KQL Detection Queries
// ============================================================================
// Test ID: e5577355-f8e4-4e52-b1b2-f7d1c8b864f1
// Test Name: SilentButDeadly WFP EDR Network Isolation
// MITRE ATT&CK: T1562.001 - Impair Defenses: Disable or Modify Tools
// Created: 2025-12-06
// Author: F0RT1KA Defense Guidance Builder
// ============================================================================
//
// TECHNIQUE-FOCUSED DETECTION PRINCIPLE:
// These detections target the underlying WFP-based EDR isolation technique,
// NOT the F0RT1KA testing framework. They will catch real-world attackers
// using similar WFP manipulation techniques with their own custom tooling.
//
// ============================================================================


// ============================================================================
// QUERY 1: WFP Filter Addition Events - EDR Process Targeting
// Purpose: Detect WFP filter creation that targets security software
// Confidence: HIGH
// False Positives: Legitimate security software updates, VPN clients
// Threshold: 3+ filters targeting EDR processes within 5 minutes
// ============================================================================

SecurityEvent
| where TimeGenerated > ago(1h)
| where EventID == 5441  // WFP filter added
| where EventData has_any (
    "SentinelAgent", "SentinelServiceHost",    // SentinelOne
    "CSFalconService", "CSFalconContainer",    // CrowdStrike
    "MsMpEng", "MpCmdRun",                     // Windows Defender
    "RepMgr", "RepWAC",                        // Carbon Black
    "CylanceSvc",                              // Cylance
    "ccSvcHst",                                // Symantec
    "McShield",                                // McAfee
    "PccNTMon",                                // Trend Micro
    "SavService",                              // Sophos
    "avp",                                     // Kaspersky
    "ekrn",                                    // ESET
    "CortexXDR",                               // Palo Alto
    "xagt",                                    // FireEye/Trellix
    "elastic-endpoint"                         // Elastic Security
)
| summarize
    FilterCount = count(),
    FilterDetails = make_set(EventData),
    FirstEvent = min(TimeGenerated),
    LastEvent = max(TimeGenerated)
    by Computer, Account
| where FilterCount >= 3
| extend
    Severity = "High",
    ThreatType = "EDR Evasion - WFP Filter Targeting Security Software",
    MitreAttack = "T1562.001",
    Confidence = "High"
| project TimeGenerated = FirstEvent, Computer, Account, FilterCount,
    Severity, ThreatType, MitreAttack, Confidence


// ============================================================================
// QUERY 2: WFP Blocked Connections FROM EDR Processes
// Purpose: Detect when WFP blocks network traffic from security software
// Confidence: HIGH
// False Positives: Network outages, firewall misconfigurations
// Threshold: 5+ blocked connections from EDR processes in 5 minutes
// ============================================================================

SecurityEvent
| where TimeGenerated > ago(1h)
| where EventID in (5157, 5152)  // WFP blocked/allowed connection
| where EventData has "Block"
| extend ProcessName = extract(@"Application:\s*([^\s\\]+\.exe)", 1, EventData)
| where ProcessName in~ (
    "SentinelAgent.exe", "SentinelServiceHost.exe",
    "SentinelStaticEngine.exe", "SentinelStaticEngineScanner.exe",
    "CSFalconService.exe", "CSFalconContainer.exe",
    "MsMpEng.exe", "MpCmdRun.exe", "MsSense.exe",
    "RepMgr.exe", "RepWAC.exe", "RepUtils.exe",
    "CylanceSvc.exe", "CylanceUI.exe",
    "ccSvcHst.exe", "Rtvscan.exe",
    "McShield.exe", "McAfeeFramework.exe",
    "PccNTMon.exe", "TMBMSRV.exe",
    "SavService.exe", "SAVAdminService.exe",
    "avp.exe", "kavtray.exe",
    "ekrn.exe", "egui.exe",
    "CortexXDR.exe", "cyserver.exe",
    "xagt.exe", "FireEyeAgent.exe",
    "elastic-endpoint.exe", "elastic-agent.exe"
)
| summarize
    BlockedConnections = count(),
    TargetedProcesses = make_set(ProcessName),
    DestinationIPs = make_set(extract(@"DestAddress:\s*(\d+\.\d+\.\d+\.\d+)", 1, EventData)),
    FirstBlock = min(TimeGenerated),
    LastBlock = max(TimeGenerated)
    by Computer
| where BlockedConnections >= 5
| extend
    Duration = datetime_diff('second', LastBlock, FirstBlock),
    Severity = case(
        BlockedConnections >= 20, "Critical",
        BlockedConnections >= 10, "High",
        "Medium"
    ),
    ThreatType = "EDR Evasion - Network Isolation via WFP",
    MitreAttack = "T1562.001"
| project TimeGenerated = FirstBlock, Computer, BlockedConnections,
    TargetedProcesses, Duration, Severity, ThreatType, MitreAttack


// ============================================================================
// QUERY 3: Suspicious WFP API Usage Pattern
// Purpose: Detect processes making WFP management API calls
// Confidence: MEDIUM
// False Positives: Firewall management tools, VPN software, security updates
// Threshold: Non-system process using FwpmFilterAdd with EDR targeting
// ============================================================================

DeviceEvents
| where TimeGenerated > ago(1h)
| where ActionType == "ApiUsage" or ActionType has "Firewall"
| where ProcessCommandLine has_any (
    "FwpmEngineOpen", "FwpmFilterAdd", "FwpmProviderAdd",
    "FwpmSubLayerAdd", "FWPM_LAYER_ALE"
)
| where InitiatingProcessFileName !in~ (
    "svchost.exe", "services.exe", "System",
    "MsMpEng.exe", "MpCmdRun.exe"  // Legitimate Defender operations
)
| extend SuspiciousIndicators = case(
    ProcessCommandLine has_all ("FwpmFilterAdd", "FWPM_CONDITION_ALE_APP_ID"), "High - Process-specific filter targeting",
    ProcessCommandLine has "FwpmProviderAdd", "Medium - Custom provider creation",
    ProcessCommandLine has "FwpmSubLayerAdd", "Medium - Custom sublayer creation",
    "Low - Generic WFP operation"
)
| project TimeGenerated, DeviceName, InitiatingProcessFileName,
    InitiatingProcessCommandLine, ProcessCommandLine, SuspiciousIndicators,
    InitiatingProcessAccountName
| extend
    Severity = extract(@"(High|Medium|Low)", 1, SuspiciousIndicators),
    ThreatType = "Suspicious WFP API Usage",
    MitreAttack = "T1562.001"


// ============================================================================
// QUERY 4: EDR Telemetry Gap Detection
// Purpose: Detect sudden loss of EDR heartbeat/telemetry
// Confidence: MEDIUM-HIGH
// False Positives: Network maintenance, EDR upgrades, endpoint shutdown
// Threshold: 10+ minutes of missing telemetry from active endpoint
// ============================================================================

let timeRange = 1h;
let heartbeatInterval = 5m;
let EDRProcesses = dynamic([
    "SentinelAgent.exe", "SentinelServiceHost.exe",
    "CSFalconService.exe", "MsMpEng.exe", "MsSense.exe",
    "RepMgr.exe", "CylanceSvc.exe", "ccSvcHst.exe",
    "McShield.exe", "PccNTMon.exe", "SavService.exe",
    "avp.exe", "ekrn.exe", "CortexXDR.exe", "xagt.exe",
    "elastic-endpoint.exe"
]);
// Get endpoints with EDR processes recently active
let ActiveEndpoints = DeviceProcessEvents
| where TimeGenerated > ago(timeRange)
| where FileName in~ (EDRProcesses)
| summarize LastSeen = max(TimeGenerated) by DeviceName
| where LastSeen < ago(10m);  // Silent for 10+ minutes
// Get endpoints with recent activity but no EDR telemetry
DeviceEvents
| where TimeGenerated > ago(timeRange)
| summarize LastActivity = max(TimeGenerated) by DeviceName
| join kind=inner (ActiveEndpoints) on DeviceName
| where LastActivity > LastSeen  // System active but EDR silent
| extend
    TelemetryGapMinutes = datetime_diff('minute', LastActivity, LastSeen),
    Severity = case(
        datetime_diff('minute', LastActivity, LastSeen) > 30, "Critical",
        datetime_diff('minute', LastActivity, LastSeen) > 15, "High",
        "Medium"
    ),
    ThreatType = "EDR Telemetry Gap - Potential Network Isolation",
    MitreAttack = "T1562.001"
| project DeviceName, LastActivity, LastSeen, TelemetryGapMinutes,
    Severity, ThreatType, MitreAttack


// ============================================================================
// QUERY 5: Process Enumeration of Security Software
// Purpose: Detect enumeration of EDR/AV processes (reconnaissance phase)
// Confidence: MEDIUM
// False Positives: IT inventory scripts, system monitoring tools
// Threshold: Single process querying multiple EDR process names
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where FileName in~ ("tasklist.exe", "wmic.exe", "powershell.exe", "cmd.exe")
| where ProcessCommandLine has_any (
    "SentinelAgent", "CSFalcon", "MsMpEng", "MpCmdRun",
    "RepMgr", "CylanceSvc", "ccSvcHst", "McShield",
    "PccNTMon", "SavService", "avp", "ekrn",
    "CortexXDR", "xagt", "elastic-endpoint",
    // Tool32 snapshot patterns
    "CreateToolhelp32Snapshot", "Process32First", "Process32Next"
)
| extend EDRTargetCount = (
    iff(ProcessCommandLine has "SentinelAgent", 1, 0) +
    iff(ProcessCommandLine has "CSFalcon", 1, 0) +
    iff(ProcessCommandLine has "MsMpEng", 1, 0) +
    iff(ProcessCommandLine has "RepMgr", 1, 0) +
    iff(ProcessCommandLine has "CylanceSvc", 1, 0) +
    iff(ProcessCommandLine has "ccSvcHst", 1, 0) +
    iff(ProcessCommandLine has "McShield", 1, 0) +
    iff(ProcessCommandLine has "avp", 1, 0) +
    iff(ProcessCommandLine has "CortexXDR", 1, 0)
)
| where EDRTargetCount >= 2  // Targeting multiple EDR products
| project TimeGenerated, DeviceName, AccountName, FileName,
    ProcessCommandLine, EDRTargetCount, InitiatingProcessFileName
| extend
    Severity = case(EDRTargetCount >= 5, "High", EDRTargetCount >= 3, "Medium", "Low"),
    ThreatType = "Security Software Enumeration",
    MitreAttack = "T1518.001"


// ============================================================================
// QUERY 6: Combined WFP EDR Isolation Behavioral Detection
// Purpose: Correlate multiple indicators for high-confidence detection
// Confidence: HIGH
// False Positives: Very rare (requires multiple correlated indicators)
// Threshold: 2+ indicators within 10-minute window
// ============================================================================

let WFPEvents = SecurityEvent
| where TimeGenerated > ago(2h)
| where EventID in (5441, 5157)  // WFP filter added or blocked connection
| where EventData has_any (
    "SentinelAgent", "CSFalcon", "MsMpEng", "RepMgr",
    "CylanceSvc", "ccSvcHst", "McShield", "avp", "CortexXDR"
)
| summarize WFPEventCount = count() by Computer, bin(TimeGenerated, 10m)
| where WFPEventCount >= 3;
let ProcessEnum = DeviceProcessEvents
| where TimeGenerated > ago(2h)
| where ProcessCommandLine has_any (
    "SentinelAgent", "CSFalcon", "MsMpEng", "tasklist", "Process32"
)
| where InitiatingProcessFileName !in~ ("svchost.exe", "MsMpEng.exe")
| summarize EnumEvents = count() by DeviceName, bin(TimeGenerated, 10m)
| project Computer = DeviceName, EnumTime = TimeGenerated, EnumEvents;
let SuspiciousExecutables = DeviceProcessEvents
| where TimeGenerated > ago(2h)
| where FileName matches regex @"(?i)(silent.*deadly|edr.*silencer|wfp.*block|edr.*block)"
| summarize SuspiciousExeCount = count() by DeviceName, bin(TimeGenerated, 10m)
| project Computer = DeviceName, ExeTime = TimeGenerated, SuspiciousExeCount;
// Correlate all indicators
WFPEvents
| join kind=leftouter (ProcessEnum) on Computer
| join kind=leftouter (SuspiciousExecutables) on Computer
| extend IndicatorCount = (
    iff(WFPEventCount > 0, 1, 0) +
    iff(isnotnull(EnumEvents), 1, 0) +
    iff(isnotnull(SuspiciousExeCount), 1, 0)
)
| where IndicatorCount >= 2
| project Computer, TimeGenerated, WFPEventCount, EnumEvents, SuspiciousExeCount,
    IndicatorCount,
    Severity = "Critical",
    ThreatType = "WFP-Based EDR Network Isolation Attack",
    MitreAttack = "T1562.001",
    Confidence = "High"


// ============================================================================
// QUERY 7: Firewall Rule Modification for Security Software
// Purpose: Detect Windows Firewall rule changes blocking EDR
// Confidence: HIGH
// False Positives: IT administrators managing firewall rules
// Threshold: Outbound block rule created for security software
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where FileName in~ ("netsh.exe", "powershell.exe")
| where ProcessCommandLine has_any ("advfirewall", "New-NetFirewallRule", "Set-NetFirewallRule")
| where ProcessCommandLine has_any ("block", "Block", "BLOCK")
| where ProcessCommandLine has_any (
    "SentinelAgent", "CSFalcon", "MsMpEng", "MpCmdRun",
    "RepMgr", "CylanceSvc", "ccSvcHst", "McShield",
    "PccNTMon", "SavService", "avp", "ekrn",
    "CortexXDR", "xagt", "elastic-endpoint",
    "dir=out"  // Outbound blocking
)
| project TimeGenerated, DeviceName, AccountName, FileName, ProcessCommandLine,
    InitiatingProcessFileName, InitiatingProcessCommandLine
| extend
    Severity = "Critical",
    ThreatType = "Firewall Rule Blocking Security Software",
    MitreAttack = "T1562.004"


// ============================================================================
// QUERY 8: Defender ASR Rule Modification Detection
// Purpose: Detect attempts to modify Attack Surface Reduction rules
// Confidence: HIGH
// False Positives: IT policy changes via GPO
// Threshold: Any modification to ASR rules outside normal channels
// ============================================================================

DeviceRegistryEvents
| where TimeGenerated > ago(1h)
| where RegistryKey has "Windows Defender\\Windows Defender Exploit Guard\\ASR"
    or RegistryKey has "Windows Defender\\Real-Time Protection"
    or RegistryKey has "Windows Defender\\Exclusions"
| where ActionType in ("RegistryValueSet", "RegistryKeyDeleted")
| where InitiatingProcessFileName !in~ ("MsMpEng.exe", "svchost.exe", "gpupdate.exe")
| project TimeGenerated, DeviceName, RegistryKey, RegistryValueName,
    RegistryValueData, ActionType, InitiatingProcessFileName, AccountName
| extend
    Severity = case(
        RegistryKey has "Real-Time Protection", "Critical",
        RegistryKey has "Exclusions", "High",
        "Medium"
    ),
    ThreatType = "Windows Defender Configuration Modification",
    MitreAttack = "T1562.001"


// ============================================================================
// HUNTING QUERY: Known WFP EDR Isolation Tool Execution
// Purpose: Detect known attack tools (SilentButDeadly, EDRSilencer, etc.)
// Confidence: HIGH
// False Positives: Legitimate security testing (coordinate with security team)
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName matches regex @"(?i)(silent.*deadly|edr.*silenc|wfp.*block|edr.*block|netlock|blind.*side)"
    or SHA256 in (
        // Add known tool hashes here
        ""
    )
    or ProcessCommandLine matches regex @"(?i)(silentbutdeadly|edrsilencer|--block-edr|--isolate-av)"
| project TimeGenerated, DeviceName, AccountName, FileName,
    ProcessCommandLine, SHA256, FolderPath
| extend
    Severity = "Critical",
    ThreatType = "Known EDR Evasion Tool Execution",
    MitreAttack = "T1562.001",
    Confidence = "High"


// ============================================================================
// ALERT SUMMARY DASHBOARD QUERY
// Purpose: Aggregate all detections for SOC dashboard
// ============================================================================

let DetectionEvents = union
    // Add results from above queries here for unified dashboard
    (SecurityEvent
    | where TimeGenerated > ago(24h)
    | where EventID in (5441, 5157)
    | where EventData has_any ("SentinelAgent", "CSFalcon", "MsMpEng", "RepMgr")
    | summarize EventCount = count() by Computer, bin(TimeGenerated, 1h)
    | extend DetectionType = "WFP Filter Events Targeting EDR"
    ),
    (DeviceProcessEvents
    | where TimeGenerated > ago(24h)
    | where FileName matches regex @"(?i)(silent|edr.*silenc)"
    | summarize EventCount = count() by Computer = DeviceName, bin(TimeGenerated, 1h)
    | extend DetectionType = "Suspicious Tool Execution"
    );
DetectionEvents
| summarize TotalEvents = sum(EventCount), DetectionTypes = make_set(DetectionType)
    by Computer, bin(TimeGenerated, 1h)
| order by TotalEvents desc
| project TimeGenerated, Computer, TotalEvents, DetectionTypes,
    Severity = case(TotalEvents >= 10, "Critical", TotalEvents >= 5, "High", "Medium"),
    ThreatType = "EDR Evasion Activity Cluster",
    MitreAttack = "T1562.001"
