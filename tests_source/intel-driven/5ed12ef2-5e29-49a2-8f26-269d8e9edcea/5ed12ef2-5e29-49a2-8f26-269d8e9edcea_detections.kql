// ============================================================
// Detection Rules - Multi-Stage Ransomware Killchain
// Test ID: 5ed12ef2-5e29-49a2-8f26-269d8e9edcea
// MITRE ATT&CK: T1204.002, T1134.001, T1083, T1486, T1491.001
// Platform: Microsoft Sentinel / Microsoft Defender for Endpoint
// Author: F0RT1KA Detection Rules Generator
// Date: 2026-03-14
// ============================================================
// All rules target underlying attack technique behaviors.
// They will detect any attacker using these techniques regardless
// of what tooling was used to execute them.
// ============================================================


// ============================================================
// Detection 1: Mass File Encryption Pattern
// MITRE ATT&CK: T1486 - Data Encrypted for Impact
// Confidence: High
// ============================================================
// Purpose: Detect rapid file creation with ransomware extensions, the core
//          write phase of any file-encrypting ransomware.
// False Positives: Backup software writing intermediate staging files;
//                  tune by excluding known backup process names.
// Threshold: >10 encrypted-extension files created in a 5-minute window
// ============================================================

DeviceFileEvents
| where TimeGenerated > ago(1h)
| where ActionType in ("FileCreated", "FileRenamed")
| where FileName endswith ".encrypted"
    or FileName endswith ".locked"
    or FileName endswith ".crypted"
    or FileName endswith ".enc"
    or FileName endswith ".crypt"
    or FileName endswith ".ransom"
    or FileName endswith ".WNCRY"
    or FileName endswith ".ryk"
    or FileName endswith ".lck"
| where FolderPath !startswith "C:\\Windows\\"
    and FolderPath !startswith "C:\\Program Files\\"
| summarize
    EncryptedFileCount = count(),
    SampleFiles = make_set(FileName, 5),
    Directories = make_set(FolderPath, 5)
    by DeviceName, InitiatingProcessFileName, AccountName, bin(TimeGenerated, 5m)
| where EncryptedFileCount > 10
| extend
    Severity = case(
        EncryptedFileCount > 100, "Critical",
        EncryptedFileCount > 50,  "High",
        "Medium"
    ),
    ThreatType = "Ransomware_Encryption_Extension",
    MitreAttack = "T1486",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TimeGenerated, DeviceName, InitiatingProcessFileName, AccountName,
          EncryptedFileCount, SampleFiles, Directories, Severity, ThreatType, MitreAttack


// ============================================================
// Detection 2: Encrypt-then-Delete Pattern
// MITRE ATT&CK: T1486 - Data Encrypted for Impact
// Confidence: High
// ============================================================
// Purpose: Correlate file creation (encrypted copy) immediately followed by
//          deletion of the original file in the same directory - the defining
//          behavioral signature of file-encrypting ransomware.
// False Positives: File conversion tools that delete originals after convert;
//                  tune by adding process name exclusions for known converters.
// Threshold: 5+ correlated encrypt-delete pairs within 30 seconds
// ============================================================

let EncryptedCreations = DeviceFileEvents
| where TimeGenerated > ago(1h)
| where ActionType == "FileCreated"
| where FileName has_any (".encrypted", ".locked", ".crypted", ".enc", ".crypt", ".ransom")
| extend OriginalName = replace_regex(FileName, @"\.(encrypted|locked|crypted|enc|crypt|ransom)$", "")
| project CreateTime = TimeGenerated, DeviceName, EncryptedFile = FileName,
          OriginalName, FolderPath, InitiatingProcessFileName, AccountName;

let Deletions = DeviceFileEvents
| where TimeGenerated > ago(1h)
| where ActionType == "FileDeleted"
| project DeleteTime = TimeGenerated, DeviceName, DeletedFile = FileName, FolderPath;

EncryptedCreations
| join kind=inner (Deletions) on DeviceName, FolderPath
| where OriginalName == DeletedFile
| where abs(datetime_diff("second", DeleteTime, CreateTime)) < 30
| summarize
    PairCount = count(),
    SampleOriginals = make_set(OriginalName, 5)
    by DeviceName, InitiatingProcessFileName, AccountName, bin(CreateTime, 5m)
| where PairCount >= 5
| extend
    Severity = "Critical",
    ThreatType = "Ransomware_Encrypt_Delete_Cycle",
    MitreAttack = "T1486",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project CreateTime, DeviceName, InitiatingProcessFileName, AccountName,
          PairCount, SampleOriginals, Severity, ThreatType, MitreAttack


// ============================================================
// Detection 3: Token Manipulation - SYSTEM Process Access
// MITRE ATT&CK: T1134.001 - Access Token Manipulation
// Confidence: High
// ============================================================
// Purpose: Detect non-system processes opening handles to SYSTEM-context
//          processes (winlogon.exe, lsass.exe) for token duplication.
//          OpenProcess + OpenProcessToken on these targets is the prerequisite
//          for ImpersonateLoggedOnUser / DuplicateToken privilege escalation.
// False Positives: Security products, debuggers, admin tools.
//                  Tune by adding trusted process exclusions.
// Threshold: Any occurrence from non-whitelisted process
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where ActionType == "ProcessAccessed"
| where FileName in~ ("winlogon.exe", "lsass.exe", "csrss.exe", "services.exe")
| where InitiatingProcessFileName !in~ (
    "MsMpEng.exe",
    "svchost.exe",
    "WmiPrvSE.exe",
    "taskmgr.exe",
    "csrss.exe",
    "wininit.exe",
    "smss.exe"
)
| extend
    Severity = "High",
    ThreatType = "Token_Manipulation_System_Process_Access",
    MitreAttack = "T1134.001",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TimeGenerated, DeviceName, FileName, InitiatingProcessFileName,
          InitiatingProcessCommandLine, AccountName, Severity, ThreatType, MitreAttack


// ============================================================
// Detection 4: Dangerous Privilege Enablement
// MITRE ATT&CK: T1134.001 - Access Token Manipulation
// Confidence: High
// ============================================================
// Purpose: Detect AdjustTokenPrivileges calls enabling high-risk privileges
//          (SeDebugPrivilege, SeBackupPrivilege, SeRestorePrivilege,
//          SeTakeOwnershipPrivilege) from non-system processes.
//          Ransomware enables these to bypass file ACLs before encryption.
// False Positives: Backup agents, debuggers; tune with process exclusions.
// Threshold: Any enablement of 2+ dangerous privileges in same process
// ============================================================

DeviceEvents
| where TimeGenerated > ago(1h)
| where ActionType in ("ProcessPrimaryTokenModified", "ThreadTokenModified")
| where AdditionalFields has_any (
    "SeDebugPrivilege",
    "SeBackupPrivilege",
    "SeRestorePrivilege",
    "SeTakeOwnershipPrivilege",
    "SeShutdownPrivilege"
)
| where InitiatingProcessFileName !in~ (
    "svchost.exe",
    "services.exe",
    "System",
    "lsass.exe",
    "wininit.exe"
)
| extend
    Severity = "High",
    ThreatType = "Dangerous_Privilege_Enablement",
    MitreAttack = "T1134.001",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TimeGenerated, DeviceName, ActionType, InitiatingProcessFileName,
          InitiatingProcessCommandLine, AdditionalFields, AccountName,
          Severity, ThreatType, MitreAttack


// ============================================================
// Detection 5: Aggressive File System Enumeration
// MITRE ATT&CK: T1083 - File and Directory Discovery
// Confidence: Medium
// ============================================================
// Purpose: Detect rapid recursive directory traversal across multiple user
//          directories simultaneously. Ransomware performs an aggressive
//          pre-encryption scan filtering by extension priority across
//          Desktop, Documents, Downloads, and profile root.
// False Positives: Cloud sync clients, antivirus scans, backup software,
//                  IDE indexing. Tune with process exclusions.
// Threshold: >100 file accesses across >10 unique directories in 1 minute
// ============================================================

DeviceFileEvents
| where TimeGenerated > ago(1h)
| where ActionType in ("FileRead", "DirectoryAccessed", "FileAccessed")
| where FolderPath has_any ("\\Desktop\\", "\\Documents\\", "\\Downloads\\", "\\AppData\\")
| where InitiatingProcessFileName !in~ (
    "SearchIndexer.exe",
    "MsMpEng.exe",
    "explorer.exe",
    "OneDrive.exe",
    "Dropbox.exe",
    "GoogleDriveFS.exe",
    "BackupService.exe"
)
| summarize
    AccessCount = count(),
    UniqueDirectories = dcount(FolderPath),
    UniqueExtensions = dcount(FileExtension)
    by DeviceName, InitiatingProcessFileName, AccountName, bin(TimeGenerated, 1m)
| where AccessCount > 100 and UniqueDirectories > 10
| extend
    Severity = "Medium",
    ThreatType = "Aggressive_File_Discovery_Enumeration",
    MitreAttack = "T1083",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TimeGenerated, DeviceName, InitiatingProcessFileName, AccountName,
          AccessCount, UniqueDirectories, UniqueExtensions, Severity, ThreatType, MitreAttack


// ============================================================
// Detection 6: Encryption Target List File Creation
// MITRE ATT&CK: T1083 - File and Directory Discovery
// Confidence: High
// ============================================================
// Purpose: Detect creation of files whose names suggest a file-system
//          scan output list - an artifact of ransomware building its
//          encryption target queue. Multiple ransomware families write
//          such a list before beginning the encryption phase.
// False Positives: Backup software writing file manifests;
//                  tune by excluding known backup process names.
// Threshold: Any occurrence
// ============================================================

DeviceFileEvents
| where TimeGenerated > ago(1h)
| where ActionType == "FileCreated"
| where FileName has_any (
    "targets.list",
    "filelist.txt",
    "file_list.txt",
    "encrypt_targets",
    "files_to_encrypt",
    "target_files"
)
| extend
    Severity = "High",
    ThreatType = "Ransomware_Target_List_Creation",
    MitreAttack = "T1083",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TimeGenerated, DeviceName, FileName, FolderPath, FileSize,
          InitiatingProcessFileName, AccountName, Severity, ThreatType, MitreAttack


// ============================================================
// Detection 7: Ransom Note Deployment to Multiple Locations
// MITRE ATT&CK: T1491.001 - Defacement: Internal Defacement
// Confidence: High
// ============================================================
// Purpose: Detect creation of ransom note files using naming patterns
//          documented across Conti, LockBit, BlackCat, Ryuk, REvil, and
//          other ransomware families. A single occurrence in a user-
//          accessible directory is a critical indicator.
// False Positives: Security awareness training simulations.
// Threshold: Any occurrence
// ============================================================

DeviceFileEvents
| where TimeGenerated > ago(1h)
| where ActionType == "FileCreated"
| where FileName has_any (
    "README_RANSOMWARE",
    "YOUR_FILES_ENCRYPTED",
    "PAYMENT_INSTRUCTIONS",
    "HOW_TO_DECRYPT",
    "DECRYPT_INSTRUCTIONS",
    "RECOVER_FILES",
    "FILES_ENCRYPTED",
    "!README!",
    "RESTORE_FILES",
    "CONTI_README",
    "LOCKBIT_README"
)
| extend
    Severity = "Critical",
    ThreatType = "Ransom_Note_Deployment",
    MitreAttack = "T1491.001",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TimeGenerated, DeviceName, FileName, FolderPath,
          InitiatingProcessFileName, AccountName, Severity, ThreatType, MitreAttack


// ============================================================
// Detection 8: Desktop Wallpaper Registry Modification
// MITRE ATT&CK: T1491.001 - Defacement: Internal Defacement
// Confidence: Medium
// ============================================================
// Purpose: Detect writes to HKCU\Control Panel\Desktop\Wallpaper or
//          WallpaperStyle by non-UI processes. Ransomware (BlackCat, REvil,
//          Ryuk) modifies the wallpaper to display ransom demand imagery
//          ensuring victim sees it on next desktop interaction.
// False Positives: Third-party desktop customization tools, GPO changes.
// Threshold: Any modification from a non-whitelisted process
// ============================================================

DeviceRegistryEvents
| where TimeGenerated > ago(1h)
| where RegistryKey has "Control Panel\\Desktop"
| where RegistryValueName in~ ("Wallpaper", "WallpaperStyle")
| where InitiatingProcessFileName !in~ (
    "explorer.exe",
    "SystemSettings.exe",
    "svchost.exe",
    "UserOOBEBroker.exe",
    "rundll32.exe"
)
| extend
    Severity = "Medium",
    ThreatType = "Ransomware_Wallpaper_Defacement",
    MitreAttack = "T1491.001",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TimeGenerated, DeviceName, RegistryKey, RegistryValueName, RegistryValueData,
          InitiatingProcessFileName, AccountName, Severity, ThreatType, MitreAttack


// ============================================================
// Detection 9: Encryption Key Escrow File Creation
// MITRE ATT&CK: T1486 - Data Encrypted for Impact
// Confidence: High
// ============================================================
// Purpose: Detect creation of files that store or reference ransomware
//          encryption keys. Real ransomware writes a local key file as
//          proof-of-decryption capability or for C2 upload. Any file
//          named MASTER_KEY or containing key material naming patterns
//          created outside system paths is suspicious.
// False Positives: Legitimate key management software; tune by process.
// Threshold: Any occurrence
// ============================================================

DeviceFileEvents
| where TimeGenerated > ago(1h)
| where ActionType == "FileCreated"
| where FileName has_any (
    "MASTER_KEY",
    "master_key",
    "ENCRYPTION_KEY",
    "encryption_key",
    "PRIVATE_KEY",
    "key_escrow",
    "ENCRYPTION_COMPLETE"
)
| where FolderPath !startswith "C:\\Windows\\"
    and FolderPath !startswith "C:\\Program Files\\"
    and FolderPath !has "\\ProgramData\\Microsoft\\"
| extend
    Severity = "High",
    ThreatType = "Ransomware_Key_File_Creation",
    MitreAttack = "T1486",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TimeGenerated, DeviceName, FileName, FolderPath, FileSize,
          InitiatingProcessFileName, AccountName, Severity, ThreatType, MitreAttack


// ============================================================
// Detection 10: Ransomware Multi-Stage Behavioral Correlation
// MITRE ATT&CK: T1134.001, T1486, T1491.001 (Full Killchain)
// Confidence: High
// ============================================================
// Purpose: Correlate token manipulation, mass encryption, and ransom note
//          deployment from the same host within a 15-minute window.
//          All three indicators present simultaneously is near-certain
//          active ransomware regardless of tooling used.
// False Positives: Extremely low when all three indicators are present.
// Threshold: All three indicator types within 15 minutes on same host
// ============================================================

let TokenManipulation = DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where ActionType == "ProcessAccessed"
| where FileName in~ ("winlogon.exe", "lsass.exe")
| where InitiatingProcessFileName !in~ (
    "MsMpEng.exe", "svchost.exe", "WmiPrvSE.exe",
    "taskmgr.exe", "csrss.exe", "wininit.exe"
)
| project TokenTime = TimeGenerated, DeviceName, TokenProcess = InitiatingProcessFileName;

let FileEncryption = DeviceFileEvents
| where TimeGenerated > ago(1h)
| where ActionType in ("FileCreated", "FileRenamed")
| where FileName has_any (".encrypted", ".locked", ".crypted", ".enc", ".crypt", ".ransom")
| summarize EncryptedCount = count() by DeviceName, EncryptionTime = bin(TimeGenerated, 5m)
| where EncryptedCount >= 5;

let RansomNote = DeviceFileEvents
| where TimeGenerated > ago(1h)
| where ActionType == "FileCreated"
| where FileName has_any (
    "README_RANSOMWARE", "YOUR_FILES_ENCRYPTED",
    "HOW_TO_DECRYPT", "DECRYPT_INSTRUCTIONS", "RECOVER_FILES"
)
| project NoteTime = TimeGenerated, DeviceName, NotePath = FolderPath;

TokenManipulation
| join kind=inner (FileEncryption) on DeviceName
| join kind=inner (RansomNote) on DeviceName
| where abs(datetime_diff("minute", TokenTime, EncryptionTime)) < 15
| where abs(datetime_diff("minute", EncryptionTime, NoteTime)) < 15
| extend
    Severity = "Critical",
    ThreatType = "Ransomware_Killchain_Confirmed",
    MitreAttack = "T1134.001,T1486,T1491.001",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TokenTime, DeviceName, TokenProcess, EncryptedCount, NotePath,
          Severity, ThreatType, MitreAttack


// ============================================================
// Detection 11: Batch Script Execution for Payload Initialization
// MITRE ATT&CK: T1204.002 - User Execution: Malicious File
// Confidence: Medium
// ============================================================
// Purpose: Detect cmd.exe executing batch scripts dropped by an external
//          process in non-standard user-writable directories. Ransomware
//          frequently uses a dropper that writes and immediately executes
//          a batch file to test execution permissions and establish
//          initial foothold before deploying main payload components.
// False Positives: Legitimate software installers, developer build scripts.
//                  Tune by excluding known installer parent processes.
// Threshold: cmd.exe running .bat from non-standard writable directories
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where ActionType == "ProcessCreated"
| where FileName =~ "cmd.exe"
| where ProcessCommandLine has ".bat"
| where ProcessCommandLine !has "C:\\Windows\\"
    and ProcessCommandLine !has "C:\\Program Files\\"
    and ProcessCommandLine !has "C:\\ProgramData\\"
| where InitiatingProcessFileName !in~ (
    "msiexec.exe",
    "setup.exe",
    "installer.exe",
    "devenv.exe",
    "code.exe"
)
| extend
    Severity = "Medium",
    ThreatType = "Suspicious_Batch_Script_Execution",
    MitreAttack = "T1204.002",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TimeGenerated, DeviceName, ProcessCommandLine,
          ParentProcessName = InitiatingProcessFileName, AccountName,
          Severity, ThreatType, MitreAttack


// ============================================================
// Detection 12: Ransomware Note Opened via Notepad
// MITRE ATT&CK: T1491.001 - Defacement: Internal Defacement
// Confidence: High
// ============================================================
// Purpose: Detect notepad.exe being spawned with a ransom note file as
//          its argument. Ransomware auto-opens the ransom note to ensure
//          the victim is immediately informed of the attack and demanded
//          payment. This is a documented behavior across many families.
// False Positives: None expected for this specific combination.
// Threshold: Any occurrence
// ============================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where ActionType == "ProcessCreated"
| where FileName =~ "notepad.exe"
| where ProcessCommandLine has_any (
    "README_RANSOMWARE",
    "YOUR_FILES_ENCRYPTED",
    "HOW_TO_DECRYPT",
    "DECRYPT_INSTRUCTIONS",
    "PAYMENT_INSTRUCTIONS",
    "RECOVER_FILES"
)
| extend
    Severity = "Critical",
    ThreatType = "Ransom_Note_Display_Attempt",
    MitreAttack = "T1491.001",
    TestID = "5ed12ef2-5e29-49a2-8f26-269d8e9edcea"
| project TimeGenerated, DeviceName, ProcessCommandLine,
          ParentProcessName = InitiatingProcessFileName, AccountName,
          Severity, ThreatType, MitreAttack
