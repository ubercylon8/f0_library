// ============================================================
// F0RT1KA Detection Queries - Data Exfiltration and Encryption Simulation
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1020, T1041, T1486, T1055, T1083
// Generated by F0RT1KA Defense Guidance Builder
// ============================================================

// ============================================================
// Detection 1: Azure Storage Explorer Reconnaissance
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1083, T1018
// Confidence: High
// ============================================================
// Purpose: Detects PowerShell processes accessing Azure Storage Explorer
//          configuration directories, indicating cloud credential reconnaissance
// False Positives: Legitimate Azure administrators using Storage Explorer,
//                  automated backup tools accessing Azure configurations
// Threshold: Alert on any match; tune based on environment
// ============================================================

DeviceFileEvents
| where Timestamp > ago(24h)
| where InitiatingProcessFileName =~ "powershell.exe" or InitiatingProcessFileName =~ "pwsh.exe"
| where FolderPath has_any (
    "StorageExplorer",
    "Azure Storage Explorer",
    "\\.azure\\",
    "AzureStorageExplorer"
)
| where ActionType in ("FileRead", "FileAccessed", "FileCreated")
| extend
    Severity = "High",
    ThreatType = "CloudCredentialReconnaissance",
    MitreAttack = "T1083,T1018",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    Timestamp,
    DeviceName,
    AccountName,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    FolderPath,
    FileName,
    ActionType,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 2: Azure CLI Credential File Access
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1552.001, T1083
// Confidence: High
// ============================================================
// Purpose: Detects access to sensitive Azure CLI credential files that could
//          be harvested for cloud account compromise
// False Positives: Azure CLI legitimate operations, IDE plugins
// Threshold: Alert on any access from non-az.exe processes
// ============================================================

DeviceFileEvents
| where Timestamp > ago(24h)
| where FolderPath contains "\\.azure\\"
| where FileName in~ (
    "accessTokens.json",
    "azureProfile.json",
    "service_principal_entries.json",
    "msal_http_cache",
    "msal_token_cache.json"
)
| where InitiatingProcessFileName !in~ ("az.exe", "azurecli", "func.exe", "code.exe")
| extend
    Severity = "Critical",
    ThreatType = "CloudCredentialTheft",
    MitreAttack = "T1552.001",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    Timestamp,
    DeviceName,
    AccountName,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    FolderPath,
    FileName,
    ActionType,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 3: Data Staging and Compression Detection
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1560.001, T1074.001
// Confidence: High
// ============================================================
// Purpose: Detects PowerShell Compress-Archive cmdlet usage targeting
//          high-value file types commonly targeted for exfiltration
// False Positives: Legitimate backup scripts, developer archiving
// Threshold: Alert when archive contains sensitive file extensions
// ============================================================

DeviceProcessEvents
| where Timestamp > ago(24h)
| where FileName =~ "powershell.exe" or FileName =~ "pwsh.exe"
| where ProcessCommandLine has "Compress-Archive"
| where ProcessCommandLine has_any (
    ".pdf", ".docx", ".xlsx", ".pptx",
    ".sql", ".db", ".mdb", ".accdb",
    ".p12", ".pfx", ".key", ".pem",
    ".json", ".xml", ".csv"
)
| extend
    Severity = "High",
    ThreatType = "DataStagingForExfiltration",
    MitreAttack = "T1560.001,T1074.001",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    Timestamp,
    DeviceName,
    AccountName,
    FileName,
    ProcessCommandLine,
    InitiatingProcessFileName,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 4: High-Volume File Enumeration
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1083
// Confidence: Medium
// ============================================================
// Purpose: Detects PowerShell Get-ChildItem with recursive searches
//          across user directories indicating data discovery for exfiltration
// False Positives: IT administration scripts, legitimate file searches
// Threshold: 3+ occurrences in 10-minute window
// ============================================================

DeviceProcessEvents
| where Timestamp > ago(24h)
| where FileName =~ "powershell.exe" or FileName =~ "pwsh.exe"
| where ProcessCommandLine has "Get-ChildItem"
| where ProcessCommandLine has "-Recurse"
| where ProcessCommandLine has_any (
    "Documents", "Desktop", "Downloads", "AppData", "ProgramData"
)
| summarize
    EnumerationCount = count(),
    CommandLines = make_set(ProcessCommandLine),
    FirstSeen = min(Timestamp),
    LastSeen = max(Timestamp)
    by DeviceName, AccountName, bin(Timestamp, 10m)
| where EnumerationCount >= 3
| extend
    Severity = "Medium",
    ThreatType = "DataDiscoveryForExfiltration",
    MitreAttack = "T1083",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    FirstSeen,
    LastSeen,
    DeviceName,
    AccountName,
    EnumerationCount,
    CommandLines,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 5: Process Masquerading - conhost.exe from Unusual Location
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1055, T1036.005
// Confidence: Critical
// ============================================================
// Purpose: Detects conhost.exe (Windows Console Host) executing from
//          non-standard locations, indicating process masquerading
// False Positives: Very rare - conhost.exe should only run from System32
// Threshold: Alert on any match
// ============================================================

DeviceProcessEvents
| where Timestamp > ago(24h)
| where FileName =~ "conhost.exe"
| where not(FolderPath startswith "C:\\Windows\\System32")
| extend
    Severity = "Critical",
    ThreatType = "ProcessMasquerading",
    MitreAttack = "T1055,T1036.005",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284",
    ExpectedPath = "C:\\Windows\\System32\\conhost.exe",
    ActualPath = FolderPath
| project
    Timestamp,
    DeviceName,
    AccountName,
    FileName,
    FolderPath,
    ExpectedPath,
    ProcessCommandLine,
    InitiatingProcessFileName,
    InitiatingProcessFolderPath,
    SHA256,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 6: F0RT1KA Test Artifacts in C:\F0 Directory
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: Multiple
// Confidence: High
// ============================================================
// Purpose: Detects file operations in F0RT1KA test directory that match
//          data exfiltration and encryption simulation artifacts
// False Positives: Authorized F0RT1KA test executions
// Threshold: Alert on creation of known malicious artifact patterns
// ============================================================

DeviceFileEvents
| where Timestamp > ago(24h)
| where FolderPath startswith "C:\\F0\\"
| where FileName in~ (
    "azure_reconnaissance.ps1",
    "data_exfiltration.ps1",
    "conhost.exe",
    "azure_storage_info.json",
    "staged_data.zip",
    "exfiltration_status.txt",
    "DECRYPT_INSTRUCTIONS.txt"
)
| extend
    Severity = "High",
    ThreatType = "F0RT1KA_ExfiltrationSimulation",
    MitreAttack = "T1020,T1041,T1486,T1055",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    Timestamp,
    DeviceName,
    AccountName,
    FileName,
    FolderPath,
    ActionType,
    FileSize,
    SHA256,
    InitiatingProcessFileName,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 7: Ransom Note Creation Detection
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1486
// Confidence: Critical
// ============================================================
// Purpose: Detects creation of files with common ransom note naming patterns
// False Positives: Security research, penetration testing
// Threshold: Alert on any match
// ============================================================

DeviceFileEvents
| where Timestamp > ago(24h)
| where ActionType == "FileCreated"
| where FileName matches regex @"(?i)(DECRYPT|RANSOM|README|HOW.?TO|RESTORE|RECOVER|LOCKED|HELP|INSTRUCTIONS|_readme|\.onion)"
| where FileName endswith ".txt" or FileName endswith ".html" or FileName endswith ".hta"
| extend
    Severity = "Critical",
    ThreatType = "RansomNoteCreation",
    MitreAttack = "T1486",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    Timestamp,
    DeviceName,
    AccountName,
    FileName,
    FolderPath,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    SHA256,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 8: Encryption Behavioral Indicators - File Extension Changes
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1486
// Confidence: High
// ============================================================
// Purpose: Detects high-frequency creation of files with .encrypted extension
//          indicating ransomware-like file encryption activity
// False Positives: Legitimate encryption tools like GPG, 7-Zip encryption
// Threshold: 5+ .encrypted files created within 5 minutes
// ============================================================

DeviceFileEvents
| where Timestamp > ago(24h)
| where ActionType == "FileCreated"
| where FileName endswith ".encrypted" or FileName endswith ".enc" or FileName endswith ".locked"
| summarize
    EncryptedFileCount = count(),
    AffectedFiles = make_set(FileName),
    FirstEncryption = min(Timestamp),
    LastEncryption = max(Timestamp)
    by DeviceName, AccountName, InitiatingProcessFileName, bin(Timestamp, 5m)
| where EncryptedFileCount >= 5
| extend
    Severity = "Critical",
    ThreatType = "RansomwareEncryption",
    MitreAttack = "T1486",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    FirstEncryption,
    LastEncryption,
    DeviceName,
    AccountName,
    InitiatingProcessFileName,
    EncryptedFileCount,
    AffectedFiles,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 9: Environment Variable Reconnaissance for Cloud Credentials
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1082, T1552.001
// Confidence: Medium
// ============================================================
// Purpose: Detects PowerShell scripts accessing Azure-related environment
//          variables that may contain cloud credentials or connection strings
// False Positives: Legitimate DevOps scripts, cloud deployment automation
// Threshold: Alert when accessing 3+ Azure-related env vars
// ============================================================

DeviceProcessEvents
| where Timestamp > ago(24h)
| where FileName =~ "powershell.exe" or FileName =~ "pwsh.exe"
| where ProcessCommandLine has "GetEnvironmentVariable"
| where ProcessCommandLine has_any (
    "AZURE_STORAGE",
    "AZURE_CLIENT",
    "AZURE_TENANT",
    "AZURE_SUBSCRIPTION",
    "AZURE_SECRET"
)
| extend
    Severity = "Medium",
    ThreatType = "CloudCredentialEnumeration",
    MitreAttack = "T1082,T1552.001",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    Timestamp,
    DeviceName,
    AccountName,
    FileName,
    ProcessCommandLine,
    InitiatingProcessFileName,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 10: Multi-Phase Exfiltration Correlation Query
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1020, T1041, T1486
// Confidence: Critical
// ============================================================
// Purpose: Correlates multiple attack phases - reconnaissance, staging,
//          and encryption - to detect coordinated exfiltration attacks
// False Positives: Very rare when all phases detected together
// Threshold: Alert when 3+ phases detected within 30-minute window
// ============================================================

let AzureRecon = DeviceFileEvents
| where Timestamp > ago(1h)
| where FolderPath has_any ("StorageExplorer", ".azure", "AzureStorageExplorer")
| where InitiatingProcessFileName =~ "powershell.exe"
| summarize
    ReconEvents = count(),
    ReconFirstSeen = min(Timestamp),
    ReconLastSeen = max(Timestamp)
    by DeviceName, AccountName;

let DataStaging = DeviceFileEvents
| where Timestamp > ago(1h)
| where FolderPath contains "staging" or FileName endswith ".zip"
| where FolderPath startswith "C:\\F0"
| summarize
    StagingEvents = count(),
    StagingFirstSeen = min(Timestamp),
    StagingLastSeen = max(Timestamp)
    by DeviceName, AccountName;

let EncryptionActivity = DeviceFileEvents
| where Timestamp > ago(1h)
| where FileName endswith ".encrypted" or FileName contains "DECRYPT"
| summarize
    EncryptionEvents = count(),
    EncryptionFirstSeen = min(Timestamp),
    EncryptionLastSeen = max(Timestamp)
    by DeviceName, AccountName;

let ProcessMasquerade = DeviceProcessEvents
| where Timestamp > ago(1h)
| where FileName =~ "conhost.exe"
| where not(FolderPath startswith "C:\\Windows\\System32")
| summarize
    MasqueradeEvents = count(),
    MasqueradeFirstSeen = min(Timestamp),
    MasqueradeLastSeen = max(Timestamp)
    by DeviceName, AccountName;

AzureRecon
| join kind=inner (DataStaging) on DeviceName, AccountName
| join kind=inner (EncryptionActivity) on DeviceName, AccountName
| join kind=leftouter (ProcessMasquerade) on DeviceName, AccountName
| extend
    TotalPhases = iff(ReconEvents > 0, 1, 0) +
                  iff(StagingEvents > 0, 1, 0) +
                  iff(EncryptionEvents > 0, 1, 0) +
                  iff(MasqueradeEvents > 0, 1, 0)
| where TotalPhases >= 3
| extend
    Severity = "Critical",
    ThreatType = "CoordinatedExfiltrationAttack",
    MitreAttack = "T1020,T1041,T1486,T1055",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284",
    AttackDuration = datetime_diff('minute',
        max_of(ReconLastSeen, StagingLastSeen, EncryptionLastSeen),
        min_of(ReconFirstSeen, StagingFirstSeen, EncryptionFirstSeen))
| project
    DeviceName,
    AccountName,
    TotalPhases,
    ReconEvents,
    StagingEvents,
    EncryptionEvents,
    MasqueradeEvents,
    AttackDuration,
    ReconFirstSeen,
    EncryptionLastSeen,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 11: Browser Local Storage Access for Cloud Credentials
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1552.001, T1539
// Confidence: Medium
// ============================================================
// Purpose: Detects PowerShell accessing browser local storage directories
//          that may contain cached Azure portal authentication tokens
// False Positives: Browser cleanup scripts, forensic tools
// Threshold: Alert on PowerShell accessing browser storage with Azure focus
// ============================================================

DeviceFileEvents
| where Timestamp > ago(24h)
| where InitiatingProcessFileName =~ "powershell.exe" or InitiatingProcessFileName =~ "pwsh.exe"
| where FolderPath has_any (
    "Chrome\\User Data",
    "Edge\\User Data",
    "Mozilla\\Firefox\\Profiles",
    "Local Storage"
)
| where ActionType in ("FileRead", "FileAccessed")
| extend
    Severity = "Medium",
    ThreatType = "BrowserCredentialHarvesting",
    MitreAttack = "T1552.001,T1539",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    Timestamp,
    DeviceName,
    AccountName,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    FolderPath,
    FileName,
    ActionType,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 12: Registry Access for Azure Storage Connections
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1012, T1552.002
// Confidence: Medium
// ============================================================
// Purpose: Detects registry enumeration targeting Azure Storage Explorer
//          and Azure-related connection configuration entries
// False Positives: Azure CLI operations, legitimate admin tasks
// Threshold: Alert on PowerShell registry access to Azure keys
// ============================================================

DeviceRegistryEvents
| where Timestamp > ago(24h)
| where RegistryKey has_any (
    "Azure Storage Explorer",
    "azurestorage",
    "Microsoft\\Azure"
)
| where InitiatingProcessFileName =~ "powershell.exe" or InitiatingProcessFileName =~ "pwsh.exe"
| extend
    Severity = "Medium",
    ThreatType = "CloudConfigurationReconnaissance",
    MitreAttack = "T1012,T1552.002",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    Timestamp,
    DeviceName,
    AccountName,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    RegistryKey,
    RegistryValueName,
    ActionType,
    Severity,
    ThreatType,
    MitreAttack

// ============================================================
// Detection 13: PowerShell ExecutionPolicy Bypass
// Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
// MITRE ATT&CK: T1059.001
// Confidence: Medium
// ============================================================
// Purpose: Detects PowerShell execution with ExecutionPolicy bypass,
//          a common technique for running malicious scripts
// False Positives: Legitimate automation, software installers
// Threshold: Correlate with other suspicious indicators
// ============================================================

DeviceProcessEvents
| where Timestamp > ago(24h)
| where FileName =~ "powershell.exe" or FileName =~ "pwsh.exe"
| where ProcessCommandLine has "-ExecutionPolicy" and ProcessCommandLine has "Bypass"
| where ProcessCommandLine has_any (
    "azure",
    "exfiltration",
    "staging",
    "storage",
    "reconnaissance",
    "compress",
    "C:\\F0"
)
| extend
    Severity = "High",
    ThreatType = "MaliciousScriptExecution",
    MitreAttack = "T1059.001",
    TestID = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
| project
    Timestamp,
    DeviceName,
    AccountName,
    FileName,
    ProcessCommandLine,
    InitiatingProcessFileName,
    InitiatingProcessCommandLine,
    Severity,
    ThreatType,
    MitreAttack
