// Behavioral Detection Queries for EDR-Freeze Defense Evasion
// FOCUS: Malicious attack behaviors - WerFaultSecure abuse, security process manipulation, and malicious downloads
// Test ID: 87b7653b-2cee-44d4-9d80-73ec94d5e18e

// ========================================
// 1. WerFaultSecure Targeting Security Processes
// ========================================
// Detects WerFaultSecure.exe launched with command-line parameters targeting security processes
// High-confidence indicator of EDR-Freeze or similar defense evasion techniques

DeviceProcessEvents
| where FileName =~ "WerFaultSecure.exe"
| where ProcessCommandLine has_any (
    "MsMpEng",
    "MpDefenderCoreService",
    "NisSrv",
    "SenseCE",
    "SenseIR",
    "SenseNdr",
    "MsSense",
    "CylanceSvc",
    "CSFalconService",
    "TmListen",
    "TmCCSF"
)
| project TimeGenerated, DeviceName, AccountName, ProcessCommandLine,
    InitiatingProcessFileName, InitiatingProcessCommandLine, InitiatingProcessId
| extend Severity = "High"
| extend ThreatType = "Defense Evasion - Security Process Targeting"


// ========================================
// 2. Certutil Downloading Executables
// ========================================
// Detects certutil.exe being used to download executable files
// Common technique for downloading malicious tools after disabling security

DeviceProcessEvents
| where FileName =~ "certutil.exe"
| where ProcessCommandLine has_any ("-urlfetch", "-urlcache", "-verifyctl")
| where ProcessCommandLine has_any (".exe", ".dll", ".ps1", ".bat")
| project TimeGenerated, DeviceName, AccountName, ProcessCommandLine,
    InitiatingProcessFileName, InitiatingProcessCommandLine
| extend Severity = "High"
| extend ThreatType = "Malicious Download via Certutil"


// ========================================
// 3. Security Process Thread Suspension Anomalies
// ========================================
// Detects unusual thread suspension events in security processes
// May indicate EDR-Freeze or similar process manipulation techniques

DeviceEvents
| where ActionType in ("ThreadSuspended", "ProcessSuspended")
| where FileName in~ (
    "MsMpEng.exe",
    "MpDefenderCoreService.exe",
    "NisSrv.exe",
    "SenseCE.exe",
    "SenseIR.exe",
    "CylanceSvc.exe",
    "CSFalconService.exe"
)
| summarize SuspensionCount = count(),
    FirstSeen = min(TimeGenerated),
    LastSeen = max(TimeGenerated),
    SuspensionDuration = datetime_diff('second', max(TimeGenerated), min(TimeGenerated))
    by DeviceName, FileName, InitiatingProcessFileName
| where SuspensionDuration > 5 or SuspensionCount > 1
| extend Severity = "Critical"
| extend ThreatType = "Security Process Manipulation"


// ========================================
// 4. WerFaultSecure PPL Process Creation
// ========================================
// Detects WerFaultSecure being launched as a Protected Process Light (PPL)
// Indicates potential abuse for manipulating protected security processes

DeviceProcessEvents
| where FileName =~ "WerFaultSecure.exe"
| where ProcessCommandLine has "/h"
| extend HasPID = ProcessCommandLine has "/pid"
| extend HasTID = ProcessCommandLine has "/tid"
| extend HasEncFile = ProcessCommandLine has "/encfile"
| where HasPID and HasTID
| project TimeGenerated, DeviceName, AccountName, ProcessCommandLine,
    InitiatingProcessFileName, InitiatingProcessCommandLine, InitiatingProcessId
| extend Severity = "High"
| extend ThreatType = "WerFaultSecure PPL Abuse"


// ========================================
// 5. Combined Behavioral Detection - Full Attack Chain
// ========================================
// Correlates WerFaultSecure abuse with subsequent malicious activity
// Provides high-confidence detection of EDR-Freeze attack pattern

let WerFaultAbuseEvents = DeviceProcessEvents
| where FileName =~ "WerFaultSecure.exe"
| where ProcessCommandLine has_any ("MsMpEng", "MpDefenderCoreService", "NisSrv")
| project WerFaultTime = TimeGenerated, DeviceName, WerFaultAccount = AccountName,
    WerFaultCommand = ProcessCommandLine;

let CertutilDownloads = DeviceProcessEvents
| where FileName =~ "certutil.exe"
| where ProcessCommandLine has_any ("-urlfetch", "-urlcache", "-verifyctl")
| where ProcessCommandLine has ".exe"
| project CertutilTime = TimeGenerated, DeviceName, CertutilAccount = AccountName,
    CertutilCommand = ProcessCommandLine;

WerFaultAbuseEvents
| join kind=inner (CertutilDownloads) on DeviceName
| where CertutilTime between (WerFaultTime .. (WerFaultTime + 90s))
| project TimeGenerated = WerFaultTime, DeviceName,
    WerFaultAccount, WerFaultCommand,
    CertutilTime, CertutilAccount, CertutilCommand,
    TimeDelta = datetime_diff('second', CertutilTime, WerFaultTime)
| extend Severity = "Critical"
| extend ThreatType = "EDR-Freeze Attack Chain Detected"
| extend Description = "WerFaultSecure targeting security process followed by certutil download"


// ========================================
// 6. File Creation in Suspicious Locations
// ========================================
// Detects files being created in C:\F0 or other non-standard locations
// Common staging directory for attack tools

DeviceFileEvents
| where ActionType == "FileCreated"
| where FolderPath startswith "C:\\F0\\" or FolderPath startswith "C:\\Temp\\"
| where FileName endswith ".exe" or FileName endswith ".dll"
| where InitiatingProcessFileName !in~ ("explorer.exe", "msiexec.exe", "MpCmdRun.exe")
| project TimeGenerated, DeviceName, AccountName, FileName, FolderPath,
    InitiatingProcessFileName, InitiatingProcessCommandLine
| extend Severity = "Medium"
| extend ThreatType = "Suspicious File Staging"


// ========================================
// 7. CreateProcessAsPPL Usage Detection
// ========================================
// Detects processes attempting to create PPL (Protected Process Light) processes
// Indicates advanced process manipulation techniques

DeviceProcessEvents
| where ProcessCommandLine has_any ("CreateProcessAsPPL", "WinTCB", "ProtectionLevel")
| project TimeGenerated, DeviceName, AccountName, FileName,
    ProcessCommandLine, InitiatingProcessFileName
| extend Severity = "High"
| extend ThreatType = "PPL Process Creation Attempt"


// ========================================
// 8. Defender Core Service Anomalies
// ========================================
// Detects unusual patterns in Defender process behavior
// May indicate successful defense evasion

DeviceProcessEvents
| where FileName in~ ("MsMpEng.exe", "MpDefenderCoreService.exe", "NisSrv.exe")
| where ActionType in ("ProcessTerminated", "ProcessSuspended")
| project TimeGenerated, DeviceName, ActionType, FileName,
    ProcessCommandLine, InitiatingProcessFileName, InitiatingProcessCommandLine
| extend Severity = "Critical"
| extend ThreatType = "Defender Process Termination/Suspension"


// ========================================
// 9. Network-Based Download via LOLBin
// ========================================
// Detects Living-Off-the-Land binaries downloading content from known repositories

DeviceNetworkEvents
| where InitiatingProcessFileName in~ ("certutil.exe", "bitsadmin.exe", "curl.exe", "wget.exe")
| where RemoteUrl has_any ("github.com", "raw.githubusercontent.com", "pastebin.com")
| where RemoteUrl has_any (".exe", ".dll", ".ps1")
| project TimeGenerated, DeviceName, AccountName, InitiatingProcessFileName,
    InitiatingProcessCommandLine, RemoteUrl, RemoteIP
| extend Severity = "High"
| extend ThreatType = "Malicious Download via LOLBin"


// ========================================
// 10. Time-Based Correlation - Multiple Indicators
// ========================================
// Aggregates multiple suspicious events within a time window
// Increases detection confidence by correlating related activities

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where (
    (FileName =~ "WerFaultSecure.exe" and ProcessCommandLine has_any ("MsMpEng", "MpDefenderCoreService"))
    or (FileName =~ "certutil.exe" and ProcessCommandLine has "-urlfetch")
    or (FileName =~ "EDR-Freeze.exe")
    or (ProcessCommandLine has "CreateProcessAsPPL")
)
| summarize EventCount = count(),
    EventTypes = make_set(FileName),
    Commands = make_set(ProcessCommandLine),
    FirstEvent = min(TimeGenerated),
    LastEvent = max(TimeGenerated)
    by DeviceName, AccountName, bin(TimeGenerated, 5m)
| where EventCount >= 2
| extend Severity = "Critical"
| extend ThreatType = "Multiple Defense Evasion Indicators"
| project TimeGenerated = FirstEvent, DeviceName, AccountName, EventCount,
    EventTypes, TimeWindow = datetime_diff('second', LastEvent, FirstEvent), Severity, ThreatType