// Behavioral Detection Queries for SafePay Go-Native Ransomware Simulation
// FOCUS: Malicious ransomware behaviors only (excludes test setup/staging)
//
// Test ID: 6717c98c-b3db-490e-b03c-7b3bd3fb02ee
// Test Name: SafePay Go-Native Ransomware Simulation
// MITRE ATT&CK: T1486, T1560.001, T1071.001, T1490, T1083, T1005

// 1. Mass File Creation Detection
// Detects rapid creation of large numbers of files in user directories
DeviceFileEvents
| where ActionType == "FileCreated"
| where FolderPath has_any ("Users\\", "Documents\\", "Desktop\\")
| summarize CreatedCount=count(), UniqueExtensions=dcount(tostring(split(FileName, ".")[-1])) 
by DeviceName, InitiatingProcessFileName, InitiatingProcessCommandLine, DeviceId, bin(Timestamp, 1m)
| where CreatedCount > 150  // Threshold for suspicious mass file creation
| where UniqueExtensions >= 5  // Multiple file types indicate realistic document simulation
| where InitiatingProcessFileName !in ("msedge.exe", "msedgewebview2.exe", "sdxhelper.exe", "explorer.exe", "onedrivesetup.exe") // Make sure  to exclude legitimate processes. 

// 2. WinRAR Compression with Suspicious Arguments
// Detects WinRAR usage with arguments typical of data staging/exfiltration
DeviceProcessEvents
| where ProcessCommandLine contains "winrar" or FileName =~ "winrar.exe"
| where ProcessCommandLine has_any ("-r", "-m", "-ep1", "Archive", "EXFIL")
| where ProcessCommandLine contains ".rar"
| project DeviceName, AccountName, ProcessCommandLine, InitiatingProcessFileName

// 3. Selective Mass File Deletion
// Detects large-scale deletion of document files (ransomware preparation)
DeviceFileEvents
| where ActionType == "FileDeleted"
| where Timestamp > ago(3h)
| where FileName has_any (".docx", ".xlsx", ".pdf", ".txt", ".csv", ".sql", ".bak", ".ppt", ".doc", ".zip")
| summarize DeletedCount=count(), DeletedExtensions=make_set(tostring(split(FileName, ".")[-1]))
    by DeviceName, InitiatingProcessFileName, bin(Timestamp, 3h), DeviceId, ReportId
| where DeletedCount > 50  // Threshold for suspicious mass deletion
| where array_length(DeletedExtensions) >= 3  // Multiple document types deleted

// 4. File Extension Changes (.safepay Encryption)
// Detects files being "encrypted" with suspicious extensions
DeviceFileEvents
| where ActionType == "FileCreated"
| where TimeGenerated > ago(1h)
| where FileName endswith ".safepay"
| summarize EncryptedCount=count(), OriginalExtensions=make_set(tostring(split(replace_string(FileName, ".safepay", ""), ".")[-1]))
    by DeviceName, InitiatingProcessFileName, AccountName, bin(TimeGenerated, 5m)
| where EncryptedCount > 20  // Threshold for suspicious encryption activity

// 5. Ransom Note Creation
// Detects creation of ransom note files with typical naming patterns
DeviceFileEvents
| where ActionType == "FileCreated"
| where TimeGenerated > ago(1h)
| where FileName has_any ("readme", "ransom", "decrypt", "recovery", "safepay")
| where FileName has_any (".txt", ".html", ".hta")
| project TimeGenerated, DeviceName, AccountName, FolderPath, FileName, InitiatingProcessFileName

// 6. Go Binary Ransomware Behavior Pattern
// Detects Go binaries exhibiting ransomware-like file system activity
DeviceFileEvents
| where TimeGenerated > ago(1h)
| where InitiatingProcessFileName endswith ".exe"
| where ActionType in ("FileCreated", "FileDeleted", "FileModified")
| summarize 
    CreatedFiles=countif(ActionType == "FileCreated"),
    DeletedFiles=countif(ActionType == "FileDeleted"),
    ModifiedFiles=countif(ActionType == "FileModified"),
    UniqueDirectories=dcount(FolderPath),
    SuspiciousExtensions=countif(FileName has_any (".safepay", ".rar"))
    by DeviceName, InitiatingProcessFileName, InitiatingProcessCommandLine, AccountName, bin(TimeGenerated, 5m)
| where CreatedFiles > 50 or DeletedFiles > 30 or SuspiciousExtensions > 5
| where UniqueDirectories > 10  // Indicates directory traversal behavior

// 7. Archive File Staging Pattern
DeviceFileEvents
| where ActionType == "FileCreated"
| where Timestamp > ago(1h)
| where (tolower(FileName) endswith ".rar" or tolower(FileName) endswith ".zip")
| where tolower(FileName) has_any ("archive","data","exfil","finance","hr","legal","it","sales")
| summarize ArchiveCount=count(), ArchiveNames=make_set(FileName), ReportId=any(ReportId)
  by DeviceId, DeviceName, InitiatingProcessFileName, Timestamp=bin(Timestamp, 10m)
| where ArchiveCount >= 3
| project DeviceId, Timestamp, ReportId, DeviceName, InitiatingProcessFileName, ArchiveCount, ArchiveNames


// 8. Notepad Ransom Note Display
// Detects Notepad being used to display ransom notes
DeviceProcessEvents
| where FileName =~ "notepad.exe"
| where ProcessCommandLine has_any ("readme", "ransom", "decrypt", "safepay")
| project Timestamp, DeviceName, AccountName, ProcessCommandLine, InitiatingProcessFileName, ReportId, DeviceId
