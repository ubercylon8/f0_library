// ============================================================================
// DEFENSE GUIDANCE: KQL Detection Queries
// ============================================================================
// Test ID: 09efee46-f098-4948-8e35-dded024cd1e7
// Test Name: Sliver C2 Client Detection
// MITRE ATT&CK: T1219 - Remote Access Software
// Created: 2025-12-07
// Author: F0RT1KA Defense Guidance Builder
// ============================================================================
//
// TECHNIQUE-FOCUSED DETECTION PRINCIPLE:
// These detections target the Sliver C2 framework and similar remote access
// tools, NOT the F0RT1KA testing framework specifically. They will catch
// real-world attackers deploying Sliver or similar C2 frameworks.
//
// ============================================================================


// ============================================================================
// QUERY 1: Sliver C2 Client Binary Execution Detection
// Purpose: Detect execution of Sliver C2 client binaries
// Confidence: HIGH
// False Positives: Authorized red team testing, security assessments
// Threshold: Any execution of known Sliver patterns
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where FileName =~ "sliver_client.exe"
    or FileName =~ "sliver.exe"
    or FileName matches regex @"(?i)sliver[-_]?(client|implant|beacon)?\.exe"
    or ProcessCommandLine has_any ("sliver", "--mtls", "--wg", "--dns", "--http", "--beacon")
| extend SliverIndicator = case(
    FileName =~ "sliver_client.exe", "Direct Sliver Client",
    FileName =~ "sliver.exe", "Sliver Executable",
    ProcessCommandLine has "--mtls", "Sliver mTLS Connection",
    ProcessCommandLine has "--wg", "Sliver WireGuard Connection",
    ProcessCommandLine has "--dns", "Sliver DNS Connection",
    ProcessCommandLine has "--http", "Sliver HTTP Connection",
    "Generic Sliver Pattern"
)
| project TimeGenerated, DeviceName, AccountName, FileName, FolderPath,
    ProcessCommandLine, ProcessId, ParentProcessId, SliverIndicator
| extend
    Severity = "Critical",
    ThreatType = "C2 Framework - Sliver Client Execution",
    MitreAttack = "T1219",
    TestID = "09efee46-f098-4948-8e35-dded024cd1e7",
    Confidence = "High"


// ============================================================================
// QUERY 2: C2 Framework Binary File Drop Detection
// Purpose: Detect file creation of known C2 framework binaries
// Confidence: HIGH
// False Positives: Authorized penetration testing, software deployments
// Threshold: Any file creation matching C2 framework patterns
// ============================================================================

DeviceFileEvents
| where TimeGenerated > ago(1h)
| where ActionType == "FileCreated"
| where FileName matches regex @"(?i)(sliver|cobalt[-_]?strike|covenant|metasploit|empire|havoc|mythic|brute[-_]?ratel).*\.(exe|dll|bin)"
    or FolderPath has "c:\\F0"
| where FileName endswith ".exe" or FileName endswith ".dll"
| extend C2Framework = case(
    FileName has_any ("sliver", "SLIVER"), "Sliver C2",
    FileName has_any ("cobalt", "beacon"), "Cobalt Strike",
    FileName has "covenant", "Covenant C2",
    FileName has "metasploit", "Metasploit",
    FileName has "empire", "Empire",
    FileName has "havoc", "Havoc C2",
    FileName has "mythic", "Mythic C2",
    FileName has "brute", "Brute Ratel",
    FolderPath has "c:\\F0", "F0RT1KA Test Binary",
    "Unknown C2 Framework"
)
| project TimeGenerated, DeviceName, FileName, FolderPath, SHA256,
    InitiatingProcessFileName, InitiatingProcessCommandLine, C2Framework
| extend
    Severity = "High",
    ThreatType = "C2 Framework Binary Dropped",
    MitreAttack = "T1219",
    TestID = "09efee46-f098-4948-8e35-dded024cd1e7",
    Confidence = "High"


// ============================================================================
// QUERY 3: Go-Compiled Binary with C2 Characteristics
// Purpose: Detect Go-compiled binaries with C2 framework indicators
// Confidence: MEDIUM
// False Positives: Legitimate Go applications, DevOps tools
// Threshold: Go binary with network + process enumeration capabilities
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where ProcessCommandLine has_any ("--help", "-h", "version", "--version")
| where FolderPath !startswith "C:\\Windows\\"
    and FolderPath !startswith "C:\\Program Files\\"
    and FolderPath !startswith "C:\\Program Files (x86)\\"
| join kind=inner (
    DeviceFileCertificateInfo
    | where TimeGenerated > ago(24h)
    | where Signer == "" or IsSigned == false  // Unsigned binary
) on SHA256
| extend SuspiciousIndicators = case(
    FolderPath has "c:\\F0", "Test directory execution",
    FolderPath has "\\Temp\\", "Temp directory execution",
    FolderPath has "\\AppData\\", "User profile execution",
    "Unusual execution path"
)
| project TimeGenerated, DeviceName, AccountName, FileName, FolderPath,
    ProcessCommandLine, SHA256, SuspiciousIndicators
| extend
    Severity = "Medium",
    ThreatType = "Suspicious Go Binary Execution",
    MitreAttack = "T1219",
    TestID = "09efee46-f098-4948-8e35-dded024cd1e7",
    Confidence = "Medium"


// ============================================================================
// QUERY 4: C2 Beaconing Pattern Detection
// Purpose: Detect periodic network beaconing consistent with C2 communication
// Confidence: MEDIUM-HIGH
// False Positives: Legitimate heartbeat applications, monitoring tools
// Threshold: Regular interval connections (with jitter) to external IPs
// ============================================================================

let beaconInterval = 60s;  // Expected beacon interval
let jitterTolerance = 10s; // Acceptable jitter
DeviceNetworkEvents
| where TimeGenerated > ago(2h)
| where ActionType == "ConnectionSuccess"
| where RemoteIPType == "Public"
| where InitiatingProcessFileName !in~ ("svchost.exe", "MsMpEng.exe", "chrome.exe", "firefox.exe", "msedge.exe")
| summarize
    ConnectionCount = count(),
    UniqueRemoteIPs = dcount(RemoteIP),
    RemoteIPs = make_set(RemoteIP),
    RemotePorts = make_set(RemotePort),
    FirstConnection = min(TimeGenerated),
    LastConnection = max(TimeGenerated)
    by DeviceName, InitiatingProcessFileName, bin(TimeGenerated, beaconInterval)
| where ConnectionCount >= 5  // At least 5 connections in the window
| where UniqueRemoteIPs <= 3  // Connecting to limited IPs (typical C2)
| extend
    SessionDuration = datetime_diff('second', LastConnection, FirstConnection),
    AverageInterval = datetime_diff('second', LastConnection, FirstConnection) / toreal(ConnectionCount)
| where AverageInterval between (50 .. 70)  // ~60 second beaconing with jitter
| project TimeGenerated = FirstConnection, DeviceName, InitiatingProcessFileName,
    ConnectionCount, RemoteIPs, RemotePorts, SessionDuration, AverageInterval
| extend
    Severity = "High",
    ThreatType = "Potential C2 Beaconing Pattern",
    MitreAttack = "T1219",
    TestID = "09efee46-f098-4948-8e35-dded024cd1e7",
    Confidence = "Medium-High"


// ============================================================================
// QUERY 5: Sliver-Specific Command Line Arguments
// Purpose: Detect Sliver-specific command line patterns
// Confidence: HIGH
// False Positives: Very low - these are Sliver-specific arguments
// Threshold: Any occurrence of Sliver-specific arguments
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where ProcessCommandLine has_any (
    // Sliver connection modes
    "--mtls",           // mTLS connection
    "--wg",             // WireGuard connection
    "--http",           // HTTP connection
    "--https",          // HTTPS connection
    "--dns",            // DNS tunneling
    // Sliver operators
    "--operator",
    "--lhost",
    "--lport",
    // Sliver implant generation
    "generate",
    "--skip-symbols",
    "--disable-sgn",
    // Sliver beacons
    "--beacon",
    "--jitter"
)
| where ProcessCommandLine !has "npm"  // Exclude npm commands that might contain similar strings
    and ProcessCommandLine !has "docker"  // Exclude docker commands
| extend SliverConnectionType = case(
    ProcessCommandLine has "--mtls", "mTLS (Mutual TLS)",
    ProcessCommandLine has "--wg", "WireGuard",
    ProcessCommandLine has "--dns", "DNS Tunneling",
    ProcessCommandLine has "--http" or ProcessCommandLine has "--https", "HTTP/HTTPS",
    ProcessCommandLine has "--beacon", "Beacon Mode",
    "Unknown"
)
| project TimeGenerated, DeviceName, AccountName, FileName, FolderPath,
    ProcessCommandLine, SliverConnectionType
| extend
    Severity = "Critical",
    ThreatType = "Sliver C2 Specific Arguments Detected",
    MitreAttack = "T1219",
    TestID = "09efee46-f098-4948-8e35-dded024cd1e7",
    Confidence = "High"


// ============================================================================
// QUERY 6: Process Execution from F0RT1KA Test Directory
// Purpose: Detect any process execution from the F0RT1KA test directory
// Confidence: HIGH
// False Positives: Scheduled F0RT1KA security testing
// Threshold: Any process execution from c:\F0
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where FolderPath startswith "c:\\F0\\" or FolderPath startswith "C:\\F0\\"
| extend TestType = case(
    FileName =~ "sliver_client.exe", "Sliver C2 Client Test",
    FileName has "sliver", "Sliver Related Test",
    FileName endswith ".exe", "Unknown Test Execution",
    "Non-executable"
)
| project TimeGenerated, DeviceName, AccountName, FileName, FolderPath,
    ProcessCommandLine, SHA256, TestType, InitiatingProcessFileName
| extend
    Severity = "High",
    ThreatType = "F0RT1KA Test Execution",
    MitreAttack = "T1219",
    TestID = "09efee46-f098-4948-8e35-dded024cd1e7",
    Confidence = "High"


// ============================================================================
// QUERY 7: Combined C2 Framework Behavioral Detection
// Purpose: Correlate multiple indicators for high-confidence C2 detection
// Confidence: HIGH
// False Positives: Very rare (requires multiple correlated indicators)
// Threshold: 2+ indicators within 30-minute window
// ============================================================================

let FileDrops = DeviceFileEvents
| where TimeGenerated > ago(2h)
| where ActionType == "FileCreated"
| where FileName matches regex @"(?i)(sliver|beacon|implant|payload).*\.exe"
    or FolderPath has "c:\\F0"
| summarize FileDropCount = count() by DeviceName, bin(TimeGenerated, 30m)
| where FileDropCount >= 1
| project Computer = DeviceName, DropTime = TimeGenerated, FileDropCount;
let ProcessExec = DeviceProcessEvents
| where TimeGenerated > ago(2h)
| where FileName matches regex @"(?i)sliver.*\.exe"
    or ProcessCommandLine has_any ("--mtls", "--wg", "--dns", "--http", "--beacon")
    or FolderPath startswith "c:\\F0"
| summarize ExecCount = count() by DeviceName, bin(TimeGenerated, 30m)
| project Computer = DeviceName, ExecTime = TimeGenerated, ExecCount;
let NetworkActivity = DeviceNetworkEvents
| where TimeGenerated > ago(2h)
| where InitiatingProcessFileName !in~ ("svchost.exe", "MsMpEng.exe", "System")
| where RemoteIPType == "Public"
| summarize NetCount = count() by DeviceName, InitiatingProcessFileName, bin(TimeGenerated, 30m)
| where NetCount >= 3  // Multiple outbound connections
| project Computer = DeviceName, NetTime = TimeGenerated, NetCount, InitiatingProcessFileName;
// Correlate indicators
FileDrops
| join kind=leftouter (ProcessExec) on Computer
| join kind=leftouter (NetworkActivity) on Computer
| extend IndicatorCount = (
    iff(FileDropCount > 0, 1, 0) +
    iff(isnotnull(ExecCount), 1, 0) +
    iff(isnotnull(NetCount), 1, 0)
)
| where IndicatorCount >= 2
| project Computer, TimeGenerated = DropTime, FileDropCount, ExecCount, NetCount,
    IndicatorCount, InitiatingProcessFileName
| extend
    Severity = "Critical",
    ThreatType = "C2 Framework Multi-Indicator Detection",
    MitreAttack = "T1219",
    TestID = "09efee46-f098-4948-8e35-dded024cd1e7",
    Confidence = "High"


// ============================================================================
// QUERY 8: Unsigned Binary Execution with Network Activity
// Purpose: Detect unsigned binaries making network connections
// Confidence: MEDIUM
// False Positives: Some legitimate unsigned applications
// Threshold: Unsigned binary with external network connections
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where FolderPath !startswith "C:\\Windows\\"
    and FolderPath !startswith "C:\\Program Files\\"
| join kind=inner (
    DeviceNetworkEvents
    | where TimeGenerated > ago(1h)
    | where RemoteIPType == "Public"
    | where ActionType == "ConnectionSuccess"
) on DeviceName, $left.ProcessId == $right.InitiatingProcessId
| summarize
    NetworkConnections = count(),
    RemoteIPs = make_set(RemoteIP),
    RemotePorts = make_set(RemotePort)
    by DeviceName, FileName, FolderPath, SHA256, ProcessCommandLine
| where NetworkConnections >= 1
| where FolderPath has_any ("c:\\F0", "\\Temp\\", "\\AppData\\", "\\Downloads\\")
| project TimeGenerated = now(), DeviceName, FileName, FolderPath,
    ProcessCommandLine, SHA256, NetworkConnections, RemoteIPs, RemotePorts
| extend
    Severity = "High",
    ThreatType = "Unsigned Binary with Network Activity",
    MitreAttack = "T1219",
    TestID = "09efee46-f098-4948-8e35-dded024cd1e7",
    Confidence = "Medium"


// ============================================================================
// HUNTING QUERY: Known C2 Framework Process Names
// Purpose: Hunt for known C2 framework process names
// Confidence: HIGH
// False Positives: Coordinate with security team for authorized testing
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName matches regex @"(?i)(sliver|cobalt[-_]?strike|beacon|covenant|metasploit|meterpreter|empire|havoc|mythic|brute[-_]?ratel)"
    or ProcessCommandLine matches regex @"(?i)(sliver|beacon|implant|--mtls|--wg|meterpreter)"
| project TimeGenerated, DeviceName, AccountName, FileName, FolderPath,
    ProcessCommandLine, SHA256, InitiatingProcessFileName
| extend
    Severity = "Critical",
    ThreatType = "Known C2 Framework Detected",
    MitreAttack = "T1219",
    Confidence = "High"


// ============================================================================
// ALERT SUMMARY DASHBOARD QUERY
// Purpose: Aggregate all C2-related detections for SOC dashboard
// ============================================================================

let C2FileDetections = DeviceFileEvents
| where TimeGenerated > ago(24h)
| where ActionType == "FileCreated"
| where FileName matches regex @"(?i)(sliver|beacon|implant).*\.(exe|dll)"
    or FolderPath has "c:\\F0"
| summarize FileEvents = count() by DeviceName, bin(TimeGenerated, 1h)
| extend DetectionType = "C2 Binary File Drop";
let C2ProcessDetections = DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where FileName matches regex @"(?i)sliver"
    or ProcessCommandLine has_any ("--mtls", "--wg", "--dns", "--beacon")
    or FolderPath startswith "c:\\F0"
| summarize ProcessEvents = count() by Computer = DeviceName, bin(TimeGenerated, 1h)
| extend DetectionType = "C2 Process Execution";
let C2NetworkDetections = DeviceNetworkEvents
| where TimeGenerated > ago(24h)
| where InitiatingProcessFileName matches regex @"(?i)sliver"
| summarize NetworkEvents = count() by Computer = DeviceName, bin(TimeGenerated, 1h)
| extend DetectionType = "C2 Network Activity";
union
    (C2FileDetections | project TimeGenerated, Computer = DeviceName, EventCount = FileEvents, DetectionType),
    (C2ProcessDetections | project TimeGenerated, Computer, EventCount = ProcessEvents, DetectionType),
    (C2NetworkDetections | project TimeGenerated, Computer, EventCount = NetworkEvents, DetectionType)
| summarize TotalEvents = sum(EventCount), DetectionTypes = make_set(DetectionType)
    by Computer, bin(TimeGenerated, 1h)
| order by TotalEvents desc
| project TimeGenerated, Computer, TotalEvents, DetectionTypes,
    Severity = case(TotalEvents >= 10, "Critical", TotalEvents >= 5, "High", "Medium"),
    ThreatType = "C2 Activity Cluster",
    MitreAttack = "T1219"
