*/

rule PowerShell_DataStagingForExfiltration {
    meta:
        description = "Detects PowerShell scripts staging data for exfiltration"
        author = "F0RT1KA"
        date = "2024-01-15"
        test_id = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
        mitre_attack = "T1074.001,T1560.001"
        confidence = "medium"

    strings:
        // File enumeration patterns
        $enum1 = /Get-ChildItem.*-Recurse.*\*\.pdf/ ascii wide nocase
        $enum2 = /Get-ChildItem.*-Recurse.*\*\.docx/ ascii wide nocase
        $enum3 = /Get-ChildItem.*-Recurse.*\*\.xlsx/ ascii wide nocase
        $enum4 = /Get-ChildItem.*-Recurse.*\*\.p12/ ascii wide nocase
        $enum5 = /Get-ChildItem.*-Recurse.*\*\.pfx/ ascii wide nocase

        // Copy operations to staging
        $copy1 = /Copy-Item.*staging/ ascii wide nocase
        $copy2 = /Copy-Item.*exfil/ ascii wide nocase
        $copy3 = /Copy-Item.*temp.*zip/ ascii wide nocase

        // Compression
        $zip1 = /Compress-Archive.*-DestinationPath/ ascii wide nocase
        $zip2 = /Compress-Archive.*-CompressionLevel/ ascii wide nocase

        // High-value directories
        $dir1 = "$env:USERPROFILE\\Documents" ascii wide nocase
        $dir2 = "$env:USERPROFILE\\Desktop" ascii wide nocase
        $dir3 = "$env:APPDATA" ascii wide nocase
        $dir4 = "C:\\ProgramData" ascii wide nocase

    condition:
        (
            2 of ($enum*) and any of ($copy*)
        ) or
        (
            any of ($zip*) and 2 of ($dir*)
        ) or
        (
            any of ($copy*) and any of ($zip*)
        )
}
