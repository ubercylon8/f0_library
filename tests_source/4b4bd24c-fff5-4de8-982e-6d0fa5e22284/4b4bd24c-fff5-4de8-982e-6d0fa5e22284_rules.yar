/*
    ============================================================
    YARA Rule: PowerShell Azure Credential Harvesting
    Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
    MITRE ATT&CK: T1552.001
    Confidence: High
    Description: Generic detection for PowerShell scripts targeting
                 Azure credentials and configurations
    Author: F0RT1KA Defense Guidance Builder
    Date: 2024-01-15
    ============================================================
*/

rule PowerShell_AzureCredentialHarvesting {
    meta:
        description = "Detects PowerShell scripts harvesting Azure credentials"
        author = "F0RT1KA"
        date = "2024-01-15"
        test_id = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
        mitre_attack = "T1552.001"
        confidence = "high"

    strings:
        // Azure credential file access
        $az_cred1 = /\$env:USERPROFILE\\.azure/ ascii wide nocase
        $az_cred2 = "accessTokens.json" ascii wide nocase
        $az_cred3 = "azureProfile.json" ascii wide nocase
        $az_cred4 = "service_principal" ascii wide nocase

        // Environment variable access
        $env1 = /GetEnvironmentVariable.*AZURE/ ascii wide nocase
        $env2 = /\[Environment\]::GetEnvironmentVariable.*AZURE/ ascii wide nocase

        // Storage connection patterns
        $conn1 = /AZURE_STORAGE_CONNECTION_STRING/ ascii wide
        $conn2 = /DefaultEndpointsProtocol=https;AccountName=/ ascii wide

        // Get-Content or reading operations
        $read1 = /Get-Content.*\.azure/ ascii wide nocase
        $read2 = /\[IO\.File\]::ReadAllText.*\.azure/ ascii wide nocase

        // Suspicious combinations
        $combo1 = /ConvertFrom-Json.*accessToken/ ascii wide nocase
        $combo2 = /ConvertFrom-Json.*azureProfile/ ascii wide nocase

    condition:
        (
            2 of ($az_cred*) and (any of ($read*) or any of ($env*))
        ) or
        (
            any of ($conn*) and any of ($env*)
        ) or
        (
            any of ($combo*)
        )
}

/*
    ============================================================
    YARA Rule: PowerShell Data Staging for Exfiltration
    Test ID: 4b4bd24c-fff5-4de8-982e-6d0fa5e22284
    MITRE ATT&CK: T1074.001, T1560.001
    Confidence: Medium
    Description: Generic detection for PowerShell scripts staging
                 data for exfiltration
    Author: F0RT1KA Defense Guidance Builder
    Date: 2024-01-15
