*/

rule F0RTIKA_AzureReconScript {
    meta:
        description = "Detects PowerShell Azure Storage reconnaissance script from F0RT1KA test"
        author = "F0RT1KA"
        date = "2024-01-15"
        test_id = "4b4bd24c-fff5-4de8-982e-6d0fa5e22284"
        mitre_attack = "T1083,T1018,T1552.001"
        confidence = "high"

    strings:
        // Function names and patterns
        $func1 = "Discover-AzureStorage" ascii wide nocase
        $func2 = "Test-Administrator" ascii wide nocase
        $func3 = "Set-ExecutionPolicyBypass" ascii wide nocase

        // Azure Storage Explorer paths
        $path1 = "StorageExplorer" ascii wide nocase
        $path2 = "Azure Storage Explorer" ascii wide nocase
        $path3 = "\\.azure\\" ascii wide nocase
        $path4 = "AzureStorageExplorer" ascii wide nocase

        // Azure CLI credential files
        $cred1 = "accessTokens.json" ascii wide nocase
        $cred2 = "azureProfile.json" ascii wide nocase
        $cred3 = "service_principal_entries.json" ascii wide nocase
        $cred4 = "msal_http_cache" ascii wide nocase

        // Azure storage patterns
        $storage1 = "blob.core.windows.net" ascii wide nocase
        $storage2 = "table.core.windows.net" ascii wide nocase
        $storage3 = "queue.core.windows.net" ascii wide nocase
        $storage4 = "file.core.windows.net" ascii wide nocase

        // Environment variable names
        $env1 = "AZURE_STORAGE_CONNECTION_STRING" ascii wide
        $env2 = "AZURE_STORAGE_ACCOUNT" ascii wide
        $env3 = "AZURE_STORAGE_KEY" ascii wide
        $env4 = "AZURE_CLIENT_SECRET" ascii wide

        // Registry paths
        $reg1 = "HKCU:\\Software\\Microsoft\\Azure Storage Explorer" ascii wide
        $reg2 = "HKLM:\\SOFTWARE\\Microsoft\\Azure" ascii wide

        // Output indicators
        $output1 = "azure_storage_info.json" ascii wide nocase
        $output2 = "exfiltration_status.txt" ascii wide nocase
        $output3 = "AZURE_RECON_COMPLETE" ascii wide

    condition:
        (
            // Must have at least one function indicator
            any of ($func*) and
            // Plus Azure path patterns
            2 of ($path*) and
            // Plus credential file or env var indicators
            (any of ($cred*) or any of ($env*))
        ) or
        (
            // Alternative: Storage patterns with registry enumeration
            2 of ($storage*) and any of ($reg*)
        ) or
        (
            // High confidence: specific output file indicators
            any of ($output*) and any of ($path*)
        )
}

