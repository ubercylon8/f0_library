// ============================================================================
// DEFENSE GUIDANCE: KQL Detection Queries
// ============================================================================
// Test ID: 12afe0fc-597b-4e79-9cc4-40b4675ee83c
// Test Name: LimaCharlie Timeout Validation Harness
// MITRE ATT&CK: T1497.001 - Virtualization/Sandbox Evasion: System Checks
// Created: 2025-12-07
// Author: F0RT1KA Defense Guidance Builder
// ============================================================================
//
// DETECTION PRINCIPLE:
// These detections target long-running processes and timeout evasion techniques
// commonly used by malware to evade sandbox analysis. While this specific test
// is a utility, the behaviors mirror real-world sandbox evasion patterns.
//
// ============================================================================


// ============================================================================
// QUERY 1: Long-Running Process Detection
// Purpose: Detect processes running longer than expected threshold
// Confidence: MEDIUM
// False Positives: Legitimate long-running applications, services, installers
// Threshold: Process runtime > 5 minutes
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where ActionType == "ProcessCreated"
| extend ProcessAge = datetime_diff('minute', now(), TimeGenerated)
| where ProcessAge >= 5  // Process running 5+ minutes
// Exclude known long-running legitimate processes
| where FileName !in~ (
    "svchost.exe", "services.exe", "lsass.exe", "csrss.exe",
    "winlogon.exe", "System", "smss.exe", "MsMpEng.exe",
    "dwm.exe", "explorer.exe", "RuntimeBroker.exe"
)
// Focus on potentially suspicious locations
| where FolderPath !startswith "C:\\Windows\\System32\\"
    or FolderPath has "c:\\F0"
| project TimeGenerated, DeviceName, FileName, FolderPath,
    ProcessCommandLine, AccountName, ProcessAge,
    InitiatingProcessFileName, InitiatingProcessCommandLine
| extend
    Severity = case(
        ProcessAge >= 30, "Medium",
        ProcessAge >= 15, "Low",
        "Informational"
    ),
    ThreatType = "Long-Running Process - Potential Sandbox Evasion",
    MitreAttack = "T1497.001",
    Confidence = "Medium"
| project TimeGenerated, DeviceName, FileName, ProcessAge, Severity,
    ThreatType, MitreAttack, FolderPath, AccountName


// ============================================================================
// QUERY 2: F0RT1KA Framework Directory Activity
// Purpose: Detect file operations in the F0RT1KA working directory
// Confidence: HIGH
// False Positives: Legitimate F0RT1KA security testing
// Threshold: Any file creation in c:\F0
// ============================================================================

DeviceFileEvents
| where TimeGenerated > ago(1h)
| where FolderPath startswith "c:\\F0" or FolderPath startswith "C:\\F0"
| where ActionType in ("FileCreated", "FileModified", "FileRenamed")
| summarize
    FileCount = count(),
    FileNames = make_set(FileName),
    FirstEvent = min(TimeGenerated),
    LastEvent = max(TimeGenerated)
    by DeviceName, InitiatingProcessFileName, InitiatingProcessAccountName
| extend
    Duration = datetime_diff('second', LastEvent, FirstEvent),
    Severity = case(
        FileCount >= 10, "High",
        FileCount >= 5, "Medium",
        "Low"
    ),
    ThreatType = "F0RT1KA Framework Activity",
    MitreAttack = "T1497.001",
    TestID = "12afe0fc-597b-4e79-9cc4-40b4675ee83c"
| project FirstEvent, DeviceName, InitiatingProcessFileName,
    FileCount, FileNames, Duration, Severity, ThreatType, MitreAttack


// ============================================================================
// QUERY 3: Sequential Child Process Execution with Delays
// Purpose: Detect parent processes spawning children with significant gaps
// Confidence: MEDIUM
// False Positives: Build systems, installers, orchestration tools
// Threshold: Multiple child processes with 60+ second gaps
// ============================================================================

let ChildProcesses = DeviceProcessEvents
| where TimeGenerated > ago(2h)
| where ActionType == "ProcessCreated"
| project DeviceName, ParentProcessId = InitiatingProcessId,
    ParentProcessName = InitiatingProcessFileName,
    ChildProcessName = FileName,
    ChildStartTime = TimeGenerated,
    ChildFolderPath = FolderPath;
// Find parent processes with multiple children
ChildProcesses
| summarize
    ChildCount = count(),
    ChildProcesses = make_list(ChildProcessName),
    ChildStartTimes = make_list(ChildStartTime),
    FirstChild = min(ChildStartTime),
    LastChild = max(ChildStartTime)
    by DeviceName, ParentProcessId, ParentProcessName
| where ChildCount >= 2
| extend TotalDuration = datetime_diff('second', LastChild, FirstChild)
| where TotalDuration >= 120  // Children spawned over 2+ minutes
| extend AvgGapSeconds = TotalDuration / (ChildCount - 1)
| where AvgGapSeconds >= 60  // Average 60+ seconds between children
| project TimeGenerated = FirstChild, DeviceName, ParentProcessName,
    ChildCount, ChildProcesses, TotalDuration, AvgGapSeconds
| extend
    Severity = case(
        TotalDuration >= 300, "Medium",
        TotalDuration >= 180, "Low",
        "Informational"
    ),
    ThreatType = "Sequential Staged Execution - Timing Evasion Pattern",
    MitreAttack = "T1497.001",
    Confidence = "Medium"


// ============================================================================
// QUERY 4: Stage Binary Execution Pattern
// Purpose: Detect execution of binaries named with stage/phase patterns
// Confidence: MEDIUM-HIGH
// False Positives: Legitimate staged deployment or testing tools
// Threshold: Binary names containing stage/phase indicators
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where ActionType == "ProcessCreated"
| where FileName matches regex @"(?i)(stage|phase|step)[-_]?\d+"
    or FileName matches regex @"(?i)T\d{4}\.\d{3}"  // MITRE technique patterns
| project TimeGenerated, DeviceName, FileName, FolderPath,
    ProcessCommandLine, AccountName,
    InitiatingProcessFileName, InitiatingProcessFolderPath
| extend
    Severity = case(
        FolderPath has "c:\\F0", "High",
        FolderPath !startswith "C:\\Program Files", "Medium",
        "Low"
    ),
    ThreatType = "Staged Binary Execution Pattern",
    MitreAttack = "T1497.001",
    Confidence = "Medium-High",
    TestID = "12afe0fc-597b-4e79-9cc4-40b4675ee83c"


// ============================================================================
// QUERY 5: Timeout Validation Harness Specific Detection
// Purpose: Detect the specific LimaCharlie Timeout Validation Harness test
// Confidence: HIGH
// False Positives: Only legitimate F0RT1KA testing
// Threshold: Exact file/process patterns
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(24h)
| where ActionType == "ProcessCreated"
| where FileName matches regex @"(?i)12afe0fc[-_]?597b"
    or ProcessCommandLine has "12afe0fc-597b-4e79-9cc4-40b4675ee83c"
    or FileName matches regex @"(?i)stage-T1497\.001-\d\.exe"
| project TimeGenerated, DeviceName, FileName, FolderPath,
    ProcessCommandLine, AccountName,
    InitiatingProcessFileName
| extend
    Severity = "High",
    ThreatType = "F0RT1KA Timeout Validation Harness Execution",
    MitreAttack = "T1497.001",
    TestID = "12afe0fc-597b-4e79-9cc4-40b4675ee83c",
    Confidence = "High"


// ============================================================================
// QUERY 6: Process with Periodic Console Output Pattern
// Purpose: Detect processes generating regular output intervals
// Confidence: LOW-MEDIUM
// False Positives: Legitimate progress reporting applications
// Threshold: Regular console output at 30-second intervals
// ============================================================================

// Note: This query requires Sysmon or detailed console logging
// Placeholder for environments with such telemetry
DeviceEvents
| where TimeGenerated > ago(2h)
| where ActionType has "ProcessOutput" or ActionType has "ConsoleWrite"
| where AdditionalFields has "[STAGE" or AdditionalFields has "Progress:"
| summarize
    OutputCount = count(),
    OutputSamples = make_set(AdditionalFields, 5),
    FirstOutput = min(TimeGenerated),
    LastOutput = max(TimeGenerated)
    by DeviceName, InitiatingProcessFileName
| where OutputCount >= 4
| extend Duration = datetime_diff('second', LastOutput, FirstOutput)
| extend AvgInterval = Duration / OutputCount
| where AvgInterval between (25 .. 35)  // ~30 second intervals
| project TimeGenerated = FirstOutput, DeviceName, InitiatingProcessFileName,
    OutputCount, Duration, AvgInterval
| extend
    Severity = "Low",
    ThreatType = "Periodic Progress Output - Potential Timing Evasion",
    MitreAttack = "T1497.001"


// ============================================================================
// QUERY 7: Go Binary Execution from Non-Standard Location
// Purpose: Detect Go-compiled binaries from suspicious paths
// Confidence: MEDIUM
// False Positives: Legitimate Go applications, DevOps tools
// Threshold: Go binary from temp/download/F0 locations
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(1h)
| where ActionType == "ProcessCreated"
// Go binary indicators in process metadata
| where ProcessVersionInfoFileDescription has "Go"
    or ProcessVersionInfoProductName has "Go"
    or InitiatingProcessFileName has "go"
// From suspicious locations
| where FolderPath has_any ("\\Temp\\", "\\Downloads\\", "\\F0\\", "\\AppData\\")
| project TimeGenerated, DeviceName, FileName, FolderPath,
    ProcessCommandLine, AccountName,
    ProcessVersionInfoFileDescription, ProcessVersionInfoProductName
| extend
    Severity = case(
        FolderPath has "\\F0\\", "High",
        FolderPath has "\\Temp\\", "Medium",
        "Low"
    ),
    ThreatType = "Go Binary from Non-Standard Location",
    MitreAttack = "T1497.001"


// ============================================================================
// QUERY 8: Process Exit Code 101 Detection
// Purpose: Detect processes exiting with F0RT1KA exit code 101
// Confidence: HIGH (for F0RT1KA framework)
// False Positives: Other applications using exit code 101
// ============================================================================

DeviceProcessEvents
| where TimeGenerated > ago(2h)
| where ActionType == "ProcessExited" or ActionType has "Exit"
// Note: Exit code availability varies by telemetry source
| where AdditionalFields has "101" or ProcessExitCode == 101
| where FolderPath has "F0" or FolderPath has "f0"
| project TimeGenerated, DeviceName, FileName, FolderPath,
    ProcessExitCode, ProcessDuration = AdditionalFields
| extend
    Severity = "Medium",
    ThreatType = "F0RT1KA Test Exit Code (101 - Unprotected)",
    MitreAttack = "T1497.001",
    Confidence = "High"


// ============================================================================
// QUERY 9: Combined Behavioral Detection
// Purpose: Correlate multiple indicators for high-confidence detection
// Confidence: HIGH
// False Positives: Very rare (requires multiple correlated indicators)
// Threshold: 2+ indicators within 10-minute window
// ============================================================================

let F0Activity = DeviceFileEvents
| where TimeGenerated > ago(2h)
| where FolderPath startswith "c:\\F0" or FolderPath startswith "C:\\F0"
| summarize F0FileCount = count() by DeviceName, bin(TimeGenerated, 10m);
let LongProcesses = DeviceProcessEvents
| where TimeGenerated > ago(2h)
| where FolderPath has "F0"
| extend ProcessAge = datetime_diff('minute', now(), TimeGenerated)
| where ProcessAge >= 5
| summarize LongProcessCount = count() by DeviceName, bin(TimeGenerated, 10m);
let StageExecutions = DeviceProcessEvents
| where TimeGenerated > ago(2h)
| where FileName matches regex @"(?i)stage[-_]"
| summarize StageCount = count() by DeviceName, bin(TimeGenerated, 10m);
// Correlate all indicators
F0Activity
| join kind=leftouter (LongProcesses) on DeviceName, TimeGenerated
| join kind=leftouter (StageExecutions) on DeviceName, TimeGenerated
| extend IndicatorCount = (
    iff(F0FileCount > 0, 1, 0) +
    iff(isnotnull(LongProcessCount), 1, 0) +
    iff(isnotnull(StageCount), 1, 0)
)
| where IndicatorCount >= 2
| project TimeGenerated, DeviceName, F0FileCount, LongProcessCount, StageCount,
    IndicatorCount
| extend
    Severity = "High",
    ThreatType = "Multi-Indicator Timeout/Sandbox Evasion Pattern",
    MitreAttack = "T1497.001",
    Confidence = "High"


// ============================================================================
// ALERT SUMMARY DASHBOARD QUERY
// Purpose: Aggregate all detections for SOC dashboard
// ============================================================================

let TimeoutRelatedEvents = union
    // F0 Directory Activity
    (DeviceFileEvents
    | where TimeGenerated > ago(24h)
    | where FolderPath startswith "c:\\F0" or FolderPath startswith "C:\\F0"
    | summarize EventCount = count() by Computer = DeviceName, bin(TimeGenerated, 1h)
    | extend DetectionType = "F0 Directory Activity"
    ),
    // Stage Binary Execution
    (DeviceProcessEvents
    | where TimeGenerated > ago(24h)
    | where FileName matches regex @"(?i)stage[-_]"
    | summarize EventCount = count() by Computer = DeviceName, bin(TimeGenerated, 1h)
    | extend DetectionType = "Stage Binary Execution"
    ),
    // Timeout Harness Specific
    (DeviceProcessEvents
    | where TimeGenerated > ago(24h)
    | where FileName has "12afe0fc" or ProcessCommandLine has "T1497.001"
    | summarize EventCount = count() by Computer = DeviceName, bin(TimeGenerated, 1h)
    | extend DetectionType = "Timeout Harness Execution"
    );
TimeoutRelatedEvents
| summarize TotalEvents = sum(EventCount), DetectionTypes = make_set(DetectionType)
    by Computer, bin(TimeGenerated, 1h)
| order by TotalEvents desc
| project TimeGenerated, Computer, TotalEvents, DetectionTypes,
    Severity = case(
        TotalEvents >= 10, "High",
        TotalEvents >= 5, "Medium",
        "Low"
    ),
    ThreatType = "Timeout/Sandbox Evasion Activity",
    MitreAttack = "T1497.001"
