{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://f0rt1ka.io/schemas/test-results/v2.0.json",
  "title": "F0RT1KA Security Test Results Schema",
  "description": "Standardized schema for F0RT1KA security test execution results, optimized for analytics and time-series analysis",
  "version": "2.0.0",
  "type": "object",
  "required": [
    "schemaVersion",
    "testId",
    "testName",
    "testMetadata",
    "executionContext",
    "startTime",
    "endTime",
    "durationMs",
    "exitCode",
    "exitReason",
    "outcome",
    "systemInfo",
    "phases",
    "messages",
    "filesDropped",
    "processesExecuted"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Schema version for backward compatibility tracking",
      "pattern": "^\\d+\\.\\d+$",
      "examples": ["2.0", "2.1"]
    },
    "testId": {
      "type": "string",
      "description": "Unique test identifier (UUID v4, lowercase)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "examples": ["b6c73735-0c24-4a1e-8f0a-3c24af39671b"]
    },
    "testName": {
      "type": "string",
      "description": "Human-readable test name",
      "minLength": 1,
      "maxLength": 256,
      "examples": ["MDE Network Protection Bypass Test"]
    },
    "testMetadata": {
      "type": "object",
      "description": "Test classification and attribution metadata for analytics",
      "required": ["version", "category", "severity", "techniques", "tactics"],
      "properties": {
        "version": {
          "type": "string",
          "description": "Test implementation version (semantic versioning)",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "examples": ["1.0.0", "1.2.3"]
        },
        "category": {
          "type": "string",
          "description": "Test category for filtering/grouping",
          "enum": [
            "ransomware",
            "data_exfiltration",
            "privilege_escalation",
            "defense_evasion",
            "persistence",
            "credential_access",
            "lateral_movement",
            "command_and_control",
            "impact",
            "initial_access",
            "execution",
            "discovery",
            "collection"
          ]
        },
        "severity": {
          "type": "string",
          "description": "Threat severity level",
          "enum": ["critical", "high", "medium", "low", "informational"]
        },
        "techniques": {
          "type": "array",
          "description": "MITRE ATT&CK technique IDs",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^T\\d{4}(\\.\\d{3})?$",
            "examples": ["T1055.001", "T1134.001", "T1003.001"]
          }
        },
        "tactics": {
          "type": "array",
          "description": "MITRE ATT&CK tactic names",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "reconnaissance",
              "resource-development",
              "initial-access",
              "execution",
              "persistence",
              "privilege-escalation",
              "defense-evasion",
              "credential-access",
              "discovery",
              "lateral-movement",
              "collection",
              "command-and-control",
              "exfiltration",
              "impact"
            ]
          }
        },
        "score": {
          "type": "number",
          "description": "Test quality score (0-10 scale)",
          "minimum": 0,
          "maximum": 10,
          "examples": [8.5, 7.0, 9.5]
        },
        "scoreBreakdown": {
          "type": "object",
          "description": "Detailed scoring breakdown",
          "properties": {
            "realWorldAccuracy": {
              "type": "number",
              "minimum": 0,
              "maximum": 3,
              "description": "Real-world accuracy score (0-3)"
            },
            "technicalSophistication": {
              "type": "number",
              "minimum": 0,
              "maximum": 3,
              "description": "Technical sophistication score (0-3)"
            },
            "safetyMechanisms": {
              "type": "number",
              "minimum": 0,
              "maximum": 2,
              "description": "Safety mechanisms score (0-2)"
            },
            "detectionOpportunities": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Detection opportunities score (0-1)"
            },
            "loggingObservability": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Logging and observability score (0-1)"
            }
          }
        },
        "tags": {
          "type": "array",
          "description": "Additional classification tags",
          "items": {
            "type": "string"
          },
          "examples": [["multi-stage", "memory-manipulation", "api-abuse"]]
        }
      }
    },
    "executionContext": {
      "type": "object",
      "description": "Execution environment and batch context for correlation",
      "required": ["executionId", "organization", "environment"],
      "properties": {
        "executionId": {
          "type": "string",
          "description": "Unique execution run identifier (UUID) - groups tests run together",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "batchId": {
          "type": "string",
          "description": "Optional batch identifier for test suite runs",
          "examples": ["weekly-scan-2024-11-14", "pre-deployment-validation"]
        },
        "organization": {
          "type": "string",
          "description": "Organization identifier (sb, tpsgl, rga, etc.)",
          "examples": ["sb", "tpsgl", "rga"]
        },
        "environment": {
          "type": "string",
          "description": "Deployment environment type",
          "enum": ["production", "staging", "lab", "development", "testing"]
        },
        "deploymentType": {
          "type": "string",
          "description": "How test was deployed/executed",
          "enum": ["manual", "automated", "cicd", "scheduled", "on-demand"]
        },
        "triggeredBy": {
          "type": "string",
          "description": "Who/what initiated the test execution",
          "examples": ["jim@example.com", "jenkins-pipeline", "scheduled-task"]
        },
        "configuration": {
          "type": "object",
          "description": "Test execution configuration",
          "properties": {
            "timeoutMs": {
              "type": "integer",
              "description": "Configured timeout in milliseconds",
              "minimum": 0
            },
            "certificateMode": {
              "type": "string",
              "enum": ["self-healing", "pre-installed", "embedded"],
              "description": "Certificate installation approach used"
            },
            "multiStageEnabled": {
              "type": "boolean",
              "description": "Whether multi-stage architecture was used"
            }
          }
        }
      }
    },
    "startTime": {
      "type": "string",
      "format": "date-time",
      "description": "Test start timestamp (ISO 8601 UTC)",
      "examples": ["2024-11-14T15:30:45.123Z"]
    },
    "endTime": {
      "type": "string",
      "format": "date-time",
      "description": "Test end timestamp (ISO 8601 UTC)",
      "examples": ["2024-11-14T15:32:18.456Z"]
    },
    "durationMs": {
      "type": "integer",
      "description": "Total execution duration in milliseconds",
      "minimum": 0,
      "examples": [93333]
    },
    "exitCode": {
      "type": "integer",
      "description": "Test exit code indicating outcome",
      "enum": [101, 105, 126, 127, 102, 999, 1],
      "examples": [101, 126]
    },
    "exitReason": {
      "type": "string",
      "description": "Human-readable exit reason",
      "minLength": 1,
      "maxLength": 512,
      "examples": [
        "System is unprotected - attack succeeded",
        "Attack execution prevented by security controls",
        "File quarantined before execution"
      ]
    },
    "outcome": {
      "type": "object",
      "description": "Computed outcome metrics for analytics",
      "required": ["protected", "category", "detectionPhase"],
      "properties": {
        "protected": {
          "type": "boolean",
          "description": "Whether endpoint was protected (exitCode in [105,126,127])"
        },
        "category": {
          "type": "string",
          "description": "Outcome categorization",
          "enum": [
            "quarantined_on_extraction",
            "execution_prevented",
            "quarantined_on_execution",
            "unprotected",
            "timeout",
            "test_error",
            "unknown"
          ]
        },
        "detectionPhase": {
          "type": ["string", "null"],
          "description": "Phase where detection occurred (null if unprotected)",
          "enum": ["file_drop", "pre_execution", "during_execution", "post_execution", null]
        },
        "blockedTechniques": {
          "type": "array",
          "description": "Which ATT&CK techniques were blocked (multi-stage only)",
          "items": {
            "type": "string",
            "pattern": "^T\\d{4}(\\.\\d{3})?$"
          }
        },
        "successfulTechniques": {
          "type": "array",
          "description": "Which ATT&CK techniques succeeded (multi-stage only)",
          "items": {
            "type": "string",
            "pattern": "^T\\d{4}(\\.\\d{3})?$"
          }
        }
      }
    },
    "isMultiStage": {
      "type": "boolean",
      "description": "Whether this is a multi-stage test with killchain",
      "default": false
    },
    "stages": {
      "type": "array",
      "description": "Stage execution details (multi-stage tests only)",
      "items": {
        "type": "object",
        "required": ["stageId", "technique", "name", "startTime", "endTime", "durationMs", "status", "exitCode"],
        "properties": {
          "stageId": {
            "type": "integer",
            "description": "Stage number in killchain sequence",
            "minimum": 1
          },
          "technique": {
            "type": "string",
            "description": "MITRE ATT&CK technique ID for this stage",
            "pattern": "^T\\d{4}(\\.\\d{3})?$"
          },
          "name": {
            "type": "string",
            "description": "Stage descriptive name",
            "examples": ["Access Token Manipulation", "Process Injection"]
          },
          "startTime": {
            "type": "string",
            "format": "date-time",
            "description": "Stage start timestamp (ISO 8601 UTC)"
          },
          "endTime": {
            "type": "string",
            "format": "date-time",
            "description": "Stage end timestamp (ISO 8601 UTC)"
          },
          "durationMs": {
            "type": "integer",
            "description": "Stage duration in milliseconds",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "description": "Stage execution status",
            "enum": ["success", "blocked", "error", "skipped"]
          },
          "exitCode": {
            "type": "integer",
            "description": "Stage-specific exit code"
          },
          "blockedBy": {
            "type": "string",
            "description": "What blocked this stage (if status=blocked)"
          },
          "errorMessage": {
            "type": "string",
            "description": "Error details (if status=error)"
          }
        }
      }
    },
    "blockedAtStage": {
      "type": "integer",
      "description": "Stage number where execution was blocked (multi-stage only)",
      "minimum": 1
    },
    "blockedTechnique": {
      "type": "string",
      "description": "MITRE ATT&CK technique that was blocked (multi-stage only)",
      "pattern": "^T\\d{4}(\\.\\d{3})?$"
    },
    "systemInfo": {
      "type": "object",
      "description": "Target system information",
      "required": ["hostname", "osVersion", "architecture", "defenderRunning", "mdeInstalled", "processId", "username", "isAdmin"],
      "properties": {
        "hostname": {
          "type": "string",
          "description": "System hostname",
          "minLength": 1
        },
        "osVersion": {
          "type": "string",
          "description": "Operating system version",
          "examples": ["Microsoft Windows [Version 10.0.19045.3803]"]
        },
        "architecture": {
          "type": "string",
          "description": "Processor architecture",
          "enum": ["AMD64", "x86", "ARM64"]
        },
        "defenderRunning": {
          "type": "boolean",
          "description": "Whether Windows Defender service is running"
        },
        "mdeInstalled": {
          "type": "boolean",
          "description": "Whether Microsoft Defender for Endpoint is installed"
        },
        "mdeVersion": {
          "type": "string",
          "description": "MDE version if installed"
        },
        "processId": {
          "type": "integer",
          "description": "Test process ID"
        },
        "username": {
          "type": "string",
          "description": "User account running the test"
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether running with administrator privileges"
        },
        "edrProducts": {
          "type": "array",
          "description": "Detected EDR/AV products on system",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "running": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "phases": {
      "type": "array",
      "description": "Test execution phases (sequential steps)",
      "items": {
        "type": "object",
        "required": ["phaseNumber", "phaseName", "startTime", "endTime", "durationMs", "status"],
        "properties": {
          "phaseNumber": {
            "type": "integer",
            "description": "Phase sequence number",
            "minimum": 0
          },
          "phaseName": {
            "type": "string",
            "description": "Phase descriptive name",
            "examples": ["Initialization", "File Drop Operations", "Attack Execution"]
          },
          "startTime": {
            "type": "string",
            "format": "date-time",
            "description": "Phase start timestamp (ISO 8601 UTC)"
          },
          "endTime": {
            "type": "string",
            "format": "date-time",
            "description": "Phase end timestamp (ISO 8601 UTC)"
          },
          "durationMs": {
            "type": "integer",
            "description": "Phase duration in milliseconds",
            "minimum": 0
          },
          "status": {
            "type": "string",
            "description": "Phase completion status",
            "enum": ["success", "failed", "blocked", "skipped", "in_progress"]
          },
          "details": {
            "type": "string",
            "description": "Additional phase details"
          },
          "errors": {
            "type": "array",
            "description": "Errors encountered during phase",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "messages": {
      "type": "array",
      "description": "Detailed message log entries",
      "items": {
        "type": "object",
        "required": ["timestamp", "level", "phase", "message"],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Message timestamp (ISO 8601 UTC)"
          },
          "level": {
            "type": "string",
            "description": "Log level",
            "enum": ["INFO", "WARN", "ERROR", "CRITICAL", "SUCCESS", "DEBUG"]
          },
          "phase": {
            "type": "string",
            "description": "Which phase generated this message"
          },
          "message": {
            "type": "string",
            "description": "Log message content",
            "minLength": 1
          }
        }
      }
    },
    "filesDropped": {
      "type": "array",
      "description": "Files created/dropped during test execution",
      "items": {
        "type": "object",
        "required": ["filename", "path", "size", "quarantined", "timestamp"],
        "properties": {
          "filename": {
            "type": "string",
            "description": "File name",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "description": "Full file path",
            "minLength": 1
          },
          "size": {
            "type": "integer",
            "description": "File size in bytes",
            "minimum": 0
          },
          "quarantined": {
            "type": "boolean",
            "description": "Whether file was quarantined by EDR/AV"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "File drop timestamp (ISO 8601 UTC)"
          },
          "sha256": {
            "type": "string",
            "description": "SHA-256 hash of file (optional)",
            "pattern": "^[a-f0-9]{64}$"
          },
          "fileType": {
            "type": "string",
            "description": "File type/extension",
            "examples": ["exe", "dll", "ps1", "bat"]
          }
        }
      }
    },
    "processesExecuted": {
      "type": "array",
      "description": "Processes executed during test",
      "items": {
        "type": "object",
        "required": ["processName", "success", "timestamp"],
        "properties": {
          "processName": {
            "type": "string",
            "description": "Process executable name",
            "minLength": 1
          },
          "commandLine": {
            "type": "string",
            "description": "Full command line"
          },
          "pid": {
            "type": "integer",
            "description": "Process ID",
            "minimum": 0
          },
          "success": {
            "type": "boolean",
            "description": "Whether process launched successfully"
          },
          "exitCode": {
            "type": "integer",
            "description": "Process exit code"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Process start timestamp (ISO 8601 UTC)"
          },
          "errorMsg": {
            "type": "string",
            "description": "Error message if launch failed"
          },
          "parentPid": {
            "type": "integer",
            "description": "Parent process ID (optional)"
          }
        }
      }
    },
    "certBypass": {
      "type": "object",
      "description": "Certificate bypass attempt details (test-specific)",
      "properties": {
        "mode": {
          "type": "string",
          "description": "Bypass mode used"
        },
        "attempted": {
          "type": "boolean",
          "description": "Whether bypass was attempted"
        },
        "success": {
          "type": "boolean",
          "description": "Whether bypass succeeded"
        },
        "blocked": {
          "type": "boolean",
          "description": "Whether bypass was blocked"
        },
        "blockedBy": {
          "type": "string",
          "description": "What blocked the bypass attempt"
        },
        "watchdogActive": {
          "type": "boolean",
          "description": "Whether watchdog process was active"
        },
        "restoreSuccess": {
          "type": "boolean",
          "description": "Whether system state was restored"
        },
        "durationMs": {
          "type": "integer",
          "description": "Bypass attempt duration in milliseconds"
        },
        "patchAddress": {
          "type": "string",
          "description": "Memory address that was patched"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Bypass attempt timestamp"
        }
      }
    },
    "networkTest": {
      "type": "object",
      "description": "Network testing details (test-specific)",
      "properties": {
        "totalEndpoints": {
          "type": "integer",
          "description": "Total endpoints tested",
          "minimum": 0
        },
        "successfulTests": {
          "type": "integer",
          "description": "Number of successful connection tests",
          "minimum": 0
        },
        "failedTests": {
          "type": "integer",
          "description": "Number of failed connection tests",
          "minimum": 0
        },
        "vulnerableCount": {
          "type": "integer",
          "description": "Number of vulnerable endpoints found",
          "minimum": 0
        },
        "protectedCount": {
          "type": "integer",
          "description": "Number of protected endpoints found",
          "minimum": 0
        },
        "overallVulnerable": {
          "type": "boolean",
          "description": "Whether system is overall vulnerable"
        },
        "results": {
          "type": "array",
          "description": "Individual endpoint test results",
          "items": {
            "type": "object",
            "properties": {
              "endpoint": {
                "type": "string"
              },
              "blocked": {
                "type": "boolean"
              },
              "latencyMs": {
                "type": "integer"
              }
            }
          }
        }
      }
    },
    "identifierExtraction": {
      "type": "object",
      "description": "MDE identifier extraction details (test-specific)",
      "properties": {
        "method": {
          "type": "string",
          "description": "Extraction method used",
          "enum": ["registry", "config", "wmi", "api", "simulated"]
        },
        "mdeInstalled": {
          "type": "boolean",
          "description": "Whether MDE is installed"
        },
        "success": {
          "type": "boolean",
          "description": "Whether extraction succeeded"
        },
        "machineId": {
          "type": "string",
          "description": "Extracted machine ID"
        },
        "tenantId": {
          "type": "string",
          "description": "Extracted tenant ID",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        },
        "senseId": {
          "type": "string",
          "description": "Extracted SENSE ID"
        },
        "orgId": {
          "type": "string",
          "description": "Extracted organization ID"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Extraction timestamp"
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Computed metrics for dashboard aggregation",
      "properties": {
        "totalPhases": {
          "type": "integer",
          "description": "Total number of phases executed",
          "minimum": 0
        },
        "successfulPhases": {
          "type": "integer",
          "description": "Number of successful phases",
          "minimum": 0
        },
        "failedPhases": {
          "type": "integer",
          "description": "Number of failed phases",
          "minimum": 0
        },
        "totalFilesDropped": {
          "type": "integer",
          "description": "Total files dropped",
          "minimum": 0
        },
        "filesQuarantined": {
          "type": "integer",
          "description": "Files quarantined by EDR",
          "minimum": 0
        },
        "totalProcesses": {
          "type": "integer",
          "description": "Total processes executed",
          "minimum": 0
        },
        "successfulProcesses": {
          "type": "integer",
          "description": "Successfully launched processes",
          "minimum": 0
        },
        "totalLogMessages": {
          "type": "integer",
          "description": "Total log messages generated",
          "minimum": 0
        },
        "errorCount": {
          "type": "integer",
          "description": "Number of error-level messages",
          "minimum": 0
        },
        "criticalCount": {
          "type": "integer",
          "description": "Number of critical-level messages",
          "minimum": 0
        }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "Test artifacts and related resources",
      "properties": {
        "logFilePath": {
          "type": "string",
          "description": "Path to text log file"
        },
        "jsonFilePath": {
          "type": "string",
          "description": "Path to JSON log file"
        },
        "screenshotPaths": {
          "type": "array",
          "description": "Paths to screenshots captured",
          "items": {
            "type": "string"
          }
        },
        "packetCapturePath": {
          "type": "string",
          "description": "Path to network packet capture file"
        }
      }
    }
  }
}
