#!/bin/bash
# Wrapper script for F0RT1KA test results validation

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/validate_test_results.py"

# Check if Python script exists
if [ ! -f "$PYTHON_SCRIPT" ]; then
    echo "ERROR: Validation script not found: $PYTHON_SCRIPT"
    exit 2
fi

# Check if jsonschema is installed
if ! python3 -c "import jsonschema" 2>/dev/null; then
    echo "ERROR: jsonschema module not found"
    echo "Install with: pip install jsonschema"
    exit 2
fi

# Run validation script with all arguments
python3 "$PYTHON_SCRIPT" "$@"
