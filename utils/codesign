#!/bin/bash

# F0RT1KA Code Signing Utility
# Uses osslsigncode to sign Windows executables with certificates

set -e
set +H  # Disable history expansion to handle passwords with special characters like !

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Print colored output
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Show usage information
show_usage() {
    cat << EOF
F0RT1KA Code Signing Utility

USAGE:
    $(basename "$0") [OPTIONS] [COMMAND]

COMMANDS:
    sign <file(s)>          Sign one or more files (supports glob patterns)
    sign-nested <file> <cert1> <cert2>  Dual-sign a file (sign with cert1, nest cert2)
    sign-all [directory]    Sign all executables in directory (default: build/)
    verify <binary>         Verify signature of a binary
    list-certs              List available certificates in signing-certs/

OPTIONS:
    --cert <file>           Certificate file (required for signing)
    --password <pass>       Certificate password (will prompt if not provided)
    --timestamp-url <url>   Timestamp server URL (optional)
    --description <desc>    Description for signature (optional)
    --url <url>             URL for signature (optional)
    --output <file>         Output file (default: overwrites input)
    --verbose               Enable verbose output
    --help                  Show this help message

EXAMPLES:
    # Sign a binary (will prompt for certificate and password)
    $(basename "$0") sign build/test-uuid/test-uuid.exe

    # Sign multiple PowerShell scripts with glob pattern
    $(basename "$0") --cert signing-certs/mycert.pfx --password 'mypass' sign staging/uuid/*.ps1

    # Sign multiple files explicitly
    $(basename "$0") --cert signing-certs/mycert.pfx sign file1.exe file2.ps1 file3.exe

    # Sign all binaries in build directory
    $(basename "$0") sign-all

    # Dual-sign with org cert + F0RT1KA cert (for ASR compatibility + self-healing)
    $(basename "$0") sign-nested build/test-uuid/test-uuid.exe signing-certs/sb_cert.pfx signing-certs/F0RT1KA.pfx

    # Sign with description and URL
    $(basename "$0") --cert signing-certs/mycert.pfx \\
        --description "F0RT1KA Security Test" \\
        --url "https://github.com/ubercylon8/f0_library" \\
        sign build/test-uuid/test-uuid.exe

    # Verify a signature
    $(basename "$0") verify build/test-uuid/test-uuid.exe

NOTES:
    - Requires osslsigncode to be installed
    - Certificates should be in PFX/P12 format
    - Default certificate directory: signing-certs/
    - Timestamping is recommended for production binaries
EOF
}

# Check if osslsigncode is installed
check_osslsigncode() {
    if ! command -v osslsigncode &> /dev/null; then
        print_error "osslsigncode is not installed or not in PATH"
        print_info "Install with: brew install osslsigncode (macOS) or apt-get install osslsigncode (Linux)"
        exit 1
    fi
}

# List available certificates
list_certificates() {
    # Get the directory where this script is located
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local cert_dir="$script_dir/../signing-certs"
    
    print_info "Available certificates in signing-certs/:"
    
    if [[ ! -d "$cert_dir" ]]; then
        print_warning "Certificate directory not found: $cert_dir"
        return 1
    fi
    
    local count=0
    for cert_file in "$cert_dir"/*.{pfx,p12}; do
        if [[ -f "$cert_file" ]]; then
            echo "  • $(basename "$cert_file")"
            ((count++))
        fi
    done
    
    if [[ $count -eq 0 ]]; then
        print_warning "No certificate files found in $cert_dir/"
        print_info "Expected formats: .pfx, .p12"
    else
        print_info "Total: $count certificates"
    fi
}

# Prompt for certificate selection
select_certificate() {
    # Get the directory where this script is located
    local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local cert_dir="$script_dir/../signing-certs"
    local selected_cert=""

    if [[ ! -d "$cert_dir" ]]; then
        print_error "Certificate directory not found: $cert_dir"
        return 1
    fi

    # Check for F0RT1KA certificate (default/recommended)
    local f0rt1ka_cert="$cert_dir/F0RT1KA.pfx"
    if [[ -f "$f0rt1ka_cert" ]]; then
        selected_cert="$f0rt1ka_cert"
        print_info "Using F0RT1KA certificate (default): $(basename "$selected_cert")"
        echo "$selected_cert"
        return 0
    fi

    # Build array of certificates (fallback if F0RT1KA not found)
    local certs=()
    for cert_file in "$cert_dir"/*.{pfx,p12}; do
        if [[ -f "$cert_file" ]]; then
            certs+=("$cert_file")
        fi
    done

    if [[ ${#certs[@]} -eq 0 ]]; then
        print_error "No certificates found in $cert_dir/"
        print_warning "Expected F0RT1KA.pfx for self-healing tests"
        return 1
    elif [[ ${#certs[@]} -eq 1 ]]; then
        selected_cert="${certs[0]}"
        print_info "Using certificate: $(basename "$selected_cert")"
    else
        echo "Available certificates:" >&2
        for i in "${!certs[@]}"; do
            echo "  $((i+1)). $(basename "${certs[i]}")" >&2
        done

        while true; do
            read -p "Select certificate (1-${#certs[@]}): " choice
            if [[ "$choice" =~ ^[0-9]+$ ]] && [[ $choice -ge 1 ]] && [[ $choice -le ${#certs[@]} ]]; then
                selected_cert="${certs[$((choice-1))]}"
                break
            else
                print_warning "Invalid selection. Please enter a number between 1 and ${#certs[@]}"
            fi
        done
    fi

    echo "$selected_cert"
}

# Prompt for password securely (or auto-read from password file)
prompt_password() {
    local cert_file="$1"
    local password=""

    # Check if there's a password file for this certificate
    local password_file="${cert_file}.txt"
    local password_file_hidden=".$(basename "$cert_file").txt"
    local password_file_hidden_path="$(dirname "$cert_file")/$password_file_hidden"

    # Try to read password from file (hidden file first, then regular)
    if [[ -f "$password_file_hidden_path" ]]; then
        password=$(cat "$password_file_hidden_path" 2>/dev/null | tr -d '\n\r')
        if [[ -n "$password" ]]; then
            print_info "Using password from file: $password_file_hidden" >&2
            echo "$password"
            return 0
        fi
    elif [[ -f "$password_file" ]]; then
        password=$(cat "$password_file" 2>/dev/null | tr -d '\n\r')
        if [[ -n "$password" ]]; then
            print_info "Using password from file: $(basename "$password_file")" >&2
            echo "$password"
            return 0
        fi
    fi

    # No password file found - prompt user (only if interactive)
    if [[ ! -t 0 ]]; then
        print_error "No password file found for $(basename "$cert_file") and stdin is not a terminal" >&2
        return 1
    fi
    while [[ -z "$password" ]]; do
        read -s -p "Enter certificate password: " password
        echo
        if [[ -z "$password" ]]; then
            print_warning "Password cannot be empty"
        fi
    done

    echo "$password"
}

# Sign a binary
sign_binary() {
    local binary_path="$1"
    local cert_file="$2"
    local password="$3"
    local output_file="$4"
    local description="$5"
    local url="$6"
    local timestamp_url="$7"
    local verbose="$8"
    
    if [[ ! -f "$binary_path" ]]; then
        print_error "Binary not found: $binary_path"
        return 1
    fi
    
    if [[ ! -f "$cert_file" ]]; then
        print_error "Certificate not found: $cert_file"
        return 1
    fi
    
    # Use input file as output if not specified
    local use_temp=false
    local temp_output=""
    if [[ -z "$output_file" ]]; then
        output_file="$binary_path"
        # If overwriting input file, use a temporary file
        if [[ "$output_file" == "$binary_path" ]]; then
            use_temp=true
            temp_output="${binary_path}.tmp"
        fi
    fi
    
    print_info "Signing binary: $(basename "$binary_path")"
    print_info "Certificate: $(basename "$cert_file")"
    print_info "Output: $(basename "$output_file")"
    
    # Build osslsigncode command
    local actual_output="$output_file"
    if [[ "$use_temp" == "true" ]]; then
        actual_output="$temp_output"
    fi
    
    local sign_cmd=(
        "osslsigncode"
        "sign"
        "-pkcs12" "$cert_file"
        "-pass" "$password"
        "-in" "$binary_path"
        "-out" "$actual_output"
    )
    
    # Add optional parameters
    if [[ -n "$description" ]]; then
        sign_cmd+=("-n" "$description")
    fi
    
    if [[ -n "$url" ]]; then
        sign_cmd+=("-i" "$url")
    fi
    
    if [[ -n "$timestamp_url" ]]; then
        sign_cmd+=("-t" "$timestamp_url")
    fi
    
    if [[ "$verbose" == "true" ]]; then
        print_info "Command: ${sign_cmd[*]}"
    fi
    
    # Execute signing
    local error_output
    if error_output=$("${sign_cmd[@]}" 2>&1); then
        # If we used a temp file, move it to the final location
        if [[ "$use_temp" == "true" ]]; then
            if mv -f "$temp_output" "$output_file"; then
                print_success "Successfully signed: $(basename "$output_file")"
            else
                print_error "Failed to move signed file to final location"
                rm -f "$temp_output"
                return 1
            fi
        else
            print_success "Successfully signed: $(basename "$output_file")"
        fi
        
        # Show file info
        if [[ -f "$output_file" ]]; then
            local size=$(ls -lh "$output_file" | awk '{print $5}')
            print_info "Signed binary size: $size"
        fi
        
        return 0
    else
        print_error "Failed to sign: $(basename "$binary_path")"
        if [[ -n "$error_output" ]]; then
            print_error "Error details: $error_output"
        fi
        # Clean up temp file if it exists
        if [[ "$use_temp" == "true" ]] && [[ -f "$temp_output" ]]; then
            rm -f "$temp_output"
        fi
        return 1
    fi
}

# Dual-sign a binary (sign with primary cert, then nest secondary cert)
# This creates a binary that is trusted by endpoints with EITHER certificate
sign_binary_nested() {
    local binary_path="$1"
    local primary_cert="$2"
    local primary_password="$3"
    local secondary_cert="$4"
    local secondary_password="$5"
    local description="$6"
    local url="$7"
    local timestamp_url="$8"
    local verbose="$9"

    if [[ ! -f "$binary_path" ]]; then
        print_error "Binary not found: $binary_path"
        return 1
    fi

    if [[ ! -f "$primary_cert" ]]; then
        print_error "Primary certificate not found: $primary_cert"
        return 1
    fi

    if [[ ! -f "$secondary_cert" ]]; then
        print_error "Secondary certificate not found: $secondary_cert"
        return 1
    fi

    print_info "Dual-signing binary: $(basename "$binary_path")"
    print_info "  Primary cert: $(basename "$primary_cert")"
    print_info "  Secondary cert: $(basename "$secondary_cert")"

    # Step 1: Sign with primary certificate
    local temp_signed="${binary_path}.primary-signed.tmp"

    local primary_cmd=(
        "osslsigncode"
        "sign"
        "-pkcs12" "$primary_cert"
        "-pass" "$primary_password"
        "-in" "$binary_path"
        "-out" "$temp_signed"
    )

    # Add optional parameters for primary signature
    if [[ -n "$description" ]]; then
        primary_cmd+=("-n" "$description")
    fi

    if [[ -n "$url" ]]; then
        primary_cmd+=("-i" "$url")
    fi

    if [[ -n "$timestamp_url" ]]; then
        primary_cmd+=("-t" "$timestamp_url")
    fi

    if [[ "$verbose" == "true" ]]; then
        print_info "Primary sign command: ${primary_cmd[*]}"
    fi

    print_info "[1/2] Signing with primary certificate..."
    if [[ "$verbose" == "true" ]]; then
        print_info "DEBUG: Primary password length: ${#primary_password}"
    fi
    local error_output
    if ! error_output=$("${primary_cmd[@]}" 2>&1); then
        print_error "Primary signature failed: $error_output"
        rm -f "$temp_signed"
        return 1
    fi

    print_success "Primary signature applied"

    # Step 2: Nest secondary certificate
    local temp_dual="${binary_path}.dual-signed.tmp"

    local secondary_cmd=(
        "osslsigncode"
        "sign"
        "-nest"
        "-pkcs12" "$secondary_cert"
        "-pass" "$secondary_password"
        "-in" "$temp_signed"
        "-out" "$temp_dual"
    )

    # Add optional parameters for secondary signature (same as primary)
    if [[ -n "$description" ]]; then
        secondary_cmd+=("-n" "$description")
    fi

    if [[ -n "$url" ]]; then
        secondary_cmd+=("-i" "$url")
    fi

    if [[ -n "$timestamp_url" ]]; then
        secondary_cmd+=("-t" "$timestamp_url")
    fi

    if [[ "$verbose" == "true" ]]; then
        print_info "Secondary sign command: ${secondary_cmd[*]}"
    fi

    print_info "[2/2] Nesting secondary certificate..."
    if ! error_output=$("${secondary_cmd[@]}" 2>&1); then
        print_error "Secondary signature (nested) failed: $error_output"
        rm -f "$temp_signed" "$temp_dual"
        return 1
    fi

    print_success "Secondary signature nested"

    # Step 3: Move dual-signed binary to final location (overwrite original)
    if mv -f "$temp_dual" "$binary_path"; then
        rm -f "$temp_signed"  # Clean up intermediate file
        print_success "Dual-signed binary ready: $(basename "$binary_path")"

        # Show file info
        if [[ -f "$binary_path" ]]; then
            local size=$(ls -lh "$binary_path" | awk '{print $5}')
            print_info "Final binary size: $size"
            print_info "Binary is now trusted by endpoints with EITHER certificate"
        fi

        return 0
    else
        print_error "Failed to finalize dual-signed binary"
        rm -f "$temp_signed" "$temp_dual"
        return 1
    fi
}

# Verify binary signature
verify_signature() {
    local binary_path="$1"
    local verbose="$2"
    
    if [[ ! -f "$binary_path" ]]; then
        print_error "Binary not found: $binary_path"
        return 1
    fi
    
    print_info "Verifying signature: $(basename "$binary_path")"
    
    local verify_cmd=("osslsigncode" "verify" "$binary_path")
    
    if [[ "$verbose" == "true" ]]; then
        print_info "Command: ${verify_cmd[*]}"
    fi
    
    # Execute verification
    local output
    if output=$("${verify_cmd[@]}" 2>&1); then
        print_success "Signature verified: $(basename "$binary_path")"
        if [[ "$verbose" == "true" ]]; then
            echo "$output"
        fi
        return 0
    else
        print_error "Signature verification failed: $(basename "$binary_path")"
        if [[ "$verbose" == "true" ]]; then
            echo "$output"
        fi
        return 1
    fi
}

# Sign all executables in directory
sign_all_binaries() {
    local directory="$1"
    local cert_file="$2"
    local password="$3"
    local description="$4"
    local url="$5"
    local timestamp_url="$6"
    local verbose="$7"
    
    if [[ ! -d "$directory" ]]; then
        print_error "Directory not found: $directory"
        return 1
    fi
    
    print_info "Signing all executables in: $directory"
    
    local signed_count=0
    local failed_count=0
    
    # Find all .exe files
    while IFS= read -r -d '' exe_file; do
        if sign_binary "$exe_file" "$cert_file" "$password" "" "$description" "$url" "$timestamp_url" "$verbose"; then
            ((signed_count++))
        else
            ((failed_count++))
        fi
    done < <(find "$directory" -name "*.exe" -type f -print0)
    
    print_info "Signing summary: $signed_count successful, $failed_count failed"
    
    if [[ $failed_count -gt 0 ]]; then
        return 1
    fi
    
    return 0
}

# Main function
main() {
    local command=""
    local binary_paths=()
    local directory="build"
    local cert_file=""
    local password=""
    local output_file=""
    local description=""
    local url=""
    local timestamp_url=""
    local verbose=false
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --cert)
                cert_file="$2"
                shift 2
                ;;
            --password)
                password="$2"
                shift 2
                ;;
            --output)
                output_file="$2"
                shift 2
                ;;
            --description)
                description="$2"
                shift 2
                ;;
            --url)
                url="$2"
                shift 2
                ;;
            --timestamp-url)
                timestamp_url="$2"
                shift 2
                ;;
            --verbose)
                verbose=true
                shift
                ;;
            --help)
                show_usage
                exit 0
                ;;
            sign)
                command="sign"
                # Handle multiple files - collect all remaining non-option arguments
                shift
                binary_paths=()
                while [[ $# -gt 0 && ! "$1" =~ ^-- ]]; do
                    # Expand glob patterns
                    for file in $1; do
                        if [[ -f "$file" ]]; then
                            binary_paths+=("$file")
                        fi
                    done
                    shift
                done
                ;;
            sign-nested)
                command="sign-nested"
                shift
                # Expect: <binary> <cert1> <cert2>
                if [[ -n "$1" && ! "$1" =~ ^-- ]]; then
                    binary_paths=("$1")
                    shift
                fi
                # Store cert files in an array for nested signing
                local nested_certs=()
                while [[ $# -gt 0 && ! "$1" =~ ^-- ]]; do
                    nested_certs+=("$1")
                    shift
                done
                # Export for use in case statement (bash array limitation workaround)
                export NESTED_CERT1="${nested_certs[0]:-}"
                export NESTED_CERT2="${nested_certs[1]:-}"
                ;;
            sign-all)
                command="sign-all"
                if [[ -n "$2" && ! "$2" =~ ^-- ]]; then
                    directory="$2"
                    shift 2
                else
                    shift
                fi
                ;;
            verify)
                command="verify"
                # For verify, we only support single file for now
                if [[ -n "$2" && ! "$2" =~ ^-- ]]; then
                    binary_paths=("$2")
                    shift 2
                else
                    shift
                fi
                ;;
            list-certs)
                command="list-certs"
                shift
                ;;
            *)
                print_error "Unknown option: $1"
                show_usage
                exit 1
                ;;
        esac
    done
    
    # Check osslsigncode installation
    check_osslsigncode
    
    # Execute command
    case "$command" in
        sign)
            if [[ ${#binary_paths[@]} -eq 0 ]]; then
                print_error "At least one file path required for sign command"
                show_usage
                exit 1
            fi
            
            # Select certificate if not provided
            if [[ -z "$cert_file" ]]; then
                cert_file=$(select_certificate)
                if [[ $? -ne 0 ]]; then
                    exit 1
                fi
            fi
            
            # Prompt for password if not provided (or auto-read from password file)
            if [[ -z "$password" ]]; then
                password=$(prompt_password "$cert_file")
            fi
            
            # Sign each file
            local signed_count=0
            local failed_count=0
            
            for binary_path in "${binary_paths[@]}"; do
                print_info "Processing file $((signed_count + failed_count + 1)) of ${#binary_paths[@]}: $(basename "$binary_path")"
                if sign_binary "$binary_path" "$cert_file" "$password" "$output_file" "$description" "$url" "$timestamp_url" "$verbose"; then
                    ((signed_count++))
                else
                    ((failed_count++))
                fi
            done
            
            print_info "Signing summary: $signed_count successful, $failed_count failed"
            
            if [[ $failed_count -gt 0 ]]; then
                exit 1
            fi
            ;;
        sign-nested)
            # Validate inputs
            if [[ ${#binary_paths[@]} -eq 0 ]]; then
                print_error "Binary path required for sign-nested command"
                print_info "Usage: $(basename "$0") sign-nested <binary> <cert1> <cert2>"
                exit 1
            fi

            if [[ -z "$NESTED_CERT1" || -z "$NESTED_CERT2" ]]; then
                print_error "Two certificate files required for dual signing"
                print_info "Usage: $(basename "$0") sign-nested <binary> <cert1> <cert2>"
                print_info "Example: $(basename "$0") sign-nested test.exe sb_cert.pfx F0RT1KA.pfx"
                exit 1
            fi

            local binary_path="${binary_paths[0]}"
            local primary_cert="$NESTED_CERT1"
            local secondary_cert="$NESTED_CERT2"

            # Get passwords for both certificates
            print_info "Dual signing requires passwords for both certificates"
            print_info "Primary certificate: $(basename "$primary_cert")"
            local primary_password=$(prompt_password "$primary_cert")

            print_info "Secondary certificate: $(basename "$secondary_cert")"
            local secondary_password=$(prompt_password "$secondary_cert")

            # Perform dual signing
            if sign_binary_nested "$binary_path" "$primary_cert" "$primary_password" "$secondary_cert" "$secondary_password" "$description" "$url" "$timestamp_url" "$verbose"; then
                print_success "Dual signing completed successfully"
                exit 0
            else
                print_error "Dual signing failed"
                exit 1
            fi
            ;;
        sign-all)
            # Select certificate if not provided
            if [[ -z "$cert_file" ]]; then
                cert_file=$(select_certificate)
                if [[ $? -ne 0 ]]; then
                    exit 1
                fi
            fi
            
            # Prompt for password if not provided (or auto-read from password file)
            if [[ -z "$password" ]]; then
                password=$(prompt_password "$cert_file")
            fi
            
            sign_all_binaries "$directory" "$cert_file" "$password" "$description" "$url" "$timestamp_url" "$verbose"
            ;;
        verify)
            if [[ ${#binary_paths[@]} -eq 0 ]]; then
                print_error "File path required for verify command"
                show_usage
                exit 1
            fi
            
            verify_signature "${binary_paths[0]}" "$verbose"
            ;;
        list-certs)
            list_certificates
            ;;
        "")
            print_error "No command specified"
            show_usage
            exit 1
            ;;
        *)
            print_error "Unknown command: $command"
            show_usage
            exit 1
            ;;
    esac
}

# Run main function
main "$@"